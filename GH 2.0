// ===================================================================
// WIPE FUNCTIONS
// ===================================================================
function wipeAllData() {
    if (confirm('⚠️ WARNING: This will delete ALL data including games, stats, ratings, and settings. This CANNOT be undone. Are you sure?')) {
        if (confirm('FINAL WARNING: Really delete everything?')) {
            localStorage.clear();
            sessionStorage.clear();
            showToast("🗑️ All data wiped. Reloading...");
            setTimeout(function() { location.reload(); }, 1000);
        }
    }
}

function wipeStatsOnly() {
    if (confirm('Reset all play counts, ratings, and playtime data? Games will remain.')) {
        totalViews = 0;
        playTimeData = {};
        personalBests = {};
        ratings = {};
        recentlyPlayed = [];
        gameLeaderboards = {};
        for (var i = 0; i < games.length; i++) {
            games[i].views = 0;
        }
        saveAll();
        render();
        showToast("📊 Stats wiped successfully!");
    }
}

// ===================================================================
// UTILITY FUNCTIONS
// ===================================================================
function formatPlayTime(seconds) {
    if (!seconds) return '0min';
    var hours = Math.floor(seconds / 3600);
    var minutes = Math.floor((seconds % 3600) / 60);
    return hours > 0 ? hours + 'h ' + minutes + 'min' : minutes + 'min';
}

function escapeHtml(text) {
    if (!text) return '';
    return text.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function showToast(message, type) {
    type = type || 'success';
    var container = document.getElementById('toastContainer');
    var toast = document.createElement('div');
    toast.className = 'toast ' + type;
    toast.textContent = message;
    container.appendChild(toast);
    setTimeout(function() {
        toast.style.animation = 'slideOut 0.3s ease-out';
        setTimeout(function() { toast.remove(); }, 300);
    }, 3000);
}

function saveAll() {
    saveData("games", games);
    saveData("totalViews", totalViews);
    saveData("playTimeData", playTimeData);
    saveData("personalBests", personalBests);
    saveData("ratings", ratings);
    saveData("favorites", favorites);
    saveData("gameTags", gameTags);
    saveData("recentlyPlayed", recentlyPlayed);
    saveData("updatedGames", updatedGames);
    saveData("gameLeaderboards", gameLeaderboards);
    saveData("customCategories", customCategories);
    saveData("gameTypes", gameTypes);
    saveData("achievements", achievements);
    saveData("unlockedBackgrounds", unlockedBackgrounds);
    saveData("bgMusicUrl", bgMusicUrl);
    saveData("cardSize", cardSize);
    document.getElementById("totalGames").innerText = games.length;
    document.getElementById("totalViews").innerText = totalViews;
    checkAchievements();
}

// ===================================================================
// KEYBOARD SHORTCUTS
// ===================================================================
document.addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'k') {
        e.preventDefault();
        document.getElementById('searchInput').focus();
    }
    if (e.ctrlKey && e.key === 's') {
        e.preventDefault();
        openStats();
    }
    if (e.ctrlKey && e.shiftKey && e.key === ' ') {
        e.preventDefault();
        toggleAI();
    }
    if (e.key === 'Escape') {
        closeStats();
        closeAdmin();
        closeSettings();
        closeAchievements();
        if (currentPlayerGame !== null) {
            closePlayer();
        }
    }
});

// ===================================================================
// AUTHENTICATION
// ===================================================================
function openLogin() {
    document.getElementById("loginOverlay").style.display = "flex";
}

function login() {
    var password = document.getElementById("pass").value;
    if (adminPasswords.indexOf(password) !== -1) {
        unlocked = true;
        sessionStorage.setItem("admin", "true");
        document.getElementById("loginOverlay").style.display = "none";
        document.getElementById("adminPanel").classList.add("active");
        showToast("✅ Admin unlocked!");
    } else {
        showToast("❌ Wrong password!", "error");
    }
}

function toggleAdmin() {
    if (!unlocked) {
        openLogin();
        return;
    }
    document.getElementById("adminPanel").classList.toggle("active");
}

function closeAdmin() {
    document.getElementById("adminPanel").classList.remove("active");
}

function saveAdmins() {
    adminPasswords = document.getElementById("admins").value.split(",").map(function(v) { return v.trim(); }).filter(function(v) { return v; });
    saveData("admins", adminPasswords);
    showToast("✅ Admin passwords saved!");
}

// ===================================================================
// SETTINGS
// ===================================================================
function openSettings() {
    document.getElementById('settingsOverlay').style.display = 'flex';
    document.getElementById('exportCode').value = btoa(encodeURIComponent(JSON.stringify({
        games: games,
        playTimeData: playTimeData,
        personalBests: personalBests,
        ratings: ratings,
        favorites: favorites,
        gameTags: gameTags,
        gameLeaderboards: gameLeaderboards,
        customCategories: customCategories,
        gameTypes: gameTypes,
        achievements: achievements,
        bgMusicUrl: bgMusicUrl
    })));
    populateBGSelect();
    document.getElementById('emojiTheme').value = currentEmojiTheme;
    document.getElementById('cardSize').value = cardSize;
}

function closeSettings() {
    document.getElementById('settingsOverlay').style.display = 'none';
}

function switchSettingsTab(tab, element) {
    document.querySelectorAll('.settings-tab').forEach(function(t) { t.classList.remove('active'); });
    document.querySelectorAll('.settings-content').forEach(function(c) { c.classList.remove('active'); });
    element.classList.add('active');
    document.getElementById('tab-' + tab).classList.add('active');
}

function copyExportCode() {
    document.getElementById('exportCode').select();
    document.execCommand("copy");
    showToast("✅ Code copied to clipboard!");
}

function importGames() {
    var code = document.getElementById("importCode").value.trim();
    if (!code) {
        showToast("❌ Paste import code first!", "error");
        return;
    }
    try {
        var data = JSON.parse(decodeURIComponent(atob(code)));
        if (document.getElementById("replaceExisting").checked) {
            games = data.games || [];
            playTimeData = data.playTimeData || {};
            personalBests = data.personalBests || {};
            ratings = data.ratings || {};
            favorites = data.favorites || [];
            gameTags = data.gameTags || {};
            gameLeaderboards = data.gameLeaderboards || {};
            customCategories = data.customCategories || [];
            gameTypes = data.gameTypes || {};
            achievements = data.achievements || achievements;
            bgMusicUrl = data.bgMusicUrl || '';
        } else {
            games = games.concat(data.games || []);
            Object.assign(playTimeData, data.playTimeData || {});
            Object.assign(personalBests, data.personalBests || {});
            Object.assign(ratings, data.ratings || {});
            favorites = Array.from(new Set(favorites.concat(data.favorites || [])));
            Object.assign(gameTags, data.gameTags || {});
            Object.assign(gameLeaderboards, data.gameLeaderboards || {});
            customCategories = Array.from(new Set(customCategories.concat(data.customCategories || [])));
            Object.assign(gameTypes, data.gameTypes || {});
            if (data.achievements) Object.assign(achievements, data.achievements);
            if (data.bgMusicUrl) bgMusicUrl = data.bgMusicUrl;
        }
        saveAll();
        render();
        renderCategories();
        populateBGSelect();
        if (bgMusicUrl) {
            document.getElementById('bgMusic').src = bgMusicUrl;
            document.getElementById('musicPlayer').classList.add('active');
        }
        filterGames();
        showToast("✅ Data imported successfully!");
    } catch(e) {
        showToast("❌ Invalid import code!", "error");
    }
}

// ===================================================================
// STATISTICS
// ===================================================================
function openStats() {
    document.getElementById('statsOverlay').style.display = 'flex';
    document.getElementById('statsDashboard').style.display = 'block';
    document.getElementById('statTotalGames').innerText = games.length;
    document.getElementById('statTotalPlays').innerText = totalViews;
    var totalTime = 0;
    for (var key in playTimeData) {
        totalTime += playTimeData[key];
    }
    document.getElementById('statTotalTime').innerText = formatPlayTime(totalTime);
    var mostPlayed = games.reduce(function(max, game) {
        return (game.views || 0) > (max.views || 0) ? game : max;
    }, games[0]);
    document.getElementById('statMostPlayed').innerText = mostPlayed ? mostPlayed.title : '-';
    var allRatings = Object.values(ratings).filter(function(r) { return r > 0; });
    document.getElementById('statAvgRating').innerText = allRatings.length ? (allRatings.reduce(function(a, b) { return a + b; }, 0) / allRatings.length).toFixed(1) : '-';
    var unlockedCount = Object.values(achievements).filter(function(a) { return a; }).length;
    document.getElementById('statAchievements').innerText = unlockedCount + '/8';
}

function closeStats() {
    document.getElementById('statsOverlay').style.display = 'none';
    document.getElementById('statsDashboard').style.display = 'none';
}

// ===================================================================
// FILTERS & SEARCH
// ===================================================================
var currentFilter = 'all';

function filterByCategory(category, element) {
    currentFilter = category;
    document.querySelectorAll('.category-tag').forEach(function(tag) {
        tag.classList.remove('active');
    });
    if (element) element.classList.add('active');
    filterGames();
}

function filterGames() {
    var searchTerm = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.card').forEach(function(card) {
        var index = parseInt(card.dataset.index);
        var game = games[index];
        if (!game) {
            card.style.display = 'none';
            return;
        }
        var tags = gameTags[index] || [];
        var matchesSearch = (game.title || '').toLowerCase().indexOf(searchTerm) !== -1 ||
                           (game.desc || '').toLowerCase().indexOf(searchTerm) !== -1 ||
                           tags.some(function(tag) { return tag.toLowerCase().indexOf(searchTerm) !== -1; });
        
        var matchesFilter = true;
        if (currentFilter === 'favorites') {
            matchesFilter = favorites.indexOf(index) !== -1;
        } else if (currentFilter === 'recent') {
            matchesFilter = recentlyPlayed.indexOf(index) !== -1;
        } else if (currentFilter === 'mostPlayed') {
            var sorted = games.slice().sort(function(a, b) { return (b.views || 0) - (a.views || 0); }).slice(0, 10);
            matchesFilter = sorted.indexOf(game) !== -1;
        } else if (currentFilter !== 'all') {
            matchesFilter = tags.map(function(t) { return t.toLowerCase(); }).indexOf(currentFilter.toLowerCase()) !== -1;
        }
        
        card.style.display = (matchesSearch && matchesFilter) ? 'block' : 'none';
    });
}

function addToRecentlyPlayed(index) {
    recentlyPlayed = recentlyPlayed.filter(function(r) { return r !== index; });
    recentlyPlayed.unshift(index);
    if (recentlyPlayed.length > 10) recentlyPlayed.pop();
    saveData('recentlyPlayed', recentlyPlayed);
    updateRecentlyPlayed();
}

function updateRecentlyPlayed() {
    var html = '';
    for (var i = 0; i < recentlyPlayed.length; i++) {
        var idx = recentlyPlayed[i];
        if (games[idx]) {
            html += '<span class="recent-game-chip" onclick="openPlayer(' + idx + ')">🎮 ' + escapeHtml(games[idx].title.substring(0, 15)) + '</span>';
        }
    }
    document.getElementById('recentList').innerHTML = html;
}

// ===================================================================
// FAVORITES & RATINGS
// ===================================================================
function toggleFavorite(index, event) {
    event.stopPropagation();
    if (favorites.indexOf(index) !== -1) {
        favorites = favorites.filter(function(f) { return f !== index; });
    } else {
        favorites.push(index);
    }
    saveAll();
    render();
    filterGames();
}

function rateGame(index, rating, event) {
    event.stopPropagation();
    if (ratings[index] === rating) {
        delete ratings[index];
    } else {
        ratings[index] = rating;
    }
    saveAll();
    render();
}

// ===================================================================
// CUSTOM CATEGORIES
// ===================================================================
function renderCategories() {
    var container = document.getElementById('categoryFilters');
    var html = '<span class="category-tag' + (currentFilter === 'all' ? ' active' : '') + '" onclick="filterByCategory(\'all\', this)">🎯 All</span>';
    html += '<span class="category-tag' + (currentFilter === 'favorites' ? ' active' : '') + '" onclick="filterByCategory(\'favorites\', this)">⭐ Favorites</span>';
    html += '<span class="category-tag' + (currentFilter === 'recent' ? ' active' : '') + '" onclick="filterByCategory(\'recent\', this)">🕐 Recent</span>';
    html += '<span class="category-tag' + (currentFilter === 'mostPlayed' ? ' active' : '') + '" onclick="filterByCategory(\'mostPlayed\', this)">🔥 Popular</span>';
    
    for (var i = 0; i < customCategories.length; i++) {
        var cat = customCategories[i];
        html += '<span class="category-tag" onclick="filterByCategory(\'' + cat.toLowerCase() + '\', this)">' + cat +
            ' <button class="delete-category-btn" onclick="event.stopPropagation(); deleteCategory(\'' + cat + '\')">✕</button></span>';
    }
    
    html += '<span class="add-category-btn" onclick="addCustomCategory()">➕ Add</span>';
    container.innerHTML = html;
}

function addCustomCategory() {
    var name = prompt('Enter new category name:');
    if (name && customCategories.indexOf(name) === -1) {
        customCategories.push(name);
        saveData('customCategories', customCategories);
        renderCategories();
        showToast('✅ Category "' + name + '" created!');
    }
}

function createCustomCategory() {
    var name = document.getElementById('newCategoryName').value.trim();
    if (name && customCategories.indexOf(name) === -1) {
        customCategories.push(name);
        document.getElementById('newCategoryName').value = '';
        saveData('customCategories', customCategories);
        renderCategories();
        updateAdminCategories();
        showToast('✅ Category "' + name + '" created!');
    }
}

function deleteCategory(name) {
    if (confirm('Delete category "' + name + '"?')) {
        customCategories = customCategories.filter(function(c) { return c !== name; });
        saveData('customCategories', customCategories);
        renderCategories();
        filterGames();
        updateAdminCategories();
        showToast('🗑️ Category deleted');
    }
}

function updateAdminCategories() {
    var list = document.getElementById('customCategoriesList');
    if (list) {
        var html = '';
        for (var i = 0; i < customCategories.length; i++) {
            html += '<span style="display:inline-block;background:rgba(0,170,255,0.1);padding:3px 8px;border-radius:8px;margin:2px;font-size:11px;">' + customCategories[i] +
                ' <button onclick="deleteCategory(\'' + customCategories[i] + '\');updateAdminCategories();" style="background:none;border:none;color:red;cursor:pointer;font-size:10px;">✕</button></span>';
        }
        list.innerHTML = html;
    }
}

// ===================================================================
// GAME TYPE HANDLING
// ===================================================================
function toggleCodeInput() {
    var type = document.getElementById('gameType').value;
    document.getElementById('code').style.display = type === 'html' ? 'block' : 'none';
    document.getElementById('codeLabel').style.display = type === 'html' ? 'block' : 'none';
    document.getElementById('youtubeUrl').style.display = type === 'youtube' ? 'block' : 'none';
    document.getElementById('mp4Url').style.display = type === 'mp4' ? 'block' : 'none';
}

function getYouTubeID(url) {
    var match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&\s]+)/);
    return match ? match[1] : null;
}

// ===================================================================
// RENDER GAMES
// ===================================================================
function render() {
    var gamesContainer = document.getElementById("games");
    var adminContainer = document.getElementById("adminList");
    var gamesHtml = '';
    var adminHtml = '';
    
    for (var i = 0; i < games.length; i++) {
        var game = games[i];
        var playTime = playTimeData['game_' + i] || 0;
        var isFav = favorites.indexOf(i) !== -1;
        var tags = gameTags[i] || [];
        var updated = updatedGames.indexOf(i) !== -1;
        var type = gameTypes[i] || 'html';
        var lb = (gameLeaderboards[i] || []).slice(0, 5);
        
        var thumbnail = '';
        if (type === 'youtube' && game.youtubeId) {
            thumbnail = '<iframe class="yt-thumb" src="https://www.youtube.com/embed/' + game.youtubeId + '?controls=0&showinfo=0" style="pointer-events:none;"></iframe>';
        } else if (type === 'mp4' && game.mp4Url) {
            thumbnail = '<video src="' + game.mp4Url + '" muted loop playsinline style="pointer-events:none;"></video>';
        } else {
            thumbnail = '<img src="' + (game.image || 'https://placehold.co/400x200/1a1a2e/00aaff?text=' + encodeURIComponent(game.title || 'Game')) + '" loading="lazy" onerror="this.src=\'https://placehold.co/400x200/1a1a2e/00aaff?text=Game\'">';
        }
        
        gamesHtml += '<div class="card' + (updated ? ' updated' : '') + '" data-index="' + i + '">' +
            (updated ? '<div class="update-badge">🆕</div>' : '') +
            '<button class="favorite-btn' + (isFav ? ' active' : '') + '" onclick="toggleFavorite(' + i + ', event)">' + (isFav ? '❤️' : '🤍') + '</button>' +
            thumbnail +
            '<div class="info">' +
            '<h2>' + escapeHtml(game.title) + '</h2>' +
            '<div class="game-tags">' + tags.map(function(t) { return '<span class="game-tag">' + escapeHtml(t) + '</span>'; }).join('') + '</div>' +
            '<div class="rating">' +
            [1, 2, 3, 4, 5].map(function(s) {
                return '<span class="star' + (s <= (ratings[i] || 0) ? ' active' : '') + '" onclick="rateGame(' + i + ', ' + s + ', event)">★</span>';
            }).join('') +
            (ratings[i] ? ' <span class="star-remove" onclick="rateGame(' + i + ', ' + ratings[i] + ', event)">✕ remove</span>' : '') +
            '</div>' +
            '<div class="desc">' + escapeHtml((game.desc || '').substring(0, 80)) + '</div>' +
            (lb.length ? '<div class="leaderboard-section">🏅 ' + lb.map(function(e, j) {
                return '<div class="leaderboard-entry"><span>' + (j + 1) + '. Player</span><span>' + formatPlayTime(e.time) + '</span></div>';
            }).join('') + '</div>' : '') +
            '<button class="playBtn blue" onclick="openPlayer(' + i + ')">🎮 PLAY</button>' +
            '<div class="meta"><span>👁️ ' + (game.views || 0) + ' plays</span><span>⏱️ ' + formatPlayTime(playTime) + '</span></div>' +
            '</div></div>';
        
        adminHtml += '<div class="admin-game-item">' +
            '<div><b>' + escapeHtml(game.title) + '</b> <small>(' + type + ')</small><br><small>👁️ ' + (game.views || 0) + ' plays</small></div>' +
            '<div>' +
            '<button onclick="startEdit(' + i + ')" style="background:#ff8800;color:white;">✏️</button>' +
            '<button onclick="del(' + i + ')" style="background:#ff4444;color:white;">🗑️</button>' +
            '<button onclick="updatedGames.push(' + i + '); saveAll(); render();" style="background:#00aaff;color:white;">🆕</button>' +
            '</div></div>';
    }
    
    gamesContainer.innerHTML = gamesHtml;
    adminContainer.innerHTML = adminHtml;
    document.getElementById("totalGames").innerText = games.length;
    document.getElementById("totalViews").innerText = totalViews;
    updateRecentlyPlayed();
}

// ===================================================================
// GAME CRUD OPERATIONS
// ===================================================================
var editIndex = null;

function startEdit(index) {
    editIndex = index;
    var game = games[index];
    document.getElementById('title').value = game.title || '';
    document.getElementById('image').value = game.image || '';
    document.getElementById('desc').value = game.desc || '';
    document.getElementById('tags').value = (gameTags[index] || []).join(', ');
    document.getElementById('gameType').value = gameTypes[index] || 'html';
    toggleCodeInput();
    
    if (gameTypes[index] === 'youtube') {
        document.getElementById('youtubeUrl').value = game.youtubeUrl || '';
    } else if (gameTypes[index] === 'mp4') {
        document.getElementById('mp4Url').value = game.mp4Url || '';
    } else {
        document.getElementById('code').value = game.code || '';
    }
    
    var btn = document.getElementById('addGameBtn');
    btn.textContent = '✏️ UPDATE GAME';
    btn.style.background = 'linear-gradient(135deg, #ff8800, #cc6600)';
    btn.onclick = updateGame;
    
    document.getElementById('adminPanel').classList.add('active');
}

function updateGame() {
    if (editIndex === null) return;
    var type = document.getElementById('gameType').value;
    
    games[editIndex] = {
        title: document.getElementById('title').value,
        image: document.getElementById('image').value,
        desc: document.getElementById('desc').value,
        code: type === 'html' ? document.getElementById('code').value : (games[editIndex].code || ''),
        youtubeId: type === 'youtube' ? getYouTubeID(document.getElementById('youtubeUrl').value) : null,
        youtubeUrl: type === 'youtube' ? document.getElementById('youtubeUrl').value : '',
        mp4Url: type === 'mp4' ? document.getElementById('mp4Url').value : '',
        views: games[editIndex].views || 0,
        date: games[editIndex].date || new Date().toLocaleDateString(),
        updated: new Date().toLocaleString()
    };
    
    gameTags[editIndex] = document.getElementById('tags').value.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t; });
    gameTypes[editIndex] = type;
    updatedGames.push(editIndex);
    
    resetForm();
    saveAll();
    render();
    filterGames();
    showToast("✅ Game updated!");
}

function addGame() {
    var title = document.getElementById('title').value;
    var type = document.getElementById('gameType').value;
    var code = type === 'html' ? document.getElementById('code').value : '';
    var youtubeId = type === 'youtube' ? getYouTubeID(document.getElementById('youtubeUrl').value) : null;
    var mp4Url = type === 'mp4' ? document.getElementById('mp4Url').value : '';
    
    if (!title || (type === 'html' && !code) || (type === 'youtube' && !youtubeId) || (type === 'mp4' && !mp4Url)) {
        showToast("❌ Please fill all required fields!", "error");
        return;
    }
    
    var index = games.length;
    games.push({
        title: title,
        image: document.getElementById('image').value,
        desc: document.getElementById('desc').value,
        code: code,
        youtubeId: youtubeId,
        youtubeUrl: type === 'youtube' ? document.getElementById('youtubeUrl').value : '',
        mp4Url: mp4Url,
        views: 0,
        date: new Date().toLocaleDateString(),
        updated: new Date().toLocaleString()
    });
    
    gameTags[index] = document.getElementById('tags').value.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t; });
    gameTypes[index] = type;
    updatedGames.push(index);
    
    resetForm();
    saveAll();
    render();
    showToast("✅ Game added successfully!");
}

function resetForm() {
    ['title', 'image', 'desc', 'code', 'tags', 'youtubeUrl', 'mp4Url'].forEach(function(id) {
        document.getElementById(id).value = '';
    });
    document.getElementById('gameType').value = 'html';
    toggleCodeInput();
    
    var btn = document.getElementById('addGameBtn');
    btn.textContent = '✅ ADD GAME';
    btn.style.background = 'linear-gradient(135deg, #00cc66, #009944)';
    btn.onclick = addGame;
    editIndex = null;
}

function del(index) {
    if (confirm('Delete "' + games[index].title + '"?')) {
        delete playTimeData['game_' + index];
        delete personalBests['game_' + index];
        delete ratings[index];
        delete gameTags[index];
        delete gameLeaderboards[index];
        delete gameTypes[index];
        favorites = favorites.filter(function(f) { return f !== index; });
        games.splice(index, 1);
        saveAll();
        render();
        filterGames();
        showToast("🗑️ Game deleted");
    }
}

function uploadHTMLFile() {
    var file = document.getElementById('htmlFileInput').files[0];
    if (file) {
        var reader = new FileReader();
        reader.onload = function(e) {
            document.getElementById('code').value = e.target.result;
        };
        reader.readAsText(file);
    }
}

function uploadMP4File() {
    var file = document.getElementById('mp4FileInput').files[0];
    if (file) {
        var url = URL.createObjectURL(file);
        document.getElementById('mp4Url').value = url;
        showToast("✅ MP4 file loaded!");
    }
}

// ===================================================================
// INITIALIZATION
// ===================================================================
var savedBG = loadData("bg", "default");
currentBG = savedBG;

populateBGSelect();
document.getElementById('bgSelect').value = savedBG;
document.getElementById('emojiTheme').value = currentEmojiTheme;
document.getElementById('cardSize').value = cardSize;

changeBG();
changeCardSize();

// Initialize particles
var particlesContainer = document.getElementById('particlesContainer');
var fragment = document.createDocumentFragment();
for (var i = 0; i < 130; i++) {
    var span = document.createElement("span");
    span.style.left = Math.random() * 100 + "vw";
    span.style.animationDuration = (Math.random() * 10 + 5) + "s";
    span.style.animationDelay = Math.random() * 5 + "s";
    fragment.appendChild(span);
}
particlesContainer.appendChild(fragment);

// Fullscreen change handler
document.addEventListener('fullscreenchange', function() {
    if (!document.fullscreenElement && currentPlayerGame !== null) {
        // Keep player open but exit fullscreen
    }
});

// Frame observer for legacy frame (if still used)
var frameObserver = new MutationObserver(function(mutations) {
    mutations.forEach(function(m) {
        if (m.type === 'attributes' && m.attributeName === 'style') {
            var frame = document.getElementById('frame');
            if (frame && frame.style.display === 'none') {
                stopPlayerTimer();
            }
        }
    });
});
var legacyFrame = document.getElementById('frame');
if (legacyFrame) {
    frameObserver.observe(legacyFrame, { attributes: true });
}

// Start systems
animateBG();
render();
renderCategories();
updateAdminCategories();

// Intervals
setInterval(spawnEmoji, 2800);
setInterval(saveAll, 30000);
setInterval(checkAchievements, 15000);

// Initial achievement check
checkAchievements();

// Expose functions globally
window.openPlayer = openPlayer;
window.closePlayer = closePlayer;
window.fullscreenPlayer = fullscreenPlayer;
window.newTabPlayer = newTabPlayer;
window.toggleFavorite = toggleFavorite;
window.rateGame = rateGame;
window.startEdit = startEdit;
window.del = del;
window.filterByCategory = filterByCategory;
window.addCustomCategory = addCustomCategory;
window.deleteCategory = deleteCategory;
window.createCustomCategory = createCustomCategory;
window.aiAutoSetup = aiAutoSetup;
window.switchSettingsTab = switchSettingsTab;
window.setMusic = setMusic;
window.setMusicFromAdmin = setMusicFromAdmin;
window.uploadMusic = uploadMusic;
window.wipeAllData = wipeAllData;
window.wipeStatsOnly = wipeStatsOnly;
window.toggleAI = toggleAI;
window.sendAIMessage = sendAIMessage;
window.showAchievements = showAchievements;
window.closeAchievements = closeAchievements;
window.saveAdmins = saveAdmins;
window.toggleAdmin = toggleAdmin;
window.closeAdmin = closeAdmin;
window.uploadHTMLFile = uploadHTMLFile;
window.uploadMP4File = uploadMP4File;
window.changeBG = changeBG;
window.changeEmojiTheme = changeEmojiTheme;
window.changeCardSize = changeCardSize;
</script>
</body>
</html>
