// ===================================================================
// EMOJI SYSTEM
// ===================================================================
var emojiSets = {
    none: [],
    gaming: ["🎮", "🕹️", "👾", "🎯", "🎲", "🏆", "💎", "⭐", "🔥", "⚡", "🎭", "🎪"],
    nature: ["🌿", "🌸", "🌺", "🍃", "🌻", "🦋", "🌈", "💧", "🌙", "☀️", "🌊", "🍀"],
    space: ["🚀", "🌍", "⭐", "🌙", "☄️", "🛸", "💫", "🌟", "🌌", "🪐", "🔭", "✨"],
    party: ["🎉", "🎊", "🥳", "🎈", "🎵", "💃", "🕺", "🎶", "🍾", "🎂", "🎁", "🥂"],
    random: ["🐱", "🐶", "🦄", "🍕", "🌈", "🎸", "📚", "🧩", "🎨", "🧸", "🌮", "🦋"]
};

var activeEmojis = [];

function spawnEmoji() {
    if (document.hidden || currentEmojiTheme === "none") return;
    var set = emojiSets[currentEmojiTheme] || emojiSets.gaming;
    if (!set.length) return;
    
    var emoji = set[Math.floor(Math.random() * set.length)];
    var el = document.createElement('div');
    el.className = 'emoji-float';
    el.textContent = emoji;
    el.style.left = Math.random() * 92 + 'vw';
    el.style.animationDuration = (Math.random() * 10 + 8) + 's';
    el.style.fontSize = (Math.random() * 18 + 20) + 'px';
    el.style.animationDelay = '0s';
    
    document.getElementById('emojiContainer').appendChild(el);
    activeEmojis.push(el);
    
    if (activeEmojis.length > 20) {
        var old = activeEmojis.shift();
        if (old) old.remove();
    }
    
    var duration = parseFloat(el.style.animationDuration) || 14;
    setTimeout(function() {
        el.remove();
        activeEmojis = activeEmojis.filter(function(e) { return e !== el; });
    }, duration * 1000);
}

function changeEmojiTheme() {
    currentEmojiTheme = document.getElementById("emojiTheme").value;
    saveData("emojiTheme", currentEmojiTheme);
}

// ===================================================================
// CARD SIZE
// ===================================================================
function changeCardSize() {
    cardSize = document.getElementById("cardSize").value;
    saveData("cardSize", cardSize);
    var grid = document.getElementById('games');
    if (cardSize === 'compact') {
        grid.style.gridTemplateColumns = 'repeat(auto-fit, minmax(220px, 1fr))';
    } else if (cardSize === 'large') {
        grid.style.gridTemplateColumns = 'repeat(auto-fit, minmax(320px, 1fr))';
    } else {
        grid.style.gridTemplateColumns = 'repeat(auto-fit, minmax(260px, 1fr))';
    }
}

// ===================================================================
// ACHIEVEMENT SYSTEM
// ===================================================================
function checkAchievements() {
    var newAchievements = [];
    
    if (!achievements.firstPlay && totalViews >= 1) {
        achievements.firstPlay = true;
        newAchievements.push("🎮 First Play!");
    }
    if (!achievements.tenPlays && totalViews >= 10) {
        achievements.tenPlays = true;
        newAchievements.push("🔥 10 Plays!");
    }
    if (!achievements.twentyFivePlays && totalViews >= 25) {
        achievements.twentyFivePlays = true;
        newAchievements.push("💪 25 Plays!");
    }
    if (!achievements.favoriteFive && favorites.length >= 5) {
        achievements.favoriteFive = true;
        newAchievements.push("⭐ 5 Favorites!");
    }
    if (!achievements.ratingMaster && Object.keys(ratings).length >= 5) {
        achievements.ratingMaster = true;
        newAchievements.push("⭐ Rating Master!");
    }
    var totalTime = 0;
    for (var key in playTimeData) {
        totalTime += playTimeData[key];
    }
    if (!achievements.playTime1h && totalTime >= 3600) {
        achievements.playTime1h = true;
        newAchievements.push("⏱️ 1 Hour Playtime!");
    }
    if (!achievements.gameCollector && games.length >= 10) {
        achievements.gameCollector = true;
        newAchievements.push("🎯 10 Games Collected!");
    }
    if (!achievements.vibeMaster && totalTime >= 7200 && favorites.length >= 3) {
        achievements.vibeMaster = true;
        newAchievements.push("🌟 Vibe Master!");
    }
    
    for (var i = 0; i < newAchievements.length; i++) {
        showAchievementPopup(newAchievements[i]);
    }
    
    if (newAchievements.length > 0) {
        saveData('achievements', achievements);
    }
}

function showAchievementPopup(text) {
    var popup = document.createElement('div');
    popup.className = 'achievement-popup';
    popup.textContent = text;
    document.body.appendChild(popup);
    setTimeout(function() {
        popup.remove();
    }, 5500);
}

function showAchievements() {
    document.getElementById('achievementsOverlay').style.display = 'flex';
    var allAchievements = [
        { key: 'firstPlay', name: 'First Play', icon: '🎮' },
        { key: 'tenPlays', name: '10 Plays', icon: '🔥' },
        { key: 'twentyFivePlays', name: '25 Plays', icon: '💪' },
        { key: 'favoriteFive', name: '5 Favorites', icon: '⭐' },
        { key: 'ratingMaster', name: 'Rating Master', icon: '⭐' },
        { key: 'playTime1h', name: '1 Hour', icon: '⏱️' },
        { key: 'gameCollector', name: '10 Games', icon: '🎯' },
        { key: 'vibeMaster', name: 'Vibe Master', icon: '🌟' }
    ];
    
    document.getElementById('achievementsList').innerHTML = allAchievements.map(function(a) {
        var unlocked = achievements[a.key];
        return '<div style="display:flex;align-items:center;gap:10px;padding:10px;background:rgba(255,255,255,' + (unlocked ? '0.08' : '0.03') + ');border-radius:10px;margin:4px 0;' + (unlocked ? 'border:2px solid #ffd700;' : 'opacity:0.5;') + '">' +
            '<span style="font-size:24px;">' + a.icon + '</span>' +
            '<div><b>' + a.name + '</b></div>' +
            '<span style="margin-left:auto;font-size:18px;">' + (unlocked ? '✅' : '🔒') + '</span>' +
            '</div>';
    }).join('');
}

function closeAchievements() {
    document.getElementById('achievementsOverlay').style.display = 'none';
}

// ===================================================================
// AI ASSISTANT (ENHANCED FOR EXPERIENCE)
// ===================================================================
function toggleAI() {
    document.getElementById('aiChat').classList.toggle('active');
}

function sendAIMessage() {
    var input = document.getElementById('aiInput');
    var message = input.value.trim();
    if (!message) return;
    
    var messages = document.getElementById('aiMessages');
    messages.innerHTML += '<div class="ai-message user">' + escapeHtml(message) + '</div>';
    input.value = '';
    messages.scrollTop = messages.scrollHeight;
    
    setTimeout(function() {
        var response = generateAIResponse(message);
        messages.innerHTML += '<div class="ai-message bot">' + response + '</div>';
        messages.scrollTop = messages.scrollHeight;
    }, 450);
}

function generateAIResponse(message) {
    var lower = message.toLowerCase();
    
    if (lower.indexOf('auto setup') !== -1 || lower.indexOf('fill info') !== -1) {
        var title = document.getElementById('title').value || 'New Game';
        if (!document.getElementById('title').value) {
            document.getElementById('title').value = title;
        }
        document.getElementById('desc').value = 'An awesome ' + title + ' experience! Play now and have fun.';
        document.getElementById('tags').value = 'fun, game';
        document.getElementById('image').value = 'https://source.unsplash.com/400x200/?' + encodeURIComponent(title + ' game');
        return '✅ Auto-setup complete for <b>"' + escapeHtml(title) + '"</b>! Image, description, and tags have been filled. You can now add the game code and save it.';
    }
    
    if (lower.indexOf('suggest bg') !== -1 || lower.indexOf('pick background') !== -1 || lower.indexOf('change bg') !== -1) {
        var backgrounds = ['default', 'matrix', 'stars', 'cartoon', 'nick', 'void', 'dmc', 'aurora', 'sunrise', 'neon', 'galaxy', 'fireice', 'ocean', 'forest'];
        var bg = backgrounds[Math.floor(Math.random() * backgrounds.length)];
        currentBG = bg;
        saveData('bg', bg);
        populateBGSelect();
        document.getElementById('bgSelect').value = bg;
        changeBG();
        var bgNames = {default:'Default Cosmic',matrix:'Matrix Rain',stars:'Starry Night',cartoon:'Cartoon Network',nick:'Nickelodeon',void:'Infinite Void',dmc:'Devil May Cry',aurora:'Aurora Waves',sunrise:'Golden Sunrise',neon:'Neon City',galaxy:'Spiral Galaxy',fireice:'Fire vs Ice',ocean:'Deep Ocean',forest:'Mystic Forest'};
        return '🎨 Switched to <b>' + (bgNames[bg] || bg) + '</b> background! Enjoy the new aesthetic vibe.';
    }
    
    if (lower.indexOf('set mood') !== -1 || lower.indexOf('vibe') !== -1) {
        var moods = [
            { bg: 'aurora', music: 'chill' },
            { bg: 'neon', music: 'synthwave' },
            { bg: 'sunrise', music: 'lo-fi' },
            { bg: 'void', music: 'ambient' },
            { bg: 'dmc', music: 'rock' }
        ];
        var mood = moods[Math.floor(Math.random() * moods.length)];
        currentBG = mood.bg;
        saveData('bg', mood.bg);
        populateBGSelect();
        document.getElementById('bgSelect').value = mood.bg;
        changeBG();
        return '🎭 Mood set! Background changed to match a <b>' + mood.music + '</b> vibe. Want music too? Add a URL in Settings → Music tab.';
    }
    
    if (lower.indexOf('music') !== -1 || lower.indexOf('song') !== -1 || lower.indexOf('audio') !== -1) {
        return '🎵 You can set background music in <b>Settings → Music tab</b> or in the <b>Admin Panel</b>. Paste any MP3/WAV URL or upload a file. The music player will appear in the bottom-left corner.';
    }
    
    if (lower.indexOf('improve') !== -1 || lower.indexOf('enhance') !== -1 || lower.indexOf('tip') !== -1 || lower.indexOf('help') !== -1) {
        return '💡 <b>Pro Tips:</b><br>• Use <b>Ctrl+K</b> to search games<br>• Use <b>Ctrl+Shift+Space</b> to open me<br>• Rate games by clicking stars<br>• Click a rated star again to remove rating<br>• Favorite games with the ❤️ button<br>• Try different backgrounds in Settings<br>• Say "suggest bg" to switch backgrounds<br>• Say "auto setup" to fill game info';
    }
    
    if (lower.indexOf('hello') !== -1 || lower.indexOf('hi') !== -1 || lower.indexOf('hey') !== -1) {
        return 'Hey there! 👋 Ready to game? Try saying <b>"suggest bg"</b> to change the vibe, or <b>"auto setup"</b> to fill game info quickly.';
    }
    
    return '🤔 I can help with:<br>• <b>"auto setup"</b> - Fill game info<br>• <b>"suggest bg"</b> - Change background<br>• <b>"set mood"</b> - Pick a vibe<br>• <b>"improve experience"</b> - Get tips<br>• <b>"music"</b> - Info about BG music<br>What would you like?';
}

function aiAutoSetup() {
    var response = generateAIResponse('auto setup');
    var chat = document.getElementById('aiChat');
    var messages = document.getElementById('aiMessages');
    chat.classList.add('active');
    messages.innerHTML += '<div class="ai-message bot">' + response + '</div>';
    messages.scrollTop = messages.scrollHeight;
}

