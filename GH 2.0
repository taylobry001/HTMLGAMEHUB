<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
<title>Ultimate Game Hub v3.5</title>
<style>
:root {
    --bg-primary: #050505;
    --bg-secondary: rgba(20, 20, 20, 0.75);
    --bg-card: rgba(20, 20, 20, 0.65);
    --accent: #00aaff;
    --accent2: #0066cc;
    --text: #ffffff;
    --text-secondary: #aaa;
    --border: rgba(255, 255, 255, 0.08);
    --input-bg: #2a2a2a;
    --success: #00aa55;
    --danger: #ff4444;
    --warning: #ffaa00;
    --purple: #8844ff;
    --orange: #ff8800;
    --pink: #ff4488;
    --cyan: #00ffcc;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', system-ui, -apple-system, sans-serif;
}

body {
    background: var(--bg-primary);
    color: var(--text);
    overflow-x: hidden;
    transition: background 0.8s ease;
    -webkit-tap-highlight-color: transparent;
    -webkit-font-smoothing: antialiased;
}

/* Loading Screen */
#loadingScreen {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #000;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    transition: opacity 0.5s ease, visibility 0.5s ease;
}
#loadingScreen.hidden {
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
}
.loading-spinner {
    width: 60px;
    height: 60px;
    border: 3px solid rgba(0, 170, 255, 0.2);
    border-top-color: #00aaff;
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
}
@keyframes spin {
    to { transform: rotate(360deg); }
}
.loading-text {
    color: #00aaff;
    margin-top: 20px;
    font-size: 14px;
    animation: loadingPulse 1.5s ease-in-out infinite;
}
@keyframes loadingPulse {
    0%, 100% { opacity: 0.5; }
    50% { opacity: 1; }
}
.loading-bar {
    width: 200px;
    height: 3px;
    background: rgba(0, 170, 255, 0.2);
    border-radius: 3px;
    margin-top: 15px;
    overflow: hidden;
    position: relative;
}
.loading-bar::after {
    content: '';
    position: absolute;
    top: 0;
    left: -50%;
    width: 50%;
    height: 100%;
    background: #00aaff;
    animation: loadingBar 1.5s ease-in-out infinite;
}
@keyframes loadingBar {
    0% { left: -50%; }
    100% { left: 150%; }
}

/* Game Player Page */
#gamePlayer {
    position: fixed;
    inset: 0;
    z-index: 10001;
    background: #000;
    display: none;
    flex-direction: column;
}
#gamePlayer.active {
    display: flex;
}
#gamePlayerHeader {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px 16px;
    background: rgba(0, 0, 0, 0.95);
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    z-index: 10;
}
#gamePlayerTitle {
    color: white;
    font-weight: bold;
    font-size: 14px;
    max-width: 50%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}
.player-buttons {
    display: flex;
    gap: 6px;
}
.player-btn {
    padding: 6px 12px;
    border: none;
    border-radius: 6px;
    color: white;
    cursor: pointer;
    font-size: 12px;
    transition: 0.2s;
    font-weight: 600;
}
.player-btn:hover {
    filter: brightness(1.2);
}
.player-btn.fullscreen {
    background: #8844ff;
}
.player-btn.newtab {
    background: #ff8800;
}
.player-btn.close {
    background: #ff4444;
}
#gamePlayerFrame {
    flex: 1;
    width: 100%;
    border: none;
    background: #000;
}

/* Live Timer */
#liveTimer {
    position: fixed;
    top: 12px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    background: rgba(0, 0, 0, 0.85);
    color: #00ff88;
    padding: 5px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-family: 'Courier New', monospace;
    border: 1px solid rgba(0, 255, 136, 0.3);
    backdrop-filter: blur(10px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
    letter-spacing: 1px;
}
#liveTimer.visible {
    opacity: 1;
}

/* Session Play Timer */
#sessionPlayTimer {
    position: fixed;
    top: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 100;
    background: rgba(0, 0, 0, 0.85);
    color: #ffaa00;
    padding: 4px 12px;
    border-radius: 15px;
    font-size: 11px;
    font-family: 'Courier New', monospace;
    border: 1px solid rgba(255, 170, 0, 0.3);
    backdrop-filter: blur(10px);
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.3s ease;
}
#sessionPlayTimer.visible {
    opacity: 1;
}

/* === BACKGROUND EFFECTS === */
.bgEffects {
    position: fixed;
    inset: 0;
    z-index: -3;
    overflow: hidden;
    pointer-events: none;
}
#bgCanvas {
    position: fixed;
    inset: 0;
    z-index: -3;
    pointer-events: none;
    opacity: 0.85;
    will-change: transform;
}

/* Floating Emojis */
.emoji-float {
    position: fixed;
    z-index: -1;
    pointer-events: none;
    font-size: 28px;
    animation: emojiDrift linear infinite;
    opacity: 0.5;
    will-change: transform;
    filter: drop-shadow(0 0 6px rgba(255, 255, 255, 0.3));
}
@keyframes emojiDrift {
    0% {
        transform: translateY(105vh) rotate(0deg) scale(0.5);
        opacity: 0;
    }
    10% {
        opacity: 0.6;
    }
    90% {
        opacity: 0.6;
    }
    100% {
        transform: translateY(-15vh) rotate(360deg) scale(1.2);
        opacity: 0;
    }
}

/* Standard Particles */
.particles {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
}
.particles span {
    position: absolute;
    width: 3px;
    height: 3px;
    background: white;
    opacity: 0.12;
    border-radius: 50%;
    animation: float linear infinite;
    will-change: transform;
}
.particles span:nth-child(odd) {
    width: 2px;
    height: 2px;
    background: #00aaff;
    box-shadow: 0 0 4px #00aaff;
}
.particles span:nth-child(3n) {
    width: 4px;
    height: 4px;
    background: #0066cc;
    box-shadow: 0 0 6px #0066cc;
    opacity: 0.18;
}
.particles span:nth-child(5n) {
    width: 5px;
    height: 5px;
    background: #ff4488;
    box-shadow: 0 0 8px #ff4488;
    opacity: 0.22;
}
@keyframes float {
    from {
        transform: translateY(100vh) rotate(0deg);
    }
    to {
        transform: translateY(-10vh) rotate(360deg);
    }
}

/* Glow Orbs */
.glowOrb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.25;
    animation: floatOrb 12s ease-in-out infinite;
    will-change: transform;
}
.glowOrb:nth-child(2) {
    animation-delay: -4s;
    animation-duration: 15s;
}
.glowOrb:nth-child(3) {
    animation-delay: -8s;
    animation-duration: 18s;
}
.glowOrb:nth-child(4) {
    animation-delay: -3s;
    animation-duration: 20s;
    width: 250px;
    height: 250px;
    background: #ff4488;
    top: 40%;
    left: 70%;
}
.glowOrb:nth-child(5) {
    animation-delay: -6s;
    animation-duration: 22s;
    width: 300px;
    height: 300px;
    background: #8844ff;
    top: 80%;
    left: 40%;
}
@keyframes floatOrb {
    0% {
        transform: translate(0, 0) scale(1);
    }
    25% {
        transform: translate(100px, -80px) scale(1.2);
    }
    50% {
        transform: translate(-60px, -120px) scale(1.3);
    }
    75% {
        transform: translate(-100px, -30px) scale(1.1);
    }
    100% {
        transform: translate(0, 0) scale(1);
    }
}

/* === HEADER === */
header {
    text-align: center;
    padding: 18px 15px;
    background: var(--bg-secondary);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 10;
}
header h1 {
    font-size: clamp(28px, 6vw, 42px);
    background: linear-gradient(135deg, #00aaff, #8844ff, #ff4488);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 20px rgba(0, 170, 255, 0.5));
    animation: titleShine 3s ease-in-out infinite;
    letter-spacing: 1px;
}
@keyframes titleShine {
    0%, 100% {
        filter: drop-shadow(0 0 20px rgba(0, 170, 255, 0.5));
    }
    50% {
        filter: drop-shadow(0 0 40px rgba(136, 68, 255, 0.8));
    }
}

/* === TOPBAR === */
.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 16px;
    background: rgba(15, 15, 15, 0.7);
    backdrop-filter: blur(16px);
    flex-wrap: wrap;
    gap: 8px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.search-area {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(0, 0, 0, 0.5);
    padding: 5px 14px;
    border-radius: 30px;
    border: 1px solid rgba(0, 170, 255, 0.3);
    transition: 0.3s ease;
    flex: 1;
    min-width: 160px;
    max-width: 280px;
}
.search-area:focus-within {
    border-color: #00aaff;
    box-shadow: 0 0 20px rgba(0, 170, 255, 0.4);
}
.search-area input {
    background: transparent;
    border: none;
    color: white;
    padding: 6px;
    width: 100%;
    outline: none;
    font-size: 13px;
}
.search-area input::placeholder {
    color: rgba(255, 255, 255, 0.3);
}
.topbar-stats {
    color: #aaa;
    font-size: 12px;
    white-space: nowrap;
}
.topbar-buttons {
    display: flex;
    gap: 5px;
}
.gear {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: white;
    font-size: 18px;
    cursor: pointer;
    transition: 0.3s ease;
    padding: 7px 10px;
    border-radius: 10px;
    position: relative;
}
.gear:hover {
    transform: scale(1.1);
    background: rgba(0, 170, 255, 0.2);
    border-color: #00aaff;
    box-shadow: 0 0 15px rgba(0, 170, 255, 0.3);
}

/* === CATEGORY FILTERS === */
.category-filters {
    display: flex;
    gap: 5px;
    padding: 8px 16px;
    flex-wrap: wrap;
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    align-items: center;
}
.category-tag {
    padding: 5px 12px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #aaa;
    cursor: pointer;
    font-size: 11px;
    transition: 0.3s ease;
    white-space: nowrap;
    user-select: none;
}
.category-tag:hover, .category-tag.active {
    background: rgba(0, 170, 255, 0.25);
    border-color: #00aaff;
    color: #00aaff;
    box-shadow: 0 0 15px rgba(0, 170, 255, 0.2);
    transform: translateY(-1px);
}
.add-category-btn {
    padding: 5px 10px;
    border-radius: 20px;
    background: rgba(0, 170, 255, 0.2);
    border: 1px dashed #00aaff;
    color: #00aaff;
    cursor: pointer;
    font-size: 11px;
    transition: 0.3s ease;
}
.add-category-btn:hover {
    background: rgba(0, 170, 255, 0.4);
}
.delete-category-btn {
    padding: 1px 6px;
    border-radius: 8px;
    background: rgba(255, 0, 0, 0.2);
    border: none;
    color: #ff6666;
    cursor: pointer;
    font-size: 9px;
    margin-left: 3px;
    transition: 0.2s ease;
}
.delete-category-btn:hover {
    background: rgba(255, 0, 0, 0.5);
}

/* === RECENTLY PLAYED === */
.recently-played {
    padding: 8px 16px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 8px;
    align-items: center;
    flex-wrap: wrap;
}
.recently-played > span {
    color: var(--accent);
    font-size: 12px;
}
.recent-game-chip {
    padding: 4px 10px;
    background: rgba(0, 170, 255, 0.1);
    border: 1px solid rgba(0, 170, 255, 0.3);
    border-radius: 15px;
    font-size: 11px;
    cursor: pointer;
    white-space: nowrap;
    transition: 0.2s ease;
}
.recent-game-chip:hover {
    background: rgba(0, 170, 255, 0.3);
    transform: scale(1.05);
}

/* === GAMES GRID === */
.games {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 14px;
    padding: 14px;
}
@media (max-width: 600px) {
    .games {
        grid-template-columns: 1fr;
        gap: 10px;
        padding: 10px;
    }
}
.card {
    background: var(--bg-card);
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.3);
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    will-change: transform;
    contain: layout style;
}
.card:hover {
    transform: translateY(-8px);
    box-shadow: 0 0 35px rgba(0, 170, 255, 0.35), 0 8px 30px rgba(0, 0, 0, 0.5);
    border-color: rgba(0, 170, 255, 0.3);
}
.card:active {
    transform: scale(0.97);
    transition: 0.1s ease;
}
.card img, .card video, .card iframe.yt-thumb {
    width: 100%;
    height: 160px;
    object-fit: cover;
    background: #1a1a1a;
    border: none;
    pointer-events: none;
    content-visibility: auto;
}
.card:hover img {
    transform: scale(1.03);
    transition: 0.4s ease;
}
.info {
    padding: 12px;
}
.info h2 {
    font-size: 15px;
    margin-bottom: 5px;
    font-weight: 600;
}
.desc {
    color: var(--text-secondary);
    font-size: 11px;
    margin-bottom: 6px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.meta {
    color: #666;
    font-size: 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 5px;
}
.game-tags {
    display: flex;
    gap: 3px;
    flex-wrap: wrap;
    margin: 3px 0;
}
.game-tag {
    padding: 2px 7px;
    background: rgba(0, 170, 255, 0.12);
    border-radius: 8px;
    font-size: 9px;
    color: #00aaff;
    border: 1px solid rgba(0, 170, 255, 0.2);
}

/* === BUTTONS === */
.playBtn {
    width: 100%;
    padding: 9px;
    margin-top: 5px;
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
    transition: 0.2s ease;
    font-weight: bold;
    font-size: 12px;
    letter-spacing: 0.3px;
}
.playBtn:hover {
    filter: brightness(1.15);
}
.playBtn:active {
    transform: scale(0.96);
}
.blue {
    background: linear-gradient(135deg, #0099ff, #0066cc);
}
.green {
    background: linear-gradient(135deg, #00cc66, #009944);
}
.purple {
    background: linear-gradient(135deg, #8844ff, #6622cc);
}
.orange {
    background: linear-gradient(135deg, #ff8800, #cc6600);
}
.red-btn {
    background: linear-gradient(135deg, #ff4444, #cc2222);
}

/* === FAVORITES & RATING === */
.favorite-btn {
    position: absolute;
    top: 8px;
    right: 8px;
    background: rgba(0, 0, 0, 0.65);
    border: 2px solid rgba(255, 255, 255, 0.15);
    color: white;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 14px;
    transition: 0.2s ease;
    z-index: 5;
    display: flex;
    align-items: center;
    justify-content: center;
}
.favorite-btn:hover {
    transform: scale(1.15);
    border-color: #ff4488;
}
.favorite-btn.active {
    color: #ff4081;
    background: rgba(255, 0, 100, 0.3);
    border-color: #ff4081;
}
.rating {
    display: flex;
    gap: 2px;
    margin: 3px 0;
    align-items: center;
}
.star {
    color: #444;
    cursor: pointer;
    font-size: 14px;
    transition: 0.2s ease;
}
.star:hover, .star.active {
    color: #ffd700;
    text-shadow: 0 0 6px #ffd700;
    transform: scale(1.15);
}
.star-remove {
    color: #ff4444;
    cursor: pointer;
    font-size: 9px;
    margin-left: 3px;
    opacity: 0.6;
    transition: 0.2s ease;
}
.star-remove:hover {
    opacity: 1;
    transform: scale(1.2);
}

/* === LEADERBOARD === */
.leaderboard-section {
    background: rgba(255, 170, 0, 0.06);
    border: 1px solid rgba(255, 170, 0, 0.2);
    border-radius: 8px;
    padding: 8px;
    margin-top: 5px;
    font-size: 10px;
    color: #ffaa00;
    max-height: 100px;
    overflow-y: auto;
}
.leaderboard-entry {
    display: flex;
    justify-content: space-between;
    padding: 2px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.04);
}

/* === ACHIEVEMENT POPUP === */
.achievement-popup {
    position: fixed;
    bottom: 25px;
    left: 50%;
    transform: translateX(-50%);
    background: linear-gradient(135deg, #ffd700, #ff8c00);
    color: #000;
    padding: 12px 24px;
    border-radius: 50px;
    font-weight: bold;
    font-size: 13px;
    z-index: 10003;
    animation: achievePop 0.6s ease-out, achieveFade 3s 2.5s forwards;
    white-space: nowrap;
    box-shadow: 0 0 35px rgba(255, 215, 0, 0.6);
}
@keyframes achievePop {
    0% {
        transform: translateX(-50%) scale(0) rotate(-10deg);
    }
    60% {
        transform: translateX(-50%) scale(1.2) rotate(3deg);
    }
    100% {
        transform: translateX(-50%) scale(1) rotate(0deg);
    }
}
@keyframes achieveFade {
    to {
        opacity: 0;
        transform: translateX(-50%) translateY(-25px);
    }
}

/* === AI ASSISTANT === */
.ai-assistant {
    position: fixed;
    bottom: 16px;
    right: 16px;
    z-index: 9999;
}
.ai-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00aaff, #8844ff);
    border: none;
    color: white;
    font-size: 24px;
    cursor: pointer;
    box-shadow: 0 0 25px rgba(0, 170, 255, 0.5);
    transition: 0.3s ease;
    animation: aiPulse 2s ease-in-out infinite;
}
@keyframes aiPulse {
    0%, 100% {
        box-shadow: 0 0 25px rgba(0, 170, 255, 0.5);
    }
    50% {
        box-shadow: 0 0 45px rgba(136, 68, 255, 0.8);
    }
}
.ai-btn:hover {
    transform: scale(1.15);
}
.ai-chat {
    position: absolute;
    bottom: 65px;
    right: 0;
    width: 320px;
    height: 380px;
    background: rgba(10, 10, 20, 0.98);
    border: 1px solid rgba(0, 170, 255, 0.5);
    border-radius: 16px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 0 40px rgba(0, 0, 0, 0.8);
}
@media (max-width: 400px) {
    .ai-chat {
        width: 280px;
        height: 340px;
    }
}
.ai-chat.active {
    display: flex;
}
.ai-chat-header {
    padding: 10px 14px;
    background: rgba(0, 170, 255, 0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    color: #00aaff;
    font-size: 13px;
}
.ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
    font-size: 11px;
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.ai-message {
    padding: 8px 12px;
    border-radius: 12px;
    max-width: 85%;
    line-height: 1.4;
    animation: msgPop 0.3s ease-out;
}
@keyframes msgPop {
    from {
        opacity: 0;
        transform: translateY(8px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}
.ai-message.user {
    background: rgba(0, 170, 255, 0.25);
    margin-left: auto;
    color: white;
}
.ai-message.bot {
    background: rgba(255, 255, 255, 0.08);
    color: #ccc;
}
.ai-input-area {
    display: flex;
    padding: 8px;
    gap: 6px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}
.ai-input-area input {
    flex: 1;
    padding: 8px 12px;
    border-radius: 20px;
    border: 1px solid rgba(0, 170, 255, 0.4);
    background: rgba(0, 0, 0, 0.4);
    color: white;
    font-size: 11px;
    outline: none;
}
.ai-input-area button {
    padding: 8px 14px;
    border-radius: 20px;
    background: #00aaff;
    border: none;
    color: white;
    cursor: pointer;
    font-weight: bold;
    transition: 0.2s ease;
}

/* === MODALS === */
.overlay {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.9);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    backdrop-filter: blur(10px);
}
.modal {
    background: #1a1a25;
    padding: 22px;
    border-radius: 18px;
    border: 1px solid rgba(0, 170, 255, 0.3);
    animation: modalPop 0.3s ease-out;
    max-height: 85vh;
    overflow-y: auto;
    width: 90%;
    max-width: 550px;
}
@keyframes modalPop {
    from {
        transform: scale(0.85);
        opacity: 0;
    }
    to {
        transform: scale(1);
        opacity: 1;
    }
}
.modal-sm {
    max-width: 340px;
}
.modal input, .modal textarea, .modal select {
    width: 100%;
    padding: 9px;
    margin-top: 6px;
    border: 1px solid #333;
    border-radius: 10px;
    background: #222;
    color: white;
    font-size: 12px;
    outline: none;
    transition: 0.3s ease;
}
.modal input:focus, .modal textarea:focus {
    border-color: #00aaff;
    box-shadow: 0 0 12px rgba(0, 170, 255, 0.2);
}
.modal button {
    padding: 9px;
    margin-top: 8px;
    border-radius: 10px;
    border: none;
    color: white;
    cursor: pointer;
    font-weight: bold;
    transition: 0.3s ease;
    width: 100%;
}
.stat-item {
    display: flex;
    justify-content: space-between;
    padding: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    font-size: 13px;
}
.stat-value {
    color: #00aaff;
    font-weight: bold;
}

/* === SETTINGS TABS === */
.settings-tabs {
    display: flex;
    gap: 3px;
    margin-bottom: 14px;
    flex-wrap: wrap;
}
.settings-tab {
    padding: 6px 11px;
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: #aaa;
    cursor: pointer;
    font-size: 11px;
    transition: 0.2s ease;
    white-space: nowrap;
}
.settings-tab.active {
    background: rgba(0, 170, 255, 0.2);
    border-color: #00aaff;
    color: #00aaff;
}
.settings-content {
    display: none;
}
.settings-content.active {
    display: block;
}

/* === ADMIN PANEL === */
.adminPanel {
    position: fixed;
    top: 0;
    right: -100%;
    width: 100%;
    max-width: 460px;
    height: 100%;
    overflow: auto;
    background: rgba(8, 8, 15, 0.98);
    backdrop-filter: blur(20px);
    box-shadow: -8px 0 40px rgba(0, 0, 0, 0.6);
    padding: 18px;
    transition: 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    z-index: 9998;
    border-left: 1px solid rgba(0, 170, 255, 0.3);
}
.adminPanel.active {
    right: 0;
}
.adminPanel h2, .adminPanel h3 {
    color: #00aaff;
    margin-bottom: 8px;
    font-size: 14px;
}
.adminPanel label {
    display: block;
    color: #aaa;
    font-size: 11px;
    margin-top: 8px;
}
.adminPanel input, .adminPanel textarea, .adminPanel select {
    width: 100%;
    padding: 8px;
    margin-top: 3px;
    border: 1px solid #333;
    border-radius: 8px;
    background: #1a1a1a;
    color: white;
    font-size: 11px;
}
.adminPanel textarea {
    min-height: 60px;
    resize: vertical;
    font-family: monospace;
    font-size: 10px;
}
.file-label {
    display: inline-block;
    background: #333;
    padding: 6px 10px;
    border-radius: 8px;
    margin: 4px 2px;
    cursor: pointer;
    font-size: 10px;
    transition: 0.2s ease;
    border: 1px solid #555;
    color: #ccc;
}
.file-label:hover {
    background: #444;
    border-color: #00aaff;
}
.admin-game-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 8px;
    margin: 3px 0;
    background: rgba(255, 255, 255, 0.02);
    border-radius: 8px;
    border: 1px solid rgba(255, 255, 255, 0.04);
    font-size: 11px;
}
.admin-game-item button {
    padding: 4px 8px;
    margin: 1px;
    border-radius: 6px;
    border: none;
    cursor: pointer;
    font-size: 10px;
    color: white;
}

/* === MUSIC PLAYER === */
#musicPlayer {
    position: fixed;
    bottom: 75px;
    left: 15px;
    z-index: 9998;
    background: rgba(0, 0, 0, 0.85);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 10px;
    padding: 8px;
    display: none;
    backdrop-filter: blur(10px);
}
#musicPlayer.active {
    display: block;
}
#musicPlayer audio {
    width: 180px;
    height: 25px;
}
#musicPlayer audio::-webkit-media-controls-panel {
    background: rgba(0, 0, 0, 0.5);
}

/* === TOAST === */
.toast-container {
    position: fixed;
    top: 12px;
    right: 12px;
    z-index: 99999;
    display: flex;
    flex-direction: column;
    gap: 6px;
}
.toast {
    background: rgba(20, 20, 30, 0.95);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(0, 170, 255, 0.3);
    padding: 10px 18px;
    border-radius: 10px;
    color: white;
    animation: slideIn 0.3s ease-out;
    min-width: 180px;
    font-size: 12px;
    box-shadow: 0 8px 25px rgba(0, 0, 0, 0.4);
}
.toast.success {
    border-color: #00cc66;
}
.toast.error {
    border-color: #ff4444;
}
@keyframes slideIn {
    from {
        transform: translateX(100%);
        opacity: 0;
    }
    to {
        transform: translateX(0);
        opacity: 1;
    }
}

/* === SCROLLBAR === */
::-webkit-scrollbar {
    width: 4px;
}
::-webkit-scrollbar-track {
    background: transparent;
}
::-webkit-scrollbar-thumb {
    background: rgba(0, 170, 255, 0.25);
    border-radius: 2px;
}
::-webkit-scrollbar-thumb:hover {
    background: rgba(0, 170, 255, 0.5);
}

/* === RESPONSIVE === */
@media (max-width: 768px) {
    header h1 {
        font-size: 26px;
    }
    .games {
        grid-template-columns: 1fr;
    }
    .adminPanel {
        max-width: 100%;
    }
    .ai-chat {
        width: 280px;
        height: 340px;
    }
    .topbar {
        flex-direction: column;
        gap: 6px;
    }
    .search-area {
        max-width: 100%;
    }
}
</style>
</head>
<body>

<!-- Loading Screen -->
<div id="loadingScreen">
    <div class="loading-spinner"></div>
    <div class="loading-text">Loading Game Hub...</div>
    <div class="loading-bar"></div>
</div>

<!-- Live Timer -->
<div id="liveTimer">00:00:00</div>

<!-- Session Play Timer -->
<div id="sessionPlayTimer"></div>

<!-- Game Player -->
<div id="gamePlayer">
    <div id="gamePlayerHeader">
        <span id="gamePlayerTitle">Game</span>
        <div class="player-buttons">
            <button class="player-btn fullscreen" onclick="fullscreenPlayer()">⛶ Fullscreen</button>
            <button class="player-btn newtab" onclick="newTabPlayer()">🔗 Open Tab</button>
            <button class="player-btn close" onclick="closePlayer()">✕ Close</button>
        </div>
    </div>
    <iframe id="gamePlayerFrame" sandbox="allow-scripts allow-same-origin allow-presentation allow-popups" allow="autoplay; encrypted-media"></iframe>
</div>

<!-- Music Player -->
<div id="musicPlayer">
    <audio id="bgMusic" controls loop></audio>
    <button onclick="document.getElementById('musicPlayer').classList.remove('active');" style="background:red;color:white;border:none;padding:3px 6px;border-radius:4px;cursor:pointer;font-size:9px;display:block;margin-top:3px;">✕ Hide</button>
</div>

<!-- Background Effects -->
<div class="bgEffects" id="bgEffects">
    <canvas id="bgCanvas"></canvas>
    <div class="glowOrb" style="width: 350px; height: 350px; background: #00aaff; top: 15%; left: 20%;"></div>
    <div class="glowOrb" style="width: 300px; height: 300px; background: #0066cc; top: 45%; left: 55%;"></div>
    <div class="glowOrb" style="width: 280px; height: 280px; background: #8844ff; top: 65%; left: 25%;"></div>
    <div class="glowOrb" style="width: 220px; height: 220px; background: #ff4488; top: 35%; left: 65%;"></div>
    <div class="glowOrb" style="width: 260px; height: 260px; background: #ff8800; top: 75%; left: 50%;"></div>
</div>

<div class="particles" id="particlesContainer"></div>
<div id="emojiContainer"></div>
<div class="toast-container" id="toastContainer"></div>

<!-- AI Assistant -->
<div class="ai-assistant">
    <div class="ai-chat" id="aiChat">
        <div class="ai-chat-header">
            <span>🤖 Hub AI v3.5</span>
            <button onclick="toggleAI()" style="background:none;border:none;color:white;cursor:pointer;font-size:16px;">✕</button>
        </div>
        <div class="ai-messages" id="aiMessages">
            <div class="ai-message bot">Hey! 👋 I'm here to improve your experience. Try:<br>• "auto setup" - fill game info<br>• "suggest bg" - change background<br>• "set mood" - pick vibe + music<br>• Ctrl+Shift+Space to open me!</div>
        </div>
        <div class="ai-input-area">
            <input id="aiInput" placeholder="Ask me anything..." onkeypress="if(event.key==='Enter')sendAIMessage()">
            <button onclick="sendAIMessage()">➤</button>
        </div>
    </div>
    <button class="ai-btn" onclick="toggleAI()">🤖</button>
</div>

<!-- Login Modal -->
<div class="overlay" id="loginOverlay">
    <div class="modal modal-sm">
        <h2>🔐 Admin Login</h2>
        <input type="password" id="pass" placeholder="Password">
        <button onclick="login()" style="background:linear-gradient(135deg,#00cc66,#009944);">Unlock</button>
    </div>
</div>

<!-- Stats Modal -->
<div class="overlay" id="statsOverlay" onclick="closeStats()"></div>
<div class="modal" id="statsDashboard" style="display:none;position:fixed;top:50%;left:50%;transform:translate(-50%,-50%);z-index:10001;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
        <h2>📊 Statistics</h2>
        <button onclick="closeStats()" style="background:red;width:34px;height:34px;border-radius:50%;border:none;color:white;cursor:pointer;font-size:16px;">✕</button>
    </div>
    <div class="stat-item"><span>Total Games</span><span class="stat-value" id="statTotalGames">0</span></div>
    <div class="stat-item"><span>Total Plays</span><span class="stat-value" id="statTotalPlays">0</span></div>
    <div class="stat-item"><span>Total Play Time</span><span class="stat-value" id="statTotalTime">0min</span></div>
    <div class="stat-item"><span>Most Played Game</span><span class="stat-value" id="statMostPlayed">-</span></div>
    <div class="stat-item"><span>Average Rating</span><span class="stat-value" id="statAvgRating">-</span></div>
    <div class="stat-item"><span>Achievements</span><span class="stat-value" id="statAchievements">0/8</span></div>
    <button onclick="wipeAllData()" style="background:#ff4444;margin-top:10px;width:100%;">🗑️ Wipe All Data</button>
    <button onclick="wipeStatsOnly()" style="background:#ff8800;margin-top:5px;width:100%;">📊 Wipe Stats Only</button>
</div>

<!-- Settings Modal -->
<div class="overlay" id="settingsOverlay">
    <div class="modal" style="max-width:580px;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
            <h2>⚙️ Settings</h2>
            <button onclick="closeSettings()" style="background:red;width:34px;height:34px;border-radius:50%;border:none;color:white;cursor:pointer;font-size:16px;">✕</button>
        </div>
        <div class="settings-tabs">
            <span class="settings-tab active" onclick="switchSettingsTab('appearance',this)">🎨 Appearance</span>
            <span class="settings-tab" onclick="switchSettingsTab('emoji',this)">😊 Emojis</span>
            <span class="settings-tab" onclick="switchSettingsTab('music',this)">🎵 Music</span>
            <span class="settings-tab" onclick="switchSettingsTab('data',this)">📦 Data</span>
            <span class="settings-tab" onclick="switchSettingsTab('danger',this)">⚠️ Danger</span>
        </div>

        <div class="settings-content active" id="tab-appearance">
            <h3>🎨 Background Theme</h3>
            <select id="bgSelect" onchange="changeBG()"></select>
            <p style="font-size:10px;color:#666;margin-top:4px;">All backgrounds unlocked! Cartoon Network, Nickelodeon, Void, DMC & more</p>
            <br>
            <h3>🖼️ Card Size</h3>
            <select id="cardSize" onchange="changeCardSize()">
                <option value="normal">Normal</option>
                <option value="compact">Compact</option>
                <option value="large">Large</option>
            </select>
        </div>

        <div class="settings-content" id="tab-emoji">
            <h3>😊 Floating Emojis</h3>
            <select id="emojiTheme" onchange="changeEmojiTheme()">
                <option value="none">🚫 None</option>
                <option value="gaming">🎮 Gaming</option>
                <option value="nature">🌿 Nature</option>
                <option value="space">🚀 Space</option>
                <option value="party">🎉 Party</option>
                <option value="random">🎲 Random</option>
            </select>
        </div>

        <div class="settings-content" id="tab-music">
            <h3>🎵 Background Music</h3>
            <input id="musicUrl" placeholder="Paste music URL (mp3, wav, etc.)...">
            <button onclick="setMusic()" class="playBtn blue" style="width:auto;display:inline-block;padding:8px 16px;">🎵 Set Music</button>
            <br><br>
            <label class="file-label" onclick="document.getElementById('musicFileInput').click()" style="display:inline-block;background:#333;padding:8px 12px;border-radius:8px;cursor:pointer;color:#ccc;">📁 Upload Music File</label>
            <input type="file" id="musicFileInput" accept="audio/*" style="display:none" onchange="uploadMusic()">
        </div>

        <div class="settings-content" id="tab-data">
            <h3>📤 Export Data</h3>
            <textarea id="exportCode" readonly style="min-height:80px;background:#1a1a1a;color:white;border-radius:8px;padding:8px;width:100%;font-size:10px;"></textarea>
            <button onclick="copyExportCode()" class="playBtn blue" style="width:auto;display:inline-block;padding:8px 16px;">📋 Copy</button>
            <br><br>
            <h3>📥 Import Data</h3>
            <textarea id="importCode" placeholder="Paste exported code here..." style="min-height:80px;background:#1a1a1a;color:white;border-radius:8px;padding:8px;width:100%;font-size:10px;"></textarea>
            <label style="display:flex;align-items:center;gap:5px;font-size:11px;color:#aaa;"><input type="checkbox" id="replaceExisting"> Replace existing data</label>
            <button onclick="importGames()" class="playBtn green" style="width:auto;display:inline-block;padding:8px 16px;">📥 Import</button>
        </div>

        <div class="settings-content" id="tab-danger">
            <h3>⚠️ Danger Zone</h3>
            <p style="font-size:11px;color:#ff6666;margin-bottom:8px;">These actions cannot be undone!</p>
            <button onclick="wipeAllData()" style="background:#ff4444;">🗑️ Wipe ALL Data</button>
            <button onclick="wipeStatsOnly()" style="background:#ff8800;margin-top:5px;">📊 Wipe Stats Only</button>
        </div>

        <br>
        <button onclick="showAchievements()" class="playBtn orange" style="width:auto;display:inline-block;padding:10px 20px;">🏆 View Achievements</button>
    </div>
</div>

<!-- Achievements Modal -->
<div class="overlay" id="achievementsOverlay">
    <div class="modal">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:14px;">
            <h2>🏆 Achievements</h2>
            <button onclick="closeAchievements()" style="background:red;width:34px;height:34px;border-radius:50%;border:none;color:white;cursor:pointer;font-size:16px;">✕</button>
        </div>
        <div id="achievementsList"></div>
    </div>
</div>

<header><h1>🎮 ULTIMATE GAME HUB</h1></header>

<div class="topbar">
    <div class="search-area">
        <span>🔍</span>
        <input type="text" id="searchInput" placeholder="Search games... (Ctrl+K)" onkeyup="filterGames()">
    </div>
    <div class="topbar-stats">🎮 <span id="totalViews">0</span> plays | 📦 <span id="totalGames">0</span> games</div>
    <div class="topbar-buttons">
        <button class="gear" onclick="openSettings()" title="Settings">⚙️</button>
        <button class="gear" onclick="openStats()" title="Statistics">📊</button>
        <button class="gear" onclick="toggleAdmin()" title="Admin Panel">🛡️</button>
    </div>
</div>

<div class="category-filters" id="categoryFilters"></div>

<div class="recently-played">
    <span>🕐 Recent:</span>
    <div id="recentList" style="display:flex;gap:6px;flex-wrap:wrap;"></div>
</div>

<div class="games" id="games"></div>

<!-- Admin Panel -->
<div class="adminPanel" id="adminPanel">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:12px;">
        <h2>🛡️ Admin Panel</h2>
        <button onclick="closeAdmin()" style="background:red;width:34px;height:34px;border-radius:50%;border:none;color:white;cursor:pointer;font-size:16px;">✕</button>
    </div>

    <label>Game Title *</label>
    <input id="title" placeholder="Enter game title...">

    <label>Image URL (or use AI)</label>
    <div style="display:flex;gap:4px;">
        <input id="image" placeholder="https://...">
        <button onclick="aiAutoSetup()" style="width:auto;padding:8px 12px;background:#8844ff;color:white;border:none;border-radius:8px;cursor:pointer;font-size:10px;white-space:nowrap;">🤖 Auto Setup</button>
    </div>

    <label>Description</label>
    <textarea id="desc" rows="2" placeholder="Brief description..."></textarea>

    <label>Tags (comma separated)</label>
    <input id="tags" placeholder="action, puzzle, 2d">

    <label>Game Type</label>
    <select id="gameType" onchange="toggleCodeInput()">
        <option value="html">HTML Game</option>
        <option value="youtube">YouTube Video</option>
        <option value="mp4">MP4 Video</option>
    </select>

    <label id="codeLabel">HTML Code *</label>
    <textarea id="code" rows="5" placeholder="Paste full HTML game code here..."></textarea>

    <input id="youtubeUrl" placeholder="YouTube Video URL" style="display:none;">
    <input id="mp4Url" placeholder="MP4 Video URL" style="display:none;">

    <div style="margin:5px 0;">
        <label class="file-label" onclick="document.getElementById('htmlFileInput').click()">📄 Upload HTML</label>
        <input type="file" id="htmlFileInput" accept=".html" style="display:none" onchange="uploadHTMLFile()">

        <label class="file-label" onclick="document.getElementById('mp4FileInput').click()">🎬 Upload MP4</label>
        <input type="file" id="mp4FileInput" accept=".mp4" style="display:none" onchange="uploadMP4File()">
    </div>

    <button id="addGameBtn" onclick="addGame()" style="width:100%;padding:10px;background:linear-gradient(135deg,#00cc66,#009944);color:white;border:none;border-radius:8px;cursor:pointer;font-weight:bold;margin-top:8px;">✅ ADD GAME</button>

    <h3>🎵 Background Music</h3>
    <input id="adminMusicUrl" placeholder="Music URL">
    <button onclick="setMusicFromAdmin()" style="width:100%;background:#8844ff;color:white;border:none;padding:8px;border-radius:8px;cursor:pointer;">🎵 Set BG Music</button>

    <h3>🏷️ Custom Categories</h3>
    <div id="customCategoriesList" style="margin:4px 0;"></div>
    <div style="display:flex;gap:4px;">
        <input id="newCategoryName" placeholder="New category name">
        <button onclick="createCustomCategory()" style="width:auto;background:#8844ff;color:white;border:none;border-radius:6px;padding:8px 12px;cursor:pointer;">Create</button>
    </div>

    <br>
    <label>Admin Passwords (comma separated)</label>
    <input id="admins" placeholder="pass1, pass2, pass3">
    <button onclick="saveAdmins()" style="width:100%;background:#ff8800;color:white;border:none;border-radius:8px;padding:9px;cursor:pointer;">💾 Save Admins</button>

    <h3>📋 Games List</h3>
    <div id="adminList"></div>
</div>

<script>
// ===================================================================
// DATA MANAGEMENT
// ===================================================================
function setCookie(name, value, days) {
    days = days || 365;
    var expires = new Date();
    expires.setTime(expires.getTime() + (days * 86400000));
    document.cookie = name + "=" + encodeURIComponent(value) + ";path=/;expires=" + expires.toUTCString();
}

function getCookie(name) {
    var match = document.cookie.match(new RegExp('(^| )' + name + '=([^;]+)'));
    return match ? decodeURIComponent(match[2]) : null;
}

function saveData(key, value) {
    try {
        localStorage.setItem(key, JSON.stringify(value));
        setCookie('gh_' + key, JSON.stringify(value));
    } catch(e) {
        setCookie('gh_' + key, JSON.stringify(value));
    }
}

function loadData(key, defaultValue) {
    try {
        var local = localStorage.getItem(key);
        if (local) return JSON.parse(local);
        var cookie = getCookie('gh_' + key);
        if (cookie) {
            localStorage.setItem(key, cookie);
            return JSON.parse(cookie);
        }
    } catch(e) {}
    return defaultValue;
}

// ===================================================================
// STATE
// ===================================================================
var adminPasswords = loadData("admins", ["1234"]);
var unlocked = sessionStorage.getItem("admin") === "true";
var games = loadData("games", []);
var totalViews = parseInt(loadData("totalViews", 0));
var playTimeData = loadData("playTimeData", {});
var personalBests = loadData("personalBests", {});
var ratings = loadData("ratings", {});
var favorites = loadData("favorites", []);
var gameTags = loadData("gameTags", {});
var recentlyPlayed = loadData("recentlyPlayed", []);
var updatedGames = loadData("updatedGames", []);
var gameLeaderboards = loadData("gameLeaderboards", {});
var customCategories = loadData("customCategories", ["Action", "Puzzle", "Strategy", "Racing", "Adventure"]);
var gameTypes = loadData("gameTypes", {});
var achievements = loadData("achievements", {
    firstPlay: false,
    tenPlays: false,
    twentyFivePlays: false,
    favoriteFive: false,
    ratingMaster: false,
    playTime1h: false,
    gameCollector: false,
    vibeMaster: false
});
var currentEmojiTheme = loadData("emojiTheme", "gaming");
var unlockedBackgrounds = loadData("unlockedBackgrounds", [
    "default", "matrix", "stars", "sunset", "purple", "ocean",
    "cartoon", "nick", "void", "dmc", "fire", "forest", "blood", "arctic", "sunrise", "neon", "aurora", "galaxy", "fireice"
]);
var currentBG = loadData("bg", "default");
var bgMusicUrl = loadData("bgMusicUrl", "");
var cardSize = loadData("cardSize", "normal");

document.getElementById("totalViews").innerText = totalViews;
document.getElementById("totalGames").innerText = games.length;
document.getElementById("admins").value = adminPasswords.join(",");
if (bgMusicUrl) {
    document.getElementById("bgMusic").src = bgMusicUrl;
    document.getElementById("musicPlayer").classList.add("active");
}
document.getElementById("cardSize").value = cardSize;

// ===================================================================
// LOADING SCREEN
// ===================================================================
window.addEventListener('load', function() {
    setTimeout(function() {
        document.getElementById('loadingScreen').classList.add('hidden');
    }, 800);
});

// If page already loaded (cached), hide immediately
if (document.readyState === 'complete') {
    setTimeout(function() {
        document.getElementById('loadingScreen').classList.add('hidden');
    }, 400);
}

// ===================================================================
// LIVE TIMERS
// ===================================================================
var sessionStartTime = Date.now();
var totalSessionPlayTime = 0;

setInterval(function() {
    var elapsed = Math.floor((Date.now() - sessionStartTime) / 1000) + totalSessionPlayTime;
    var hours = Math.floor(elapsed / 3600);
    var minutes = Math.floor((elapsed % 3600) / 60);
    var seconds = elapsed % 60;
    document.getElementById('liveTimer').textContent = 
        String(hours).padStart(2, '0') + ':' + 
        String(minutes).padStart(2, '0') + ':' + 
        String(seconds).padStart(2, '0');
    document.getElementById('liveTimer').classList.add('visible');
}, 1000);

function updateSessionPlayTimer() {
    if (currentPlayerGame !== null && playerStartTime) {
        var elapsed = Math.floor((Date.now() - playerStartTime) / 1000);
        var total = playerAccTime + elapsed;
        var hours = Math.floor(total / 3600);
        var minutes = Math.floor((total % 3600) / 60);
        var seconds = total % 60;
        document.getElementById('sessionPlayTimer').textContent = 
            '🎮 Playing: ' + String(hours).padStart(2, '0') + ':' + 
            String(minutes).padStart(2, '0') + ':' + 
            String(seconds).padStart(2, '0');
        document.getElementById('sessionPlayTimer').classList.add('visible');
    }
}

// ===================================================================
// GAME PLAYER SYSTEM
// ===================================================================
var currentPlayerGame = null;
var playerTimer = null;
var playerAccTime = 0;
var playerStartTime = null;
var playTimerDisplayInterval = null;

function openPlayer(index) {
    var game = games[index];
    if (!game) return;
    
    game.views = (game.views || 0) + 1;
    totalViews++;
    addToRecentlyPlayed(index);
    updatedGames = updatedGames.filter(function(u) { return u !== index; });
    
    currentPlayerGame = index;
    document.getElementById('gamePlayer').classList.add('active');
    document.getElementById('gamePlayerTitle').textContent = game.title;
    
    var type = gameTypes[index] || 'html';
    var frame = document.getElementById('gamePlayerFrame');
    
    if (type === 'youtube' && game.youtubeId) {
        frame.src = 'https://www.youtube.com/embed/' + game.youtubeId + '?autoplay=1&rel=0';
    } else if (type === 'mp4' && game.mp4Url) {
        frame.srcdoc = '<!DOCTYPE html><html><head><style>*{margin:0;padding:0;background:#000;}video{width:100%;height:100%;object-fit:contain;}</style></head><body><video src="' + game.mp4Url + '" controls autoplay style="width:100%;height:100%;"></video></body></html>';
    } else {
        frame.srcdoc = game.code || '<html><body style="background:#000;color:white;display:flex;align-items:center;justify-content:center;height:100vh;"><h1>No game code</h1></body></html>';
    }
    
    saveAll();
    startPlayerTimer(index);
    document.body.style.overflow = 'hidden';
    
    // Update play timer display
    if (playTimerDisplayInterval) clearInterval(playTimerDisplayInterval);
    playTimerDisplayInterval = setInterval(updateSessionPlayTimer, 500);
}

function closePlayer() {
    document.getElementById('gamePlayer').classList.remove('active');
    document.getElementById('gamePlayerFrame').src = '';
    document.getElementById('gamePlayerFrame').srcdoc = '';
    stopPlayerTimer();
    currentPlayerGame = null;
    document.body.style.overflow = '';
    document.getElementById('sessionPlayTimer').classList.remove('visible');
    if (playTimerDisplayInterval) {
        clearInterval(playTimerDisplayInterval);
        playTimerDisplayInterval = null;
    }
}

function fullscreenPlayer() {
    var frame = document.getElementById('gamePlayerFrame');
    if (frame.requestFullscreen) {
        frame.requestFullscreen();
    } else if (frame.webkitRequestFullscreen) {
        frame.webkitRequestFullscreen();
    }
}

function newTabPlayer() {
    if (currentPlayerGame === null) return;
    var index = currentPlayerGame;
    var game = games[index];
    var type = gameTypes[index] || 'html';
    
    if (type === 'youtube' && game.youtubeId) {
        window.open('https://www.youtube.com/watch?v=' + game.youtubeId, '_blank');
    } else if (type === 'mp4' && game.mp4Url) {
        window.open(game.mp4Url, '_blank');
    } else {
        var win = window.open('', '_blank');
        win.document.write('<!DOCTYPE html><html><head><meta charset="UTF-8"><title>' + escapeHtml(game.title) + '</title></head><body>' + (game.code || '') + '</body></html>');
    }
}

function startPlayerTimer(index) {
    stopPlayerTimer();
    currentPlayerGame = index;
    playerStartTime = Date.now();
    playerAccTime = playTimeData['game_' + index] || 0;
    
    playerTimer = setInterval(function() {
        if (currentPlayerGame !== null && playerStartTime) {
            var elapsed = Math.floor((Date.now() - playerStartTime) / 1000);
            var total = playerAccTime + elapsed;
            playTimeData['game_' + currentPlayerGame] = total;
            
            if (!personalBests['game_' + currentPlayerGame] || total > personalBests['game_' + currentPlayerGame]) {
                personalBests['game_' + currentPlayerGame] = total;
            }
            
            if (elapsed % 5 === 0) {
                saveAll();
            }
        }
    }, 1000);
}

function stopPlayerTimer() {
    if (playerTimer) {
        clearInterval(playerTimer);
        playerTimer = null;
    }
    if (currentPlayerGame !== null && playerStartTime) {
        var elapsed = Math.floor((Date.now() - playerStartTime) / 1000);
        var total = playerAccTime + elapsed;
        playTimeData['game_' + currentPlayerGame] = total;
        saveAll();
    }
    currentPlayerGame = null;
    playerStartTime = null;
    playerAccTime = 0;
}

// ===================================================================
// BACKGROUND SYSTEM (ENHANCED)
// ===================================================================
var canvas = document.getElementById('bgCanvas');
var ctx = canvas.getContext('2d');
var starfieldStars = [];

function resizeCanvas() {
    canvas.width = window.innerWidth;
    canvas.height = window.innerHeight;
}
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

// Initialize starfield
for (var i = 0; i < 180; i++) {
    starfieldStars.push({
        x: Math.random() * 2500,
        y: Math.random() * 2500,
        size: Math.random() * 2.5 + 0.8,
        speed: Math.random() * 0.02 + 0.005,
        phase: Math.random() * Math.PI * 2,
        twinkleSpeed: Math.random() * 0.003 + 0.001
    });
}

function drawDefaultBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var t = Date.now() * 0.001;
    for (var i = 0; i < 90; i++) {
        var x = (Math.sin(t + i * 0.4) * 0.5 + 0.5) * canvas.width;
        var y = (Math.cos(t * 0.6 + i * 0.35) * 0.5 + 0.5) * canvas.height;
        ctx.beginPath();
        ctx.arc(x, y, Math.random() * 2.5 + 1, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + (100 + Math.random() * 155) + ',' + (50 + Math.random() * 100) + ',255,' + (0.25 + Math.random() * 0.35) + ')';
        ctx.fill();
    }
}

function drawMatrixBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.1)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#0f0';
    ctx.font = '14px monospace';
    for (var i = 0; i < 90; i++) {
        var char = String.fromCharCode(0x30A0 + Math.random() * 96);
        ctx.fillText(char, Math.random() * canvas.width, Math.random() * canvas.height);
    }
    ctx.fillStyle = '#00ff00';
    ctx.font = '16px monospace';
    for (var i = 0; i < 25; i++) {
        ctx.fillText(String.fromCharCode(0x30A0 + Math.random() * 96), Math.random() * canvas.width, Math.random() * canvas.height);
    }
}

function drawStarsBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (var i = 0; i < starfieldStars.length; i++) {
        var s = starfieldStars[i];
        var twinkle = Math.sin(Date.now() * s.twinkleSpeed + s.phase) * 0.5 + 0.5;
        ctx.beginPath();
        ctx.arc(s.x % canvas.width, s.y % canvas.height, s.size, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,' + (0.25 + twinkle * 0.65) + ')';
        ctx.fill();
    }
}

function drawCartoonBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var colors = ['#ff6b6b', '#ffd93d', '#6bcb77', '#4d96ff', '#ff922b', '#ff4488', '#00ffcc'];
    for (var i = 0; i < 35; i++) {
        ctx.beginPath();
        var rx = Math.random() * canvas.width;
        var ry = Math.random() * canvas.height;
        var rr = Math.random() * 25 + 8;
        ctx.arc(rx, ry, rr, 0, Math.PI * 2);
        ctx.fillStyle = colors[Math.floor(Math.random() * colors.length)];
        ctx.globalAlpha = 0.12;
        ctx.fill();
        ctx.strokeStyle = 'rgba(255,255,255,0.15)';
        ctx.lineWidth = 2;
        ctx.stroke();
    }
    ctx.globalAlpha = 1;
    // Floating cartoon elements
    for (var i = 0; i < 15; i++) {
        ctx.beginPath();
        var ex = (Math.sin(Date.now() * 0.0005 + i) * 0.5 + 0.5) * canvas.width;
        var ey = (Math.cos(Date.now() * 0.0007 + i) * 0.5 + 0.5) * canvas.height;
        ctx.arc(ex, ey, Math.random() * 8 + 3, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,0.2)';
        ctx.fill();
    }
}

function drawNickBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // Orange slime splats
    ctx.fillStyle = '#ff6600';
    ctx.globalAlpha = 0.08;
    for (var i = 0; i < 25; i++) {
        var sx = Math.random() * canvas.width;
        var sy = Math.random() * canvas.height;
        ctx.beginPath();
        ctx.arc(sx, sy, Math.random() * 25 + 8, 0, Math.PI * 2);
        ctx.fill();
        // Splatter dots
        for (var j = 0; j < 5; j++) {
            ctx.beginPath();
            ctx.arc(sx + (Math.random() - 0.5) * 40, sy + (Math.random() - 0.5) * 40, Math.random() * 6 + 2, 0, Math.PI * 2);
            ctx.fill();
        }
    }
    // Green goo
    ctx.fillStyle = '#00ff00';
    ctx.globalAlpha = 0.05;
    for (var i = 0; i < 35; i++) {
        ctx.beginPath();
        ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, Math.random() * 18 + 5, 0, Math.PI * 2);
        ctx.fill();
    }
    ctx.globalAlpha = 1;
}

function drawVoidBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.06)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    var centerX = canvas.width / 2;
    var centerY = canvas.height / 2;
    for (var i = 0; i < 20; i++) {
        var angle = Date.now() * 0.0003 + i * (Math.PI * 2 / 20);
        var distance = Math.sin(Date.now() * 0.0005 + i) * 100 + 150;
        var px = centerX + Math.cos(angle) * distance;
        var py = centerY + Math.sin(angle) * distance * 0.7;
        ctx.beginPath();
        ctx.arc(px, py, Math.random() * 3 + 1, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(136,68,255,' + (0.3 + Math.random() * 0.5) + ')';
        ctx.fill();
    }
    // Center vortex
    var vortexGrad = ctx.createRadialGradient(centerX, centerY, 0, centerX, centerY, 200);
    vortexGrad.addColorStop(0, 'rgba(0,0,0,0.3)');
    vortexGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = vortexGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
}

function drawDMCBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.06)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Red and blue slash marks
    for (var i = 0; i < 45; i++) {
        var x1 = Math.random() * canvas.width;
        var y1 = Math.random() * canvas.height;
        var x2 = x1 + (Math.random() - 0.5) * 80;
        var y2 = y1 + (Math.random() - 0.5) * 80;
        ctx.beginPath();
        ctx.moveTo(x1, y1);
        ctx.lineTo(x2, y2);
        var isRed = Math.random() < 0.5;
        ctx.strokeStyle = isRed ? 'rgba(255,0,0,0.25)' : 'rgba(0,0,255,0.25)';
        ctx.lineWidth = Math.random() * 3 + 1;
        ctx.stroke();
    }
    // Glowing orbs
    for (var i = 0; i < 10; i++) {
        var ox = Math.random() * canvas.width;
        var oy = Math.random() * canvas.height;
        var grad = ctx.createRadialGradient(ox, oy, 0, ox, oy, 30);
        grad.addColorStop(0, 'rgba(255,255,255,0.3)');
        grad.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(ox - 30, oy - 30, 60, 60);
    }
}

function drawAuroraBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (var i = 0; i < 4; i++) {
        var grad = ctx.createLinearGradient(0, canvas.height * (0.15 + i * 0.18), canvas.width, canvas.height * (0.35 + i * 0.18));
        var hue = [150, 260, 190, 320][i];
        grad.addColorStop(0, 'hsla(' + hue + ',100%,60%,0.12)');
        grad.addColorStop(0.5, 'hsla(' + (hue + 40) + ',100%,50%,0.18)');
        grad.addColorStop(1, 'hsla(' + (hue - 20) + ',100%,70%,0.08)');
        ctx.fillStyle = grad;
        ctx.fillRect(0, canvas.height * (0.12 + i * 0.18) + Math.sin(Date.now() * 0.0008 + i) * 25, canvas.width, canvas.height * 0.28);
    }
}

function drawSunriseBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, '#1a0a2e');
    grad.addColorStop(0.25, '#ff6b35');
    grad.addColorStop(0.55, '#ffb347');
    grad.addColorStop(0.8, '#ffd89b');
    grad.addColorStop(1, '#87CEEB');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Animated sun
    var sunY = canvas.height * 0.45 + Math.sin(Date.now() * 0.0004) * 15;
    var sunGrad = ctx.createRadialGradient(canvas.width * 0.65, sunY, 8, canvas.width * 0.65, sunY, 140);
    sunGrad.addColorStop(0, 'rgba(255,255,220,0.9)');
    sunGrad.addColorStop(0.5, 'rgba(255,200,100,0.4)');
    sunGrad.addColorStop(1, 'rgba(255,150,50,0)');
    ctx.fillStyle = sunGrad;
    ctx.fillRect(0, sunY - 140, canvas.width, 280);
}

function drawNeonCityBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.07)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    var buildingColors = ['#ff00ff', '#00ffff', '#ff0088', '#8800ff', '#00ff88'];
    for (var i = 0; i < 40; i++) {
        var bx = i * canvas.width / 40;
        var bh = Math.random() * canvas.height * 0.55 + canvas.height * 0.15;
        ctx.fillStyle = 'rgba(0,0,0,0.5)';
        ctx.fillRect(bx, canvas.height - bh, canvas.width / 40 - 1, bh);
        var color = buildingColors[Math.floor(Math.random() * buildingColors.length)];
        ctx.fillStyle = color;
        ctx.shadowColor = color;
        ctx.shadowBlur = 7;
        ctx.fillRect(bx + 2, canvas.height - bh, 2, 2);
        // Windows
        for (var wy = canvas.height - bh + 10; wy < canvas.height - 5; wy += 15) {
            if (Math.random() < 0.4) {
                ctx.fillStyle = 'rgba(255,255,200,0.5)';
                ctx.fillRect(bx + 3, wy, 3, 4);
            }
        }
        ctx.shadowBlur = 0;
    }
}

function drawGalaxyBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var cx = canvas.width / 2;
    var cy = canvas.height / 2;
    for (var i = 0; i < 280; i++) {
        var angle = Math.random() * Math.PI * 2;
        var dist = Math.random() * Math.max(canvas.width, canvas.height) * 0.75;
        var spiralOffset = Math.sin(dist * 0.015 + Date.now() * 0.0002) * 25;
        var px = cx + Math.cos(angle) * dist + spiralOffset;
        var py = cy + Math.sin(angle) * dist * 0.55 + Math.cos(dist * 0.015) * 20;
        ctx.beginPath();
        ctx.arc(px, py, Math.random() * 2.2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + (180 + Math.random() * 75) + ',' + (130 + Math.random() * 125) + ',255,' + (Math.random() * 0.5) + ')';
        ctx.fill();
    }
}

function drawFireIceClashBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.1)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Fire side (left)
    for (var i = 0; i < 55; i++) {
        var fx = Math.random() * canvas.width * 0.48;
        var fy = Math.random() * canvas.height;
        ctx.beginPath();
        ctx.arc(fx, fy, Math.random() * 4 + 1.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,' + Math.floor(Math.random() * 130) + ',0,' + (0.25 + Math.random() * 0.45) + ')';
        ctx.fill();
    }
    // Ice side (right)
    for (var i = 0; i < 55; i++) {
        var ix = canvas.width * 0.52 + Math.random() * canvas.width * 0.48;
        var iy = Math.random() * canvas.height;
        ctx.beginPath();
        ctx.arc(ix, iy, Math.random() * 4 + 1.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(0,' + Math.floor(160 + Math.random() * 95) + ',255,' + (0.25 + Math.random() * 0.45) + ')';
        ctx.fill();
    }
    // Clash zone
    var midX = canvas.width * 0.5 + Math.sin(Date.now() * 0.002) * 25;
    for (var i = 0; i < 30; i++) {
        ctx.beginPath();
        ctx.arc(midX + (Math.random() - 0.5) * 50, Math.random() * canvas.height, Math.random() * 3 + 1, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,' + (0.4 + Math.random() * 0.5) + ')';
        ctx.fill();
    }
}

function drawForestBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // Sky gradient
    var skyGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    skyGrad.addColorStop(0, '#0a1a0a');
    skyGrad.addColorStop(0.6, '#0d2d0d');
    skyGrad.addColorStop(1, '#1a3a1a');
    ctx.fillStyle = skyGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Trees
    for (var i = 0; i < 50; i++) {
        var tx = Math.random() * canvas.width;
        var th = Math.random() * canvas.height * 0.5 + canvas.height * 0.2;
        ctx.fillStyle = 'rgba(0,' + Math.floor(60 + Math.random() * 50) + ',0,0.45)';
        ctx.beginPath();
        ctx.moveTo(tx, canvas.height - th);
        ctx.lineTo(tx - 12, canvas.height - th + 50);
        ctx.lineTo(tx + 12, canvas.height - th + 50);
        ctx.fill();
    }
}

function drawOceanBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // Water gradient
    var waterGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    waterGrad.addColorStop(0, '#001a33');
    waterGrad.addColorStop(0.5, '#003366');
    waterGrad.addColorStop(1, '#004d80');
    ctx.fillStyle = waterGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Waves
    for (var i = 0; i < 8; i++) {
        ctx.beginPath();
        ctx.moveTo(0, canvas.height * (0.25 + i * 0.08));
        for (var x = 0; x < canvas.width; x += 15) {
            ctx.lineTo(x, canvas.height * (0.25 + i * 0.08) + Math.sin(x * 0.012 + Date.now() * 0.0015 + i) * 18);
        }
        ctx.strokeStyle = 'rgba(0,170,255,' + (0.12 - i * 0.012) + ')';
        ctx.lineWidth = 2;
        ctx.stroke();
    }
}

function drawArcticBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    // Ice gradient
    var iceGrad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    iceGrad.addColorStop(0, '#d0e8ff');
    iceGrad.addColorStop(0.5, '#b0d4f0');
    iceGrad.addColorStop(1, '#e8f4ff');
    ctx.fillStyle = iceGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Snowflakes
    for (var i = 0; i < 100; i++) {
        ctx.beginPath();
        ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, Math.random() * 3 + 0.5, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(255,255,255,' + (Math.random() * 0.5 + 0.2) + ')';
        ctx.fill();
    }
}

function drawSunsetGradientBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var grad = ctx.createLinearGradient(0, 0, 0, canvas.height);
    grad.addColorStop(0, '#2c0a4a');
    grad.addColorStop(0.3, '#ff5f6d');
    grad.addColorStop(0.6, '#ffc371');
    grad.addColorStop(1, '#ffd89b');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
}

function drawPurpleVoidBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    var grad = ctx.createRadialGradient(canvas.width / 2, canvas.height / 2, 0, canvas.width / 2, canvas.height / 2, Math.max(canvas.width, canvas.height));
    grad.addColorStop(0, '#1a0040');
    grad.addColorStop(0.5, '#0f0025');
    grad.addColorStop(1, '#000010');
    ctx.fillStyle = grad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    for (var i = 0; i < 60; i++) {
        ctx.beginPath();
        ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, Math.random() * 2, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(136,68,255,' + (Math.random() * 0.4) + ')';
        ctx.fill();
    }
}

function drawFireBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (var i = 0; i < 70; i++) {
        var fx = Math.random() * canvas.width;
        var fy = Math.random() * canvas.height;
        var grad = ctx.createRadialGradient(fx, fy, 0, fx, fy, Math.random() * 30 + 10);
        grad.addColorStop(0, 'rgba(255,200,0,0.4)');
        grad.addColorStop(0.5, 'rgba(255,100,0,0.25)');
        grad.addColorStop(1, 'rgba(255,0,0,0)');
        ctx.fillStyle = grad;
        ctx.fillRect(fx - 30, fy - 30, 60, 60);
    }
}

function drawBloodMoonBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#0a0005';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    // Blood moon
    var moonGrad = ctx.createRadialGradient(canvas.width * 0.7, canvas.height * 0.3, 10, canvas.width * 0.7, canvas.height * 0.3, 120);
    moonGrad.addColorStop(0, 'rgba(200,30,30,0.8)');
    moonGrad.addColorStop(0.5, 'rgba(150,20,20,0.4)');
    moonGrad.addColorStop(1, 'rgba(0,0,0,0)');
    ctx.fillStyle = moonGrad;
    ctx.fillRect(0, 0, canvas.width, canvas.height);
}

function animateBG() {
    switch(currentBG) {
        case 'matrix': drawMatrixBG(); break;
        case 'stars': drawStarsBG(); break;
        case 'cartoon': drawCartoonBG(); break;
        case 'nick': drawNickBG(); break;
        case 'void': drawVoidBG(); break;
        case 'dmc': drawDMCBG(); break;
        case 'aurora': drawAuroraBG(); break;
        case 'sunrise': drawSunriseBG(); break;
        case 'neon': drawNeonCityBG(); break;
        case 'galaxy': drawGalaxyBG(); break;
        case 'fireice': drawFireIceClashBG(); break;
        case 'forest': drawForestBG(); break;
        case 'ocean': drawOceanBG(); break;
        case 'arctic': drawArcticBG(); break;
        case 'sunset': drawSunsetGradientBG(); break;
        case 'purple': drawPurpleVoidBG(); break;
        case 'fire': drawFireBG(); break;
        case 'blood': drawBloodMoonBG(); break;
        default: drawDefaultBG();
    }
    requestAnimationFrame(animateBG);
}

function changeBG() {
    currentBG = document.getElementById("bgSelect").value;
    var bgColors = {
        matrix: "#001100", stars: "#0a0a15", sunset: "#2a1030", purple: "#0f0020",
        ocean: "#001a2a", fire: "#1a0000", forest: "#001a00", blood: "#1a0005",
        neon: "#0a0a0a", aurora: "#0a0f1a", galaxy: "#0a0020", sunrise: "#1a0a20",
        arctic: "#e8f4ff", fireice: "#0a0005", cartoon: "#1a1a2e", nick: "#1a1000",
        void: "#050510", dmc: "#0a0005"
    };
    document.body.style.background = bgColors[currentBG] || "#050505";
    saveData("bg", currentBG);
}

