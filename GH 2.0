<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultimate Game Hub</title>

<style>
:root {
    --bg-primary: #050505;
    --bg-secondary: rgba(20, 20, 20, 0.75);
    --bg-card: rgba(20, 20, 20, 0.65);
    --accent: #00aaff;
    --accent2: #0066cc;
    --text: #ffffff;
    --text-secondary: #aaa;
    --border: rgba(255, 255, 255, 0.08);
    --input-bg: #2a2a2a;
    --success: #00aa55;
    --danger: #ff4444;
    --warning: #ffaa00;
    --purple: #8844ff;
    --orange: #ff8800;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    font-family: 'Segoe UI', Arial, sans-serif;
}

body {
    background: var(--bg-primary);
    color: var(--text);
    overflow-x: hidden;
    transition: background 0.5s ease;
}

/* === ORIGINAL BACKGROUND FX === */
.bgEffects {
    position: fixed;
    inset: 0;
    z-index: -3;
    overflow: hidden;
    pointer-events: none;
}

#bgCanvas {
    position: fixed;
    inset: 0;
    z-index: -3;
    pointer-events: none;
    opacity: 0.8;
}

.particles {
    position: fixed;
    inset: 0;
    z-index: -2;
    pointer-events: none;
}

.particles span {
    position: absolute;
    width: 3px;
    height: 3px;
    background: white;
    opacity: 0.15;
    border-radius: 50%;
    animation: float linear infinite;
}

.particles span:nth-child(odd) {
    width: 2px;
    height: 2px;
    background: #00aaff;
    box-shadow: 0 0 4px #00aaff;
}

.particles span:nth-child(3n) {
    width: 4px;
    height: 4px;
    background: #0066cc;
    box-shadow: 0 0 6px #0066cc;
    opacity: 0.2;
}

@keyframes float {
    from { transform: translateY(100vh) rotate(0deg); }
    to { transform: translateY(-10vh) rotate(360deg); }
}

.cyberLines {
    position: absolute;
    width: 200%;
    height: 200%;
    background: repeating-linear-gradient(90deg, transparent 0px, rgba(0, 170, 255, 0.05) 2px, transparent 4px);
    animation: moveGrid 20s linear infinite;
}

.cyberLines::after {
    content: '';
    position: absolute;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(0deg, transparent 0px, rgba(0, 102, 204, 0.03) 2px, transparent 4px);
}

@keyframes moveGrid {
    from { transform: translateX(0) translateY(0); }
    to { transform: translateX(-50%) translateY(-50%); }
}

.glowOrb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.35;
    animation: floatOrb 12s ease-in-out infinite;
}

.glowOrb:nth-child(2) { animation-delay: -4s; animation-duration: 15s; }
.glowOrb:nth-child(3) { animation-delay: -8s; animation-duration: 18s; }

@keyframes floatOrb {
    0% { transform: translate(0, 0) scale(1); }
    25% { transform: translate(80px, -60px) scale(1.15); }
    50% { transform: translate(-40px, -100px) scale(1.25); }
    75% { transform: translate(-80px, -20px) scale(1.1); }
    100% { transform: translate(0, 0) scale(1); }
}

/* === HEADER === */
header {
    text-align: center;
    padding: 25px;
    background: var(--bg-secondary);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 10;
}

header h1 {
    font-size: 48px;
    text-shadow: 0 0 10px #00aaff, 0 0 30px #00aaff, 0 0 60px #00aaff;
}

/* === GAME UPDATE ANIMATION === */
@keyframes updateGlow {
    0%, 100% { box-shadow: 0 0 20px rgba(0, 170, 255, 0.35); border-color: rgba(0, 170, 255, 0.3); }
    50% { box-shadow: 0 0 50px rgba(0, 255, 100, 0.8), 0 0 80px rgba(0, 170, 255, 0.6); border-color: rgba(0, 255, 100, 0.8); }
}

@keyframes updateBadgePop {
    0% { transform: scale(0) rotate(-180deg); opacity: 0; }
    60% { transform: scale(1.3) rotate(10deg); opacity: 1; }
    100% { transform: scale(1) rotate(0deg); opacity: 1; }
}

.card.updated { animation: updateGlow 1.5s ease-in-out 3; }

.update-badge {
    position: absolute;
    top: 8px;
    left: 8px;
    background: linear-gradient(135deg, #00ff88, #00aaff);
    color: #000;
    padding: 4px 10px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: bold;
    z-index: 5;
    animation: updateBadgePop 0.6s ease-out;
    box-shadow: 0 0 15px rgba(0, 255, 100, 0.5);
}

/* === TOPBAR === */
.topbar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 20px;
    background: rgba(15, 15, 15, 0.7);
    backdrop-filter: blur(12px);
    flex-wrap: wrap;
    gap: 10px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.search-area {
    display: flex;
    align-items: center;
    gap: 10px;
    background: rgba(0, 0, 0, 0.4);
    padding: 5px 15px;
    border-radius: 30px;
    border: 1px solid rgba(0, 170, 255, 0.3);
    transition: 0.3s;
}

.search-area:focus-within { border-color: #00aaff; box-shadow: 0 0 15px rgba(0, 170, 255, 0.3); }
.search-area input { background: transparent; border: none; color: white; padding: 8px; width: 200px; outline: none; }

.gear {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    color: white;
    font-size: 24px;
    cursor: pointer;
    transition: 0.3s;
    padding: 8px 12px;
    border-radius: 12px;
}

.gear:hover { transform: rotate(90deg); background: rgba(0, 170, 255, 0.2); border-color: #00aaff; }

/* === CATEGORY FILTERS === */
.category-filters {
    display: flex;
    gap: 8px;
    padding: 12px 20px;
    flex-wrap: wrap;
    background: rgba(10, 10, 10, 0.5);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    overflow-x: auto;
    align-items: center;
}

.category-tag {
    padding: 6px 16px;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #aaa;
    cursor: pointer;
    font-size: 13px;
    transition: 0.3s;
    white-space: nowrap;
}

.category-tag:hover, .category-tag.active {
    background: rgba(0, 170, 255, 0.2);
    border-color: #00aaff;
    color: #00aaff;
    box-shadow: 0 0 15px rgba(0, 170, 255, 0.2);
}

.add-category-btn {
    padding: 6px 12px;
    border-radius: 20px;
    background: rgba(0, 170, 255, 0.3);
    border: 1px dashed #00aaff;
    color: #00aaff;
    cursor: pointer;
    font-size: 13px;
    transition: 0.3s;
}

.add-category-btn:hover { background: rgba(0, 170, 255, 0.5); }

.delete-category-btn {
    padding: 2px 8px;
    border-radius: 10px;
    background: rgba(255, 0, 0, 0.2);
    border: none;
    color: #ff6666;
    cursor: pointer;
    font-size: 10px;
    margin-left: 4px;
}

/* === RECENTLY PLAYED === */
.recently-played {
    padding: 10px 20px;
    background: rgba(0, 0, 0, 0.3);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
}

.recently-played span { color: var(--accent); font-size: 13px; }

.recent-game-chip {
    padding: 4px 12px;
    background: rgba(0, 170, 255, 0.1);
    border: 1px solid rgba(0, 170, 255, 0.3);
    border-radius: 15px;
    font-size: 12px;
    cursor: pointer;
    white-space: nowrap;
    transition: 0.2s;
}

.recent-game-chip:hover { background: rgba(0, 170, 255, 0.3); }

/* === GAMES GRID === */
.games {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 20px;
    padding: 20px;
}

.card {
    background: var(--bg-card);
    border-radius: 18px;
    overflow: hidden;
    border: 1px solid var(--border);
    backdrop-filter: blur(12px);
    box-shadow: 0 0 20px rgba(0, 0, 0, 0.35);
    transition: 0.3s;
    position: relative;
}

.card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 18px;
    background: linear-gradient(135deg, rgba(0, 170, 255, 0.1), rgba(0, 102, 204, 0.05));
    opacity: 0;
    transition: 0.3s;
    pointer-events: none;
}

.card:hover::before { opacity: 1; }
.card:hover { transform: translateY(-10px) scale(1.02); box-shadow: 0 0 35px rgba(0, 170, 255, 0.35); border-color: rgba(0, 170, 255, 0.3); }

.card img, .card iframe.yt-thumb {
    width: 100%;
    height: 180px;
    object-fit: cover;
    background: #1a1a1a;
    border: none;
    pointer-events: none;
}

.info { padding: 15px; }
.info h2 { margin-bottom: 10px; font-size: 18px; }
.desc { color: var(--text-secondary); font-size: 14px; margin-bottom: 10px; line-height: 1.4; }
.meta { color: #777; font-size: 12px; margin-top: 6px; display: flex; justify-content: space-between; }

.game-tags { display: flex; gap: 4px; flex-wrap: wrap; margin: 5px 0; }
.game-tag { padding: 2px 8px; background: rgba(0, 170, 255, 0.15); border-radius: 10px; font-size: 10px; color: #00aaff; border: 1px solid rgba(0, 170, 255, 0.2); }

/* === BUTTONS === */
.playBtn {
    width: 100%;
    padding: 10px;
    margin-top: 8px;
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
    transition: 0.2s;
    font-weight: bold;
}

.playBtn:hover { transform: scale(1.03); }
.blue { background: #0099ff; }
.green { background: #00aa55; }
.purple { background: #8844ff; }
.orange { background: #ff8800; }
.red-btn { background: #ff4444; }

/* === FAVORITES & RATING === */
.favorite-btn {
    position: absolute;
    top: 10px;
    right: 10px;
    background: rgba(0, 0, 0, 0.6);
    border: none;
    color: white;
    width: 35px;
    height: 35px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 18px;
    transition: 0.3s;
    z-index: 5;
}

.favorite-btn:hover { transform: scale(1.2); }
.favorite-btn.active { color: #ff4081; background: rgba(255, 0, 100, 0.3); }

.rating { display: flex; gap: 2px; margin: 5px 0; }
.star { color: #555; cursor: pointer; font-size: 16px; transition: 0.2s; }
.star:hover, .star.active { color: #ffd700; text-shadow: 0 0 5px #ffd700; }

/* === LEADERBOARD === */
.leaderboard-section {
    background: rgba(255, 170, 0, 0.1);
    border: 1px solid rgba(255, 170, 0, 0.3);
    border-radius: 8px;
    padding: 8px;
    margin-top: 8px;
    font-size: 12px;
    color: #ffaa00;
    max-height: 100px;
    overflow-y: auto;
}

.leaderboard-entry {
    display: flex;
    justify-content: space-between;
    padding: 2px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
}

.leaderboard-entry:first-child { color: #ffd700; font-weight: bold; }

/* === AI ASSISTANT === */
.ai-assistant {
    position: fixed;
    bottom: 20px;
    right: 20px;
    z-index: 9999;
}

.ai-btn {
    width: 55px;
    height: 55px;
    border-radius: 50%;
    background: linear-gradient(135deg, #00aaff, #8844ff);
    border: none;
    color: white;
    font-size: 24px;
    cursor: pointer;
    box-shadow: 0 0 25px rgba(0, 170, 255, 0.5);
    transition: 0.3s;
}

.ai-btn:hover { transform: scale(1.1); box-shadow: 0 0 40px rgba(0, 170, 255, 0.8); }

.ai-chat {
    position: absolute;
    bottom: 65px;
    right: 0;
    width: 320px;
    height: 400px;
    background: rgba(15, 15, 25, 0.97);
    border: 1px solid rgba(0, 170, 255, 0.4);
    border-radius: 15px;
    display: none;
    flex-direction: column;
    overflow: hidden;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.7);
}

.ai-chat.active { display: flex; }

.ai-chat-header {
    padding: 12px;
    background: rgba(0, 170, 255, 0.2);
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-weight: bold;
    color: #00aaff;
}

.ai-messages {
    flex: 1;
    overflow-y: auto;
    padding: 10px;
    font-size: 12px;
}

.ai-message {
    margin-bottom: 8px;
    padding: 8px 12px;
    border-radius: 12px;
    max-width: 85%;
}

.ai-message.user {
    background: rgba(0, 170, 255, 0.2);
    margin-left: auto;
    color: white;
}

.ai-message.bot {
    background: rgba(255, 255, 255, 0.1);
    color: #ccc;
}

.ai-input-area {
    display: flex;
    padding: 10px;
    gap: 8px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
}

.ai-input-area input {
    flex: 1;
    padding: 8px 12px;
    border-radius: 20px;
    border: 1px solid rgba(0, 170, 255, 0.3);
    background: rgba(0, 0, 0, 0.3);
    color: white;
    font-size: 12px;
    outline: none;
}

.ai-input-area button {
    padding: 8px 15px;
    border-radius: 20px;
    background: #00aaff;
    border: none;
    color: white;
    cursor: pointer;
}

/* === MODALS === */
.loginOverlay, .stats-overlay, .importExportModal, .ai-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.88);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10000;
    backdrop-filter: blur(10px);
}

.loginBox, .stats-dashboard, .importExportBox {
    background: #1d1d1d;
    padding: 25px;
    border-radius: 16px;
    border: 1px solid rgba(0, 170, 255, 0.3);
    animation: pop 0.3s;
}

@keyframes pop {
    from { transform: scale(0.7); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
}

.loginBox { width: 320px; }
.loginBox input, .loginBox button { width: 100%; padding: 10px; margin-top: 12px; border-radius: 10px; }
.loginBox input { background: #2a2a2a; border: 1px solid #333; color: white; }
.loginBox button { background: #00aa55; border: none; color: white; }

.stats-dashboard { width: 90%; max-width: 600px; max-height: 80vh; overflow-y: auto; }
.stat-item { display: flex; justify-content: space-between; padding: 12px; border-bottom: 1px solid rgba(255, 255, 255, 0.1); }
.stat-value { color: #00aaff; font-weight: bold; }

.importExportBox { width: 90%; max-width: 500px; max-height: 80vh; overflow-y: auto; }
.importExportBox textarea {
    width: 100%;
    min-height: 100px;
    padding: 10px;
    border: none;
    border-radius: 10px;
    background: #2a2a2a;
    color: white;
    font-family: monospace;
    font-size: 12px;
    resize: vertical;
}

/* === ADMIN === */
.adminPanel {
    position: fixed;
    top: 0;
    right: -460px;
    width: 460px;
    height: 100%;
    overflow: auto;
    background: linear-gradient(180deg, rgba(20, 20, 20, 0.97), rgba(5, 5, 5, 0.98));
    backdrop-filter: blur(16px);
    box-shadow: -10px 0 40px rgba(0, 0, 0, 0.5);
    padding: 20px;
    transition: 0.3s;
    z-index: 9999;
}

.adminPanel.active { right: 0; }
.adminPanel input, .adminPanel textarea, .adminPanel select {
    width: 100%;
    padding: 10px;
    margin-top: 10px;
    border: 1px solid #333;
    border-radius: 10px;
    background: var(--input-bg);
    color: white;
}

.addBtn { width: 100%; padding: 12px; margin-top: 10px; border: none; border-radius: 10px; color: white; cursor: pointer; }
.file-label { display: inline-block; background: #3a3a3a; padding: 8px 12px; border-radius: 8px; margin-top: 8px; cursor: pointer; font-size: 12px; }

iframe#frame {
    width: 100%;
    height: 700px;
    border: none;
    display: none;
    background: white;
    border-radius: 12px;
}

/* === TOAST === */
.toast-container { position: fixed; top: 20px; right: 20px; z-index: 99999; display: flex; flex-direction: column; gap: 10px; }
.toast {
    background: rgba(20, 20, 20, 0.95);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(0, 170, 255, 0.3);
    padding: 15px 20px;
    border-radius: 12px;
    color: white;
    animation: slideIn 0.3s ease-out;
    min-width: 250px;
}
.toast.success { border-color: #00aa55; }
.toast.error { border-color: #ff4444; }

@keyframes slideIn { from { transform: translateX(100%); opacity: 0; } to { transform: translateX(0); opacity: 1; } }
@keyframes slideOut { from { transform: translateX(0); opacity: 1; } to { transform: translateX(100%); opacity: 0; } }

/* === RESPONSIVE === */
@media (max-width: 768px) {
    header h1 { font-size: 32px; }
    .games { grid-template-columns: 1fr; }
    .adminPanel { width: 100%; right: -100%; }
}
</style>
</head>
<body>

<div class="bgEffects" id="bgEffects">
    <canvas id="bgCanvas"></canvas>
    <div class="cyberLines"></div>
    <div class="glowOrb" style="width: 400px; height: 400px; background: #00aaff; top: 20%; left: 25%;"></div>
    <div class="glowOrb" style="width: 350px; height: 350px; background: #0066cc; top: 50%; left: 60%;"></div>
    <div class="glowOrb" style="width: 300px; height: 300px; background: #0099ff; top: 70%; left: 15%;"></div>
</div>

<div class="particles"></div>
<div class="toast-container" id="toastContainer"></div>

<!-- AI Assistant -->
<div class="ai-assistant">
    <div class="ai-chat" id="aiChat">
        <div class="ai-chat-header">
            <span>🤖 Game Hub AI</span>
            <button onclick="toggleAI()" style="background:none;border:none;color:white;cursor:pointer;font-size:18px;">✕</button>
        </div>
        <div class="ai-messages" id="aiMessages">
            <div class="ai-message bot">Hello! I'm your Game Hub assistant. Ask me to recommend games, find specific types, or help with anything!</div>
        </div>
        <div class="ai-input-area">
            <input id="aiInput" placeholder="Ask me anything..." onkeypress="if(event.key==='Enter')sendAIMessage()">
            <button onclick="sendAIMessage()">Send</button>
        </div>
    </div>
    <button class="ai-btn" onclick="toggleAI()">🤖</button>
</div>

<!-- Login -->
<div class="loginOverlay" id="loginOverlay">
    <div class="loginBox">
        <h2>Admin Login</h2>
        <input type="password" id="pass" placeholder="Password">
        <button onclick="login()">Unlock</button>
    </div>
</div>

<!-- Stats -->
<div class="stats-overlay" id="statsOverlay" onclick="closeStats()"></div>
<div class="stats-dashboard" id="statsDashboard" style="display:none; position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); z-index:10001;">
    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">
        <h2>📊 Statistics</h2>
        <button onclick="closeStats()" style="background:red;color:white;border:none;width:35px;height:35px;border-radius:10px;cursor:pointer;">✕</button>
    </div>
    <div class="stat-item"><span>Total Games</span><span class="stat-value" id="statTotalGames">0</span></div>
    <div class="stat-item"><span>Total Plays</span><span class="stat-value" id="statTotalPlays">0</span></div>
    <div class="stat-item"><span>Total Play Time</span><span class="stat-value" id="statTotalTime">0min</span></div>
    <div class="stat-item"><span>Most Played</span><span class="stat-value" id="statMostPlayed">-</span></div>
    <div class="stat-item"><span>Avg Rating</span><span class="stat-value" id="statAvgRating">-</span></div>
</div>

<!-- Import/Export -->
<div class="importExportModal" id="importExportModal">
    <div class="importExportBox">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:15px;">
            <h2>📦 Import/Export</h2>
            <button onclick="closeImportExport()" style="background:red;color:white;border:none;width:35px;height:35px;border-radius:10px;cursor:pointer;">✕</button>
        </div>
        <textarea id="exportCode" readonly style="min-height:150px;"></textarea>
        <button onclick="copyExportCode()" class="playBtn blue">📋 Copy</button>
        <hr style="margin:15px 0;border-color:#333;">
        <textarea id="importCode" placeholder="Paste code here..."></textarea>
        <label style="display:flex;align-items:center;gap:8px;margin:10px 0;font-size:12px;"><input type="checkbox" id="replaceExisting"> Replace existing</label>
        <button onclick="importGames()" class="playBtn green">📥 Import</button>
    </div>
</div>

<header><h1>🎮 GAME HUB</h1></header>

<div class="topbar">
    <div class="search-area">
        <span>🔍</span>
        <input type="text" id="searchInput" placeholder="Search... (Ctrl+K)" onkeyup="filterGames()">
    </div>
    <div>Plays: <span id="totalViews">0</span> | Games: <span id="totalGames">0</span></div>
    <div style="display:flex;gap:10px;">
        <button class="gear" onclick="openStats()">📊</button>
        <button class="gear" onclick="openImportExport()">📦</button>
        <button class="gear" onclick="toggleAdmin()">⚙️</button>
    </div>
</div>

<div class="category-filters" id="categoryFilters">
    <span class="category-tag active" onclick="filterByCategory('all', this)">🎯 All</span>
    <span class="category-tag" onclick="filterByCategory('favorites', this)">⭐ Favorites</span>
    <span class="category-tag" onclick="filterByCategory('recent', this)">🕐 Recent</span>
    <span class="category-tag" onclick="filterByCategory('mostPlayed', this)">🔥 Popular</span>
    <span class="add-category-btn" onclick="addCustomCategory()">➕ Add Category</span>
</div>

<div class="recently-played">
    <span>🕐 Recent:</span>
    <div id="recentList" style="display:flex;gap:8px;flex-wrap:wrap;"></div>
</div>

<div class="games" id="games"></div>
<iframe id="frame" sandbox="allow-scripts allow-same-origin allow-presentation"></iframe>

<div class="adminPanel" id="adminPanel">
    <div style="display:flex;justify-content:space-between;align-items:center;">
        <h2>⚙️ ADMIN</h2>
        <button onclick="closeAdmin()" style="background:red;color:white;border:none;width:35px;height:35px;border-radius:10px;cursor:pointer;">✕</button>
    </div>
    <br>
    <input id="title" placeholder="Game Title">
    <input id="image" placeholder="Image URL or YouTube URL">
    <textarea id="desc" rows="3" placeholder="Description"></textarea>
    <input id="tags" placeholder="Tags (comma separated)">
    <select id="gameType" onchange="toggleCodeInput()">
        <option value="html">HTML Game</option>
        <option value="youtube">YouTube Video</option>
    </select>
    <textarea id="code" rows="8" placeholder="FULL HTML GAME"></textarea>
    <input id="youtubeUrl" placeholder="YouTube Video URL" style="display:none;">
    <div>
        <label class="file-label" onclick="document.getElementById('htmlFileInput').click()">📄 Upload HTML</label>
        <input type="file" id="htmlFileInput" accept=".html" style="display:none" onchange="uploadHTMLFile()">
    </div>
    <button class="addBtn" onclick="addGame()" style="background:#00aa55;">ADD GAME</button>
    <br><br>
    <h3>🎨 Backgrounds</h3>
    <select id="bgSelect" onchange="changeBG()">
        <option value="default">Default Cosmic</option>
        <option value="matrix">Matrix Rain</option>
        <option value="stars">Starry Night</option>
        <option value="sunset">Sunset Glow</option>
        <option value="purple">Purple Void</option>
        <option value="ocean">Deep Ocean</option>
        <option value="fire">Fire Storm</option>
        <option value="grid">Cyber Grid</option>
        <option value="forest">Mystic Forest</option>
        <option value="blood">Blood Moon</option>
        <option value="neon">Neon City</option>
    </select>
    <br><br>
    <h3>🏷️ Custom Categories</h3>
    <div id="customCategoriesList"></div>
    <input id="newCategoryName" placeholder="New category name">
    <button onclick="createCustomCategory()" class="addBtn" style="background:#8844ff;">CREATE CATEGORY</button>
    <br><br>
    <input id="admins" placeholder="Admin Passwords">
    <button class="addBtn" onclick="saveAdmins()" style="background:#8844ff;">SAVE ADMINS</button>
    <br><br>
    <h3>Games</h3>
    <div id="adminList"></div>
</div>

<script>
// ========== DATA MANAGEMENT ==========
function setCookie(n, v, d = 365) {
    const date = new Date();
    date.setTime(date.getTime() + (d * 86400000));
    document.cookie = n + "=" + encodeURIComponent(v) + ";path=/;expires=" + date.toUTCString();
}
function getCookie(n) {
    const m = document.cookie.match(new RegExp('(^| )' + n + '=([^;]+)'));
    return m ? decodeURIComponent(m[2]) : null;
}
function saveData(k, v) {
    try { localStorage.setItem(k, JSON.stringify(v)); setCookie('gh_' + k, JSON.stringify(v)); }
    catch(e) { setCookie('gh_' + k, JSON.stringify(v)); }
}
function loadData(k, d) {
    try {
        const l = localStorage.getItem(k);
        if (l) return JSON.parse(l);
        const c = getCookie('gh_' + k);
        if (c) { localStorage.setItem(k, c); return JSON.parse(c); }
    } catch(e) {}
    return d;
}

// ========== STATE ==========
let adminPasswords = loadData("admins", ["1234"]);
let unlocked = sessionStorage.getItem("admin") === "true";
let games = loadData("games", []);
let totalViews = parseInt(loadData("totalViews", 0));
let playTimeData = loadData("playTimeData", {});
let personalBests = loadData("personalBests", {});
let ratings = loadData("ratings", {});
let favorites = loadData("favorites", []);
let gameTags = loadData("gameTags", {});
let comments = loadData("comments", {});
let recentlyPlayed = loadData("recentlyPlayed", []);
let updatedGames = loadData("updatedGames", []);
let gameLeaderboards = loadData("gameLeaderboards", {});
let customCategories = loadData("customCategories", ["Action", "Puzzle", "Strategy", "Racing"]);
let gameTypes = loadData("gameTypes", {});

document.getElementById("totalViews").innerText = totalViews;
document.getElementById("totalGames").innerText = games.length;
document.getElementById("admins").value = adminPasswords.join(",");

// ========== BACKGROUND SYSTEM (ALL ORIGINAL BGS) ==========
const canvas = document.getElementById('bgCanvas');
const ctx = canvas.getContext('2d');
let bgAnimationId;
let currentBG = loadData("bg", "default");

function resizeCanvas() { canvas.width = window.innerWidth; canvas.height = window.innerHeight; }
window.addEventListener('resize', resizeCanvas);
resizeCanvas();

function drawDefaultBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    const t = Date.now() * 0.001;
    for (let i = 0; i < 80; i++) {
        const x = (Math.sin(t + i * 0.5) * 0.5 + 0.5) * canvas.width;
        const y = (Math.cos(t * 0.7 + i * 0.3) * 0.5 + 0.5) * canvas.height;
        ctx.beginPath();
        ctx.arc(x, y, Math.random() * 2 + 1, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(0, ${150 + Math.random() * 105}, 255, ${0.3 + Math.random() * 0.4})`;
        ctx.fill();
    }
}

function drawMatrixBG() {
    ctx.fillStyle = 'rgba(0,0,0,0.1)';
    ctx.fillRect(0, 0, canvas.width, canvas.height);
    ctx.fillStyle = '#0f0';
    ctx.font = '14px monospace';
    for (let i = 0; i < 80; i++) ctx.fillText(String.fromCharCode(0x30A0 + Math.random() * 96), Math.random() * canvas.width, Math.random() * canvas.height);
}

function drawStarsBG() {
    ctx.clearRect(0, 0, canvas.width, canvas.height);
    for (let i = 0; i < 150; i++) {
        const tw = Math.sin(Date.now() * 0.003 + i) * 0.5 + 0.5;
        ctx.beginPath();
        ctx.arc(Math.random() * canvas.width, Math.random() * canvas.height, Math.random() * 2, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${0.3 + tw * 0.7})`;
        ctx.fill();
    }
}

function animateBG() {
    switch(currentBG) {
        case 'matrix': drawMatrixBG(); break;
        case 'stars': drawStarsBG(); break;
        default: drawDefaultBG();
    }
    bgAnimationId = requestAnimationFrame(animateBG);
}

function changeBG() {
    currentBG = document.getElementById("bgSelect").value;
    const body = document.body;
    body.style.background = "#050505";
    switch(currentBG) {
        case "matrix": body.style.background = "linear-gradient(180deg,#000,#001100)"; break;
        case "stars": body.style.background = "radial-gradient(circle,#111,#000)"; break;
        case "sunset": body.style.background = "linear-gradient(135deg,#ff5f6d,#ffc371)"; break;
        case "purple": body.style.background = "linear-gradient(135deg,#0f001f,#3a005f)"; break;
        case "ocean": body.style.background = "linear-gradient(180deg,#001f3f,#005577)"; break;
        case "fire": body.style.background = "linear-gradient(180deg,#220000,#661100)"; break;
        case "forest": body.style.background = "linear-gradient(180deg,#021,#041)"; break;
        case "blood": body.style.background = "linear-gradient(180deg,#100,#400)"; break;
        case "neon": body.style.background = "linear-gradient(135deg,#111,#000)"; break;
    }
    saveData("bg", currentBG);
}

// ========== CUSTOM CATEGORIES ==========
function renderCategories() {
    const container = document.getElementById('categoryFilters');
    container.innerHTML = `
        <span class="category-tag active" onclick="filterByCategory('all', this)">🎯 All</span>
        <span class="category-tag" onclick="filterByCategory('favorites', this)">⭐ Favorites</span>
        <span class="category-tag" onclick="filterByCategory('recent', this)">🕐 Recent</span>
        <span class="category-tag" onclick="filterByCategory('mostPlayed', this)">🔥 Popular</span>
        ${customCategories.map(cat => `
            <span class="category-tag" onclick="filterByCategory('${cat.toLowerCase()}', this)">
                ${cat}
                <button class="delete-category-btn" onclick="event.stopPropagation(); deleteCategory('${cat}')">✕</button>
            </span>
        `).join('')}
        <span class="add-category-btn" onclick="addCustomCategory()">➕ Add</span>
    `;
}

function addCustomCategory() {
    const name = prompt('Enter new category name:');
    if (name && !customCategories.includes(name)) {
        customCategories.push(name);
        saveData('customCategories', customCategories);
        renderCategories();
        showToast(`✅ Category "${name}" created!`);
    }
}

function createCustomCategory() {
    const name = document.getElementById('newCategoryName').value.trim();
    if (name && !customCategories.includes(name)) {
        customCategories.push(name);
        document.getElementById('newCategoryName').value = '';
        saveData('customCategories', customCategories);
        renderCategories();
        showToast(`✅ Category "${name}" created!`);
    }
}

function deleteCategory(name) {
    if (confirm(`Delete category "${name}"?`)) {
        customCategories = customCategories.filter(c => c !== name);
        saveData('customCategories', customCategories);
        renderCategories();
        filterGames();
        showToast(`🗑️ Category "${name}" deleted`);
    }
}

// ========== YOUTUBE SUPPORT ==========
function toggleCodeInput() {
    const type = document.getElementById('gameType').value;
    document.getElementById('code').style.display = type === 'html' ? 'block' : 'none';
    document.getElementById('youtubeUrl').style.display = type === 'youtube' ? 'block' : 'none';
}

function getYouTubeID(url) {
    const match = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/|youtube\.com\/embed\/)([^&\s]+)/);
    return match ? match[1] : null;
}

// ========== ADAPTIVE LEADERBOARD ==========
function updateGameLeaderboard(gameIndex, playTime) {
    if (!gameLeaderboards[gameIndex]) gameLeaderboards[gameIndex] = [];
    const lb = gameLeaderboards[gameIndex];
    
    // Add new entry
    lb.push({
        time: playTime,
        date: new Date().toISOString(),
        profile: currentProfile || 'Player'
    });
    
    // Sort by time (highest first for play time leaderboard)
    lb.sort((a, b) => b.time - a.time);
    
    // Keep top 10
    if (lb.length > 10) lb = lb.slice(0, 10);
    gameLeaderboards[gameIndex] = lb;
    saveData('gameLeaderboards', gameLeaderboards);
}

function getGameLeaderboard(gameIndex) {
    return (gameLeaderboards[gameIndex] || []).slice(0, 5);
}

// ========== IMPROVED TIMER ==========
let playStartTime = null;
let currentGameIndex = null;
let playTimeInterval = null;
let accumulatedTime = 0;

function startPlayTimer(gameIndex) {
    stopPlayTimer();
    currentGameIndex = gameIndex;
    playStartTime = Date.now();
    accumulatedTime = playTimeData[`game_${gameIndex}`] || 0;
    
    playTimeInterval = setInterval(() => {
        if (currentGameIndex !== null && playStartTime) {
            const elapsed = Math.floor((Date.now() - playStartTime) / 1000);
            const total = accumulatedTime + elapsed;
            playTimeData[`game_${currentGameIndex}`] = total;
            
            // Update personal best
            if (!personalBests[`game_${currentGameIndex}`] || total > personalBests[`game_${currentGameIndex}`]) {
                personalBests[`game_${currentGameIndex}`] = total;
            }
            
            // Update leaderboard every 10 seconds
            if (elapsed % 10 === 0 && elapsed > 0) {
                updateGameLeaderboard(currentGameIndex, total);
            }
            
            // Save every 5 seconds
            if (elapsed % 5 === 0) saveAll();
        }
    }, 1000);
}

function stopPlayTimer() {
    if (playTimeInterval) { clearInterval(playTimeInterval); playTimeInterval = null; }
    if (currentGameIndex !== null && playStartTime) {
        const elapsed = Math.floor((Date.now() - playStartTime) / 1000);
        const total = accumulatedTime + elapsed;
        playTimeData[`game_${currentGameIndex}`] = total;
        if (!personalBests[`game_${currentGameIndex}`] || total > personalBests[`game_${currentGameIndex}`]) {
            personalBests[`game_${currentGameIndex}`] = total;
        }
        updateGameLeaderboard(currentGameIndex, total);
        saveAll();
    }
    currentGameIndex = null;
    playStartTime = null;
    accumulatedTime = 0;
}

// ========== AI ASSISTANT ==========
function toggleAI() {
    document.getElementById('aiChat').classList.toggle('active');
}

function sendAIMessage() {
    const input = document.getElementById('aiInput');
    const msg = input.value.trim();
    if (!msg) return;
    
    const messages = document.getElementById('aiMessages');
    messages.innerHTML += `<div class="ai-message user">${escapeHtml(msg)}</div>`;
    input.value = '';
    messages.scrollTop = messages.scrollHeight;
    
    // AI response
    setTimeout(() => {
        const response = generateAIResponse(msg);
        messages.innerHTML += `<div class="ai-message bot">${response}</div>`;
        messages.scrollTop = messages.scrollHeight;
    }, 500);
}

function generateAIResponse(msg) {
    const lower = msg.toLowerCase();
    
    if (lower.includes('recommend') || lower.includes('suggest')) {
        const topRated = games
            .map((g, i) => ({ ...g, index: i, rating: ratings[i] || 0 }))
            .sort((a, b) => b.rating - a.rating)
            .slice(0, 3);
        if (topRated.length > 0) {
            return `I recommend: ${topRated.map(g => `🎮 ${g.title} (${'★'.repeat(g.rating)})`).join(', ')}`;
        }
        return "Try adding some games first! Then I can give better recommendations.";
    }
    
    if (lower.includes('popular') || lower.includes('most played')) {
        const popular = [...games].sort((a, b) => (b.views || 0) - (a.views || 0)).slice(0, 3);
        if (popular.length > 0) return `Most played: ${popular.map(g => `🎮 ${g.title} (${g.views || 0} plays)`).join(', ')}`;
        return "No games played yet!";
    }
    
    if (lower.includes('category') || lower.includes('categories')) {
        return `Available categories: ${customCategories.join(', ')}. You can also create custom categories!`;
    }
    
    if (lower.includes('total') || lower.includes('stats')) {
        return `📊 Stats: ${games.length} games, ${totalViews} total plays, ${formatPlayTime(Object.values(playTimeData).reduce((a,b)=>a+b,0))} total play time.`;
    }
    
    if (lower.includes('help') || lower.includes('what can you do')) {
        return "I can: 🎮 Recommend games, 📊 Show stats, 🔍 Find games by category, 💡 Give tips, and more! Just ask!";
    }
    
    const responses = [
        "That's interesting! Try searching for games using the search bar or category filters.",
        "I'm here to help! Ask me to find games, show stats, or give recommendations.",
        "Did you know? You can create custom categories and add YouTube videos!",
        "Tip: Use keyboard shortcuts! Ctrl+K to search, Ctrl+S for stats.",
        "You can rate games and build a leaderboard for each game!"
    ];
    
    return responses[Math.floor(Math.random() * responses.length)];
}

// ========== UTILS ==========
function formatPlayTime(s) {
    if (!s) return '0min';
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    return h > 0 ? `${h}h ${m}min` : `${m}min`;
}

function escapeHtml(s) {
    if (!s) return '';
    return s.replace(/[&<>]/g, m => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;' })[m] || m);
}

function showToast(msg, type = 'success') {
    const container = document.getElementById('toastContainer');
    const toast = document.createElement('div');
    toast.className = `toast ${type}`;
    toast.textContent = msg;
    container.appendChild(toast);
    setTimeout(() => {
        toast.style.animation = 'slideOut 0.3s ease-out';
        setTimeout(() => toast.remove(), 300);
    }, 3000);
}

function saveAll() {
    saveData("games", games);
    saveData("totalViews", totalViews);
    saveData("playTimeData", playTimeData);
    saveData("personalBests", personalBests);
    saveData("ratings", ratings);
    saveData("favorites", favorites);
    saveData("gameTags", gameTags);
    saveData("comments", comments);
    saveData("recentlyPlayed", recentlyPlayed);
    saveData("updatedGames", updatedGames);
    saveData("gameLeaderboards", gameLeaderboards);
    saveData("customCategories", customCategories);
    saveData("gameTypes", gameTypes);
    document.getElementById("totalGames").innerText = games.length;
    document.getElementById("totalViews").innerText = totalViews;
}

// ========== KEYBOARD SHORTCUTS ==========
document.addEventListener('keydown', function(e) {
    if (e.ctrlKey && e.key === 'k') { e.preventDefault(); document.getElementById('searchInput').focus(); }
    if (e.ctrlKey && e.key === 's') { e.preventDefault(); openStats(); }
    if (e.ctrlKey && e.shiftKey && e.key === 'A') { e.preventDefault(); toggleAdmin(); }
    if (e.ctrlKey && e.key === 'e') { e.preventDefault(); openImportExport(); }
    if (e.key === 'Escape') { closeStats(); closeAdmin(); closeImportExport(); }
});

// ========== AUTH ==========
function openLogin() { document.getElementById("loginOverlay").style.display = "flex"; }
function login() {
    const val = document.getElementById("pass").value;
    if (adminPasswords.includes(val)) {
        unlocked = true;
        sessionStorage.setItem("admin", "true");
        document.getElementById("loginOverlay").style.display = "none";
        document.getElementById("adminPanel").classList.add("active");
        showToast("✅ Admin unlocked!");
    } else { showToast("❌ Wrong password!", "error"); }
}
function toggleAdmin() {
    if (!unlocked) { openLogin(); return; }
    document.getElementById("adminPanel").classList.toggle("active");
}
function closeAdmin() { document.getElementById("adminPanel").classList.remove("active"); }

// ========== STATS ==========
function openStats() {
    document.getElementById('statsOverlay').style.display = 'flex';
    document.getElementById('statsDashboard').style.display = 'block';
    document.getElementById('statTotalGames').innerText = games.length;
    document.getElementById('statTotalPlays').innerText = totalViews;
    document.getElementById('statTotalTime').innerText = formatPlayTime(Object.values(playTimeData).reduce((a,b)=>a+b,0));
    const mp = games.reduce((max, g) => (g.views || 0) > (max.views || 0) ? g : max, games[0]);
    document.getElementById('statMostPlayed').innerText = mp ? mp.title : '-';
    const allR = Object.values(ratings).filter(r => r > 0);
    document.getElementById('statAvgRating').innerText = allR.length ? (allR.reduce((a,b)=>a+b,0)/allR.length).toFixed(1) : '-';
}
function closeStats() {
    document.getElementById('statsOverlay').style.display = 'none';
    document.getElementById('statsDashboard').style.display = 'none';
}

// ========== IMPORT/EXPORT ==========
function openImportExport() { document.getElementById("importExportModal").style.display = "flex"; generateExportCode(); }
function closeImportExport() { document.getElementById("importExportModal").style.display = "none"; }
function generateExportCode() {
    document.getElementById("exportCode").value = btoa(encodeURIComponent(JSON.stringify({
        games, playTimeData, personalBests, ratings, favorites, gameTags, comments, gameLeaderboards, customCategories, gameTypes
    })));
}
function copyExportCode() {
    document.getElementById("exportCode").select();
    document.execCommand("copy");
    showToast("✅ Copied!");
}
async function importGames() {
    const code = document.getElementById("importCode").value.trim();
    if (!code) { showToast("❌ Paste code first!", "error"); return; }
    try {
        const data = JSON.parse(decodeURIComponent(atob(code)));
        if (document.getElementById("replaceExisting").checked) {
            games = data.games || [];
            playTimeData = data.playTimeData || {};
            personalBests = data.personalBests || {};
            ratings = data.ratings || {};
            favorites = data.favorites || [];
            gameTags = data.gameTags || {};
            comments = data.comments || {};
            gameLeaderboards = data.gameLeaderboards || {};
            customCategories = data.customCategories || [];
            gameTypes = data.gameTypes || {};
        } else {
            games = games.concat(data.games || []);
            Object.assign(playTimeData, data.playTimeData || {});
            Object.assign(personalBests, data.personalBests || {});
            Object.assign(ratings, data.ratings || {});
            favorites = [...new Set([...favorites, ...(data.favorites || [])])];
            Object.assign(gameTags, data.gameTags || {});
            Object.assign(comments, data.comments || {});
            Object.assign(gameLeaderboards, data.gameLeaderboards || {});
            customCategories = [...new Set([...customCategories, ...(data.customCategories || [])])];
            Object.assign(gameTypes, data.gameTypes || {});
        }
        saveAll();
        render();
        renderCategories();
        filterGames();
        showToast(`✅ Imported!`);
    } catch(e) { showToast("❌ Invalid code", "error"); }
}

// ========== FILTERS ==========
let currentFilter = 'all';
function filterByCategory(cat, el) {
    currentFilter = cat;
    document.querySelectorAll('.category-tag').forEach(t => t.classList.remove('active'));
    if (el) el.classList.add('active');
    filterGames();
}
function filterGames() {
    const term = document.getElementById('searchInput').value.toLowerCase();
    document.querySelectorAll('.card').forEach(card => {
        const idx = parseInt(card.dataset.index);
        const g = games[idx];
        if (!g) { card.style.display = 'none'; return; }
        const tags = gameTags[idx] || [];
        const matchSearch = (g.title || '').toLowerCase().includes(term) || (g.desc || '').toLowerCase().includes(term) || tags.some(t => t.toLowerCase().includes(term));
        let matchFilter = true;
        if (currentFilter === 'favorites') matchFilter = favorites.includes(idx);
        else if (currentFilter === 'recent') matchFilter = recentlyPlayed.includes(idx);
        else if (currentFilter === 'mostPlayed') matchFilter = [...games].sort((a,b) => (b.views||0)-(a.views||0)).slice(0,10).includes(g);
        else if (currentFilter !== 'all') matchFilter = tags.map(t => t.toLowerCase()).includes(currentFilter.toLowerCase());
        card.style.display = matchSearch && matchFilter ? 'block' : 'none';
    });
}

function addToRecentlyPlayed(i) {
    recentlyPlayed = recentlyPlayed.filter(r => r !== i);
    recentlyPlayed.unshift(i);
    if (recentlyPlayed.length > 10) recentlyPlayed.pop();
    saveData('recentlyPlayed', recentlyPlayed);
    updateRecentlyPlayed();
}
function updateRecentlyPlayed() {
    document.getElementById('recentList').innerHTML = recentlyPlayed.map(i => {
        if (games[i]) return `<span class="recent-game-chip" onclick="play(${i})">🎮 ${escapeHtml(games[i].title.substring(0,15))}</span>`;
        return '';
    }).join('');
}

// ========== FAVORITES & RATINGS ==========
function toggleFavorite(i, event) {
    event.stopPropagation();
    if (favorites.includes(i)) favorites = favorites.filter(f => f !== i);
    else favorites.push(i);
    saveAll(); render(); filterGames();
}
function rateGame(i, r, event) {
    event.stopPropagation();
    ratings[i] = r;
    saveAll(); render();
}

// ========== RENDER ==========
function render() {
    let g = document.getElementById("games");
    let a = document.getElementById("adminList");
    let html = '', adminHTML = '';

    games.forEach((x, i) => {
        const pt = playTimeData[`game_${i}`] || 0;
        const pb = personalBests[`game_${i}`] || 0;
        const isFav = favorites.includes(i);
        const tags = gameTags[i] || [];
        const updated = updatedGames.includes(i);
        const lb = getGameLeaderboard(i);
        const type = gameTypes[i] || 'html';
        
        let thumbHTML = '';
        if (type === 'youtube' && x.youtubeId) {
            thumbHTML = `<iframe class="yt-thumb" src="https://www.youtube.com/embed/${x.youtubeId}?controls=0&showinfo=0&autohide=1" style="pointer-events:none;"></iframe>`;
        } else {
            thumbHTML = `<img src="${x.image || 'data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22200%22 fill=%22%232a2a2a%22%3E%3Crect width=%22400%22 height=%22200%22/%3E%3Ctext x=%2250%25%22 y=%2250%25%22 fill=%22white%22 text-anchor=%22middle%22 dy=%22.3em%22%3ENo Image%3C/text%3E%3C/svg%3E'}" loading="lazy" onerror="this.src='data:image/svg+xml,%3Csvg xmlns=%22http://www.w3.org/2000/svg%22 width=%22400%22 height=%22200%22 fill=%22%232a2a2a%22%3E%3Crect width=%22400%22 height=%22200%22/%3E%3C/svg%3E'">`;
        }

        html += `
        <div class="card ${updated ? 'updated' : ''}" data-index="${i}">
            ${updated ? '<div class="update-badge">🆕 UPDATED</div>' : ''}
            <button class="favorite-btn ${isFav ? 'active' : ''}" onclick="toggleFavorite(${i}, event)">${isFav ? '❤️' : '🤍'}</button>
            ${thumbHTML}
            <div class="info">
                <h2>${escapeHtml(x.title)}</h2>
                <div class="game-tags">${tags.map(t => `<span class="game-tag">${escapeHtml(t)}</span>`).join('')}</div>
                <div class="rating">${[1,2,3,4,5].map(s => `<span class="star ${s <= (ratings[i] || 0) ? 'active' : ''}" onclick="rateGame(${i}, ${s}, event)">★</span>`).join('')}</div>
                <div class="desc">${escapeHtml(x.desc || "")}</div>
                <div style="background:rgba(0,170,255,0.1);border:1px solid rgba(0,170,255,0.3);border-radius:8px;padding:8px;margin-top:8px;font-size:12px;color:#00aaff;">
                    ⏱️ ${formatPlayTime(pt)} | 🏆 Best: ${formatPlayTime(pb)}
                </div>
                ${lb.length > 0 ? `
                <div class="leaderboard-section">
                    🏅 Leaderboard:
                    ${lb.map((e, i) => `<div class="leaderboard-entry"><span>${i+1}. ${escapeHtml(e.profile || 'Player')}</span><span>${formatPlayTime(e.time)}</span></div>`).join('')}
                </div>` : ''}
                <button class="playBtn blue" onclick="play(${i})">${type === 'youtube' ? '▶️ WATCH' : 'PLAY'}</button>
                <button class="playBtn green" onclick="fullscreenGame(${i})">FULLSCREEN</button>
                <button class="playBtn purple" onclick="newTab(${i})">NEW TAB</button>
                <div class="meta"><span>📅 ${x.date || '?'}</span><span>👁️ ${x.views || 0}</span></div>
            </div>
        </div>`;

        adminHTML += `
        <div style="border-bottom:1px solid #333;padding:8px 0;">
            <b>${escapeHtml(x.title)}</b> (${type}) | 👁️ ${x.views}<br>
            <button onclick="startEdit(${i})" style="background:#ff8800;color:white;border:none;padding:6px;border-radius:6px;margin:2px;">Edit</button>
            <button onclick="del(${i})" style="background:red;color:white;border:none;padding:6px;border-radius:6px;margin:2px;">Del</button>
            <button onclick="updatedGames.push(${i}); saveAll(); render();" style="background:#00aaff;color:white;border:none;padding:6px;border-radius:6px;margin:2px;">🆕 Mark Updated</button>
        </div>`;
    });

    g.innerHTML = html;
    a.innerHTML = adminHTML;
    document.getElementById("totalGames").innerText = games.length;
    document.getElementById("totalViews").innerText = totalViews;
    updateRecentlyPlayed();
}

// ========== GAME ACTIONS ==========
let editIndex = null;
function startEdit(i) {
    editIndex = i;
    const g = games[i];
    document.getElementById('title').value = g.title;
    document.getElementById('image').value = g.image || '';
    document.getElementById('desc').value = g.desc || '';
    document.getElementById('tags').value = (gameTags[i] || []).join(', ');
    document.getElementById('gameType').value = gameTypes[i] || 'html';
    if (gameTypes[i] === 'youtube') {
        document.getElementById('code').style.display = 'none';
        document.getElementById('youtubeUrl').style.display = 'block';
        document.getElementById('youtubeUrl').value = g.youtubeUrl || '';
    } else {
        document.getElementById('code').style.display = 'block';
        document.getElementById('youtubeUrl').style.display = 'none';
        document.getElementById('code').value = g.code || '';
    }
    const btn = document.querySelector('.adminPanel .addBtn');
    btn.textContent = 'UPDATE GAME';
    btn.style.background = '#ff8800';
    btn.onclick = updateGame;
}

function updateGame() {
    if (editIndex === null) return;
    const type = document.getElementById('gameType').value;
    games[editIndex] = {
        ...games[editIndex],
        title: document.getElementById('title').value,
        image: document.getElementById('image').value,
        desc: document.getElementById('desc').value,
        code: type === 'html' ? document.getElementById('code').value : '',
        youtubeId: type === 'youtube' ? getYouTubeID(document.getElementById('youtubeUrl').value) : null,
        youtubeUrl: type === 'youtube' ? document.getElementById('youtubeUrl').value : '',
        updated: new Date().toLocaleString()
    };
    gameTags[editIndex] = document.getElementById('tags').value.split(',').map(t => t.trim()).filter(t => t);
    gameTypes[editIndex] = type;
    updatedGames.push(editIndex);
    resetForm();
    saveAll(); render(); filterGames();
    showToast("✅ Game updated!");
}

function addGame() {
    const title = document.getElementById('title').value;
    const type = document.getElementById('gameType').value;
    const code = type === 'html' ? document.getElementById('code').value : '';
    const ytId = type === 'youtube' ? getYouTubeID(document.getElementById('youtubeUrl').value) : null;
    
    if (!title || (type === 'html' && !code) || (type === 'youtube' && !ytId)) {
        showToast("❌ Fill all required fields!", "error"); return;
    }
    
    const idx = games.length;
    games.push({
        title, image: document.getElementById('image').value,
        desc: document.getElementById('desc').value,
        code, youtubeId: ytId,
        youtubeUrl: type === 'youtube' ? document.getElementById('youtubeUrl').value : '',
        views: 0, date: new Date().toLocaleDateString(), updated: new Date().toLocaleString()
    });
    gameTags[idx] = document.getElementById('tags').value.split(',').map(t => t.trim()).filter(t => t);
    gameTypes[idx] = type;
    updatedGames.push(idx);
    resetForm();
    saveAll(); render();
    showToast("✅ Game added!");
}

function resetForm() {
    ['title','image','desc','code','tags','youtubeUrl'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    document.getElementById('gameType').value = 'html';
    document.getElementById('code').style.display = 'block';
    document.getElementById('youtubeUrl').style.display = 'none';
    const btn = document.querySelector('.adminPanel .addBtn');
    btn.textContent = 'ADD GAME';
    btn.style.background = '#00aa55';
    btn.onclick = addGame;
    editIndex = null;
}

function del(i) {
    if (confirm(`Delete "${games[i].title}"?`)) {
        delete playTimeData[`game_${i}`];
        delete personalBests[`game_${i}`];
        delete ratings[i];
        delete gameTags[i];
        delete comments[i];
        delete gameLeaderboards[i];
        delete gameTypes[i];
        favorites = favorites.filter(f => f !== i);
        games.splice(i, 1);
        saveAll(); render(); filterGames();
    }
}

function play(i) {
    games[i].views++; totalViews++;
    addToRecentlyPlayed(i);
    updatedGames = updatedGames.filter(u => u !== i);
    
    const type = gameTypes[i] || 'html';
    const frame = document.getElementById('frame');
    frame.style.display = 'block';
    
    if (type === 'youtube' && games[i].youtubeId) {
        frame.srcdoc = `<!DOCTYPE html><html><head><style>*{margin:0;padding:0;background:#000;}iframe{width:100%;height:100%;border:none;}</style></head><body><iframe src="https://www.youtube.com/embed/${games[i].youtubeId}?autoplay=1&rel=0" allow="autoplay; encrypted-media" allowfullscreen></iframe></body></html>`;
    } else {
        frame.srcdoc = games[i].code;
    }
    
    frame.scrollIntoView({ behavior: 'smooth' });
    saveAll();
    startPlayTimer(i);
}

function fullscreenGame(i) {
    play(i);
    const frame = document.getElementById('frame');
    if (frame.requestFullscreen) frame.requestFullscreen();
}

function newTab(i) {
    games[i].views++; totalViews++;
    addToRecentlyPlayed(i);
    updatedGames = updatedGames.filter(u => u !== i);
    saveAll();
    
    const type = gameTypes[i] || 'html';
    if (type === 'youtube' && games[i].youtubeId) {
        window.open(`https://www.youtube.com/watch?v=${games[i].youtubeId}`, '_blank');
    } else {
        const win = window.open('', '_blank');
        win.document.write(`<!DOCTYPE html><html><head><meta charset="UTF-8"><title>${escapeHtml(games[i].title)}</title></head><body>${games[i].code}</body></html>`);
    }
    startPlayTimer(i);
}

function saveAdmins() {
    adminPasswords = document.getElementById("admins").value.split(",").map(v => v.trim()).filter(v => v);
    saveData("admins", adminPasswords);
    showToast("✅ Admins saved");
}

function uploadHTMLFile() {
    const file = document.getElementById('htmlFileInput').files[0];
    if (file) {
        const reader = new FileReader();
        reader.onload = function(e) { document.getElementById('code').value = e.target.result; };
        reader.readAsText(file);
    }
}

// ========== INIT ==========
const savedBG = loadData("bg", "default");
document.getElementById("bgSelect").value = savedBG;
currentBG = savedBG;
changeBG();

// Particles
const p = document.querySelector(".particles");
const frag = document.createDocumentFragment();
for (let i = 0; i < 150; i++) {
    let s = document.createElement("span");
    s.style.left = Math.random() * 100 + "vw";
    s.style.animationDuration = (Math.random() * 10 + 5) + "s";
    s.style.animationDelay = Math.random() * 5 + "s";
    frag.appendChild(s);
}
p.appendChild(frag);

document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) stopPlayTimer();
});

const frameObserver = new MutationObserver((mutations) => {
    mutations.forEach(m => {
        if (m.type === 'attributes' && m.attributeName === 'style') {
            if (document.getElementById('frame').style.display === 'none') stopPlayTimer();
        }
    });
});
frameObserver.observe(document.getElementById('frame'), { attributes: true });

animateBG();
render();
renderCategories();

// Update custom categories list in admin
function updateAdminCategories() {
    document.getElementById('customCategoriesList').innerHTML = customCategories.map(c => 
        `<span style="display:inline-block;background:rgba(0,170,255,0.1);padding:4px 10px;border-radius:10px;margin:2px;font-size:12px;">${c} <button onclick="deleteCategory('${c}');updateAdminCategories();" style="background:none;border:none;color:red;cursor:pointer;">✕</button></span>`
    ).join('');
}
updateAdminCategories();

setInterval(saveAll, 30000);
</script>
</body>
</html>
