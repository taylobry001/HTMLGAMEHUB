// Cell metadata per cell: type(Uint8), energy(Float32), radiation(Float32), age(Uint16), flags(Uint8)
// Packed as flat arrays for performance
let cellType, cellEnergy, cellRadiation, cellAge, cellFlags;
let cellMoved; // to track if cell was updated this tick

// Particle system
class Particle {
  constructor(x, y, vx, vy, color, life, size, type) {
    this.x = x; this.y = y;
    this.vx = vx; this.vy = vy;
    this.color = color;
    this.life = life; this.maxLife = life;
    this.size = size || 2;
    this.type = type || 'dot'; // dot, spark, glow, smoke, radiation
    this.alpha = 1;
  }
  update(dt) {
    this.x += this.vx * dt;
    this.y += this.vy * dt;
    this.vy += 0.05 * dt; // slight gravity for most
    this.vx *= 0.98;
    this.life -= dt;
    this.alpha = Math.max(0, this.life / this.maxLife);
    if (this.type === 'smoke') {
      this.vy -= 0.08 * dt;
      this.vy *= 0.95;
      this.vx *= 0.95;
      this.size += 0.01 * dt;
    }
    if (this.type === 'radiation') {
      this.vx += (Math.random() - 0.5) * 0.3;
      this.vy += (Math.random() - 0.5) * 0.3;
    }
  }
  draw(ctx) {
    ctx.save();
    ctx.globalAlpha = this.alpha;
    if (this.type === 'glow') {
      const grd = ctx.createRadialGradient(this.x, this.y, 0, this.x, this.y, this.size * 2);
      grd.addColorStop(0, this.color);
      grd.addColorStop(1, 'transparent');
      ctx.fillStyle = grd;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size * 2, 0, Math.PI * 2);
      ctx.fill();
    } else if (this.type === 'smoke') {
      ctx.fillStyle = this.color;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    } else {
      ctx.fillStyle = this.color;
      ctx.shadowColor = this.color;
      ctx.shadowBlur = this.size * 2;
      ctx.beginPath();
      ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
      ctx.fill();
    }
    ctx.restore();
  }
}

