  background: linear-gradient(90deg, var(--neon-cyan), var(--neon-green));
  border-radius: 2px;
  transition: width 0.5s ease;
}

/* INTRO ANIMATION */
@keyframes titlePulse {
  0%, 100% { text-shadow: 0 0 30px var(--neon-cyan), 0 0 60px rgba(0,229,255,0.3); }
  50% { text-shadow: 0 0 50px var(--neon-cyan), 0 0 100px rgba(0,229,255,0.5), 0 0 150px rgba(0,229,255,0.2); }
}

.menu-title { animation: titlePulse 2s infinite; }

/* Danger warning */
@keyframes dangerFlash {
  0%, 100% { border-color: rgba(255,34,68,0.4); }
  50% { border-color: var(--neon-red); box-shadow: 0 0 20px var(--neon-red); }
}

.danger-warning { animation: dangerFlash 0.5s infinite; }

/* Chain reaction flash */
@keyframes chainFlash {
  0% { opacity: 0; }
  10% { opacity: 0.6; }
  100% { opacity: 0; }
}

</style>
</head>
