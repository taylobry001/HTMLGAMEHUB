<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>NUCLEAR SANDBOX — REACTOR ZERO</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700;900&family=Share+Tech+Mono&family=Exo+2:wght@300;400;600&display=swap');

:root {
  --neon-green: #00ff88;
  --neon-cyan: #00e5ff;
  --neon-yellow: #ffee00;
  --neon-orange: #ff8800;
  --neon-red: #ff2244;
  --neon-purple: #cc44ff;
  --neon-blue: #0088ff;
  --bg-dark: #030810;
  --bg-panel: rgba(0,20,40,0.92);
  --border-glow: rgba(0,229,255,0.3);
  --text-dim: #4a7a8a;
  --cell-size: 8px;
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
  background: var(--bg-dark);
  color: var(--neon-cyan);
  font-family: 'Share Tech Mono', monospace;
  overflow: hidden;
  width: 100vw; height: 100vh;
  cursor: crosshair;
  user-select: none;
}

#game-wrapper {
  position: relative;
  width: 100vw; height: 100vh;
  overflow: hidden;
}

/* BACKGROUND GRID */
#bg-grid {
  position: absolute; inset: 0;
  background-image:
    linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
  background-size: 40px 40px;
  pointer-events: none;
  z-index: 0;
}

/* MAIN CANVAS */
#main-canvas {
  position: absolute;
  top: 0; left: 0;
  z-index: 1;
  image-rendering: pixelated;
}

/* PARTICLE CANVAS */
#particle-canvas {
  position: absolute;
  top: 0; left: 0;
  z-index: 2;
  pointer-events: none;
}

/* EFFECT OVERLAY */
#effect-overlay {
  position: absolute; inset: 0;
  z-index: 3;
  pointer-events: none;
  mix-blend-mode: screen;
}

/* SCREEN SHAKE */
#shake-layer {
  position: absolute; inset: -20px;
  z-index: 10;
  pointer-events: none;
}

/* ====== HUD ====== */
#hud {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  z-index: 20;
  pointer-events: none;
}

/* TOP BAR */
#top-bar {
  position: absolute;
  top: 0; left: 0; right: 0;
  height: 52px;
  background: linear-gradient(180deg, rgba(0,10,25,0.98) 0%, rgba(0,10,25,0.7) 100%);
  border-bottom: 1px solid var(--border-glow);
  display: flex;
  align-items: center;
  padding: 0 16px;
  gap: 20px;
  pointer-events: all;
  backdrop-filter: blur(8px);
}

#game-title {
  font-family: 'Orbitron', sans-serif;
  font-weight: 900;
  font-size: 16px;
  letter-spacing: 3px;
  color: var(--neon-cyan);
  text-shadow: 0 0 20px var(--neon-cyan), 0 0 40px rgba(0,229,255,0.3);
  white-space: nowrap;
}

.title-sub {
  font-size: 9px;
  color: var(--text-dim);
  letter-spacing: 2px;
  margin-top: 2px;
  display: block;
}

#top-stats {
  display: flex;
  gap: 16px;
  flex: 1;
  justify-content: center;
  flex-wrap: wrap;
}

.stat-chip {
  display: flex;
  align-items: center;
  gap: 6px;
  background: rgba(0,229,255,0.05);
  border: 1px solid rgba(0,229,255,0.15);
  border-radius: 4px;
  padding: 4px 10px;
  font-size: 11px;
  white-space: nowrap;
}

.stat-chip .label { color: var(--text-dim); }
.stat-chip .value { color: var(--neon-cyan); font-weight: bold; }
.stat-chip.danger .value { color: var(--neon-red); text-shadow: 0 0 8px var(--neon-red); }
.stat-chip.warn .value { color: var(--neon-orange); }
.stat-chip.safe .value { color: var(--neon-green); }

#top-buttons {
  display: flex;
  gap: 8px;
}

.hud-btn {
  background: rgba(0,229,255,0.08);
  border: 1px solid rgba(0,229,255,0.3);
  color: var(--neon-cyan);
  padding: 6px 12px;
  font-family: 'Share Tech Mono', monospace;
  font-size: 11px;
  cursor: pointer;
  border-radius: 3px;
  transition: all 0.15s;
  letter-spacing: 1px;
  text-transform: uppercase;
}

.hud-btn:hover {
  background: rgba(0,229,255,0.2);
  box-shadow: 0 0 12px rgba(0,229,255,0.3);
}

.hud-btn.active {
  background: rgba(0,229,255,0.25);
  box-shadow: 0 0 15px rgba(0,229,255,0.5);
  color: white;
}

.hud-btn.danger-btn {
  border-color: rgba(255,34,68,0.4);
  color: var(--neon-red);
}

.hud-btn.danger-btn:hover {
  background: rgba(255,34,68,0.2);
  box-shadow: 0 0 12px rgba(255,34,68,0.3);
}

/* LEFT PANEL - ELEMENTS */
#left-panel {
  position: absolute;
  top: 52px; left: 0; bottom: 0;
  width: 200px;
  background: var(--bg-panel);
  border-right: 1px solid var(--border-glow);
  display: flex;
  flex-direction: column;
  pointer-events: all;
  overflow-y: auto;
  overflow-x: hidden;
  backdrop-filter: blur(12px);
}

.panel-section {
  border-bottom: 1px solid rgba(0,229,255,0.1);
  padding: 10px 8px;
}

.panel-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 9px;
  letter-spacing: 2px;
  color: var(--text-dim);
  margin-bottom: 8px;
  text-transform: uppercase;
  padding-left: 4px;
}

.element-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 4px;
}

.element-btn {
  position: relative;
  padding: 8px 6px;
  border-radius: 4px;
  cursor: pointer;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  text-align: center;
  transition: all 0.15s;
  border: 1px solid transparent;
  overflow: hidden;
}

.element-btn::before {
  content: '';
  position: absolute;
  inset: 0;
  opacity: 0.15;
  transition: opacity 0.15s;
}

.element-btn:hover::before { opacity: 0.3; }
.element-btn:hover { transform: translateY(-1px); }

.element-btn.selected {
  border-color: white !important;
  transform: translateY(-1px);
  box-shadow: 0 0 12px rgba(255,255,255,0.2);
}

.element-btn.selected::before { opacity: 0.4; }

.el-symbol {
  font-family: 'Orbitron', sans-serif;
  font-weight: 700;
  font-size: 15px;
  display: block;
  line-height: 1;
  margin-bottom: 2px;
}

.el-name {
  font-size: 8px;
  opacity: 0.8;
  letter-spacing: 0.5px;
}

.el-locked {
  opacity: 0.3;
  filter: grayscale(0.8);
  cursor: not-allowed;
}

/* Element color themes */
.el-uranium { background: rgba(0,255,100,0.1); border-color: rgba(0,255,100,0.3); color: #00ff64; }
.el-uranium::before { background: radial-gradient(circle, #00ff64, transparent); }
.el-plutonium { background: rgba(0,200,255,0.1); border-color: rgba(0,200,255,0.3); color: #00c8ff; }
.el-plutonium::before { background: radial-gradient(circle, #00c8ff, transparent); }
.el-thorium { background: rgba(200,150,0,0.1); border-color: rgba(200,150,0,0.3); color: #c89600; }
.el-thorium::before { background: radial-gradient(circle, #c89600, transparent); }
.el-neutron { background: rgba(200,200,255,0.1); border-color: rgba(200,200,255,0.3); color: #c8c8ff; }
.el-neutron::before { background: radial-gradient(circle, #c8c8ff, transparent); }
.el-water { background: rgba(0,120,255,0.1); border-color: rgba(0,120,255,0.3); color: #0078ff; }
.el-water::before { background: radial-gradient(circle, #0078ff, transparent); }
.el-graphite { background: rgba(120,120,120,0.1); border-color: rgba(120,120,120,0.3); color: #888; }
.el-graphite::before { background: radial-gradient(circle, #888, transparent); }
.el-lead { background: rgba(100,80,120,0.1); border-color: rgba(100,80,120,0.3); color: #9a7ab0; }
.el-lead::before { background: radial-gradient(circle, #9a7ab0, transparent); }
.el-fire { background: rgba(255,80,0,0.1); border-color: rgba(255,80,0,0.3); color: #ff5000; }
.el-fire::before { background: radial-gradient(circle, #ff5000, transparent); }
.el-plasma { background: rgba(255,0,200,0.1); border-color: rgba(255,0,200,0.3); color: #ff00c8; }
.el-plasma::before { background: radial-gradient(circle, #ff00c8, transparent); }
.el-ice { background: rgba(180,230,255,0.1); border-color: rgba(180,230,255,0.3); color: #b4e6ff; }
.el-ice::before { background: radial-gradient(circle, #b4e6ff, transparent); }
.el-antimatter { background: rgba(255,0,0,0.1); border-color: rgba(255,0,0,0.5); color: #ff0000; }
.el-antimatter::before { background: radial-gradient(circle, #ff0000, transparent); }
.el-darkmat { background: rgba(60,0,80,0.2); border-color: rgba(150,0,200,0.4); color: #aa00dd; }
.el-darkmat::before { background: radial-gradient(circle, #aa00dd, transparent); }
.el-creature { background: rgba(0,200,80,0.1); border-color: rgba(0,200,80,0.3); color: #00c850; }
.el-creature::before { background: radial-gradient(circle, #00c850, transparent); }
.el-metal { background: rgba(180,160,100,0.1); border-color: rgba(180,160,100,0.3); color: #b4a064; }
.el-metal::before { background: radial-gradient(circle, #b4a064, transparent); }
.el-gas { background: rgba(200,255,200,0.05); border-color: rgba(200,255,200,0.2); color: #c8ffc8; }
.el-gas::before { background: radial-gradient(circle, #c8ffc8, transparent); }
.el-acid { background: rgba(180,255,0,0.1); border-color: rgba(180,255,0,0.3); color: #b4ff00; }
.el-acid::before { background: radial-gradient(circle, #b4ff00, transparent); }
.el-eraser { background: rgba(255,50,50,0.1); border-color: rgba(255,50,50,0.3); color: #ff3232; }
.el-eraser::before { background: radial-gradient(circle, #ff3232, transparent); }
.el-black-hole { background: radial-gradient(circle, rgba(100,0,150,0.3), rgba(0,0,0,0.8)); border-color: rgba(150,0,255,0.6); color: #9900ff; }
.el-tritium { background: rgba(255,150,0,0.1); border-color: rgba(255,150,0,0.3); color: #ff9600; }
.el-tritium::before { background: radial-gradient(circle, #ff9600, transparent); }
.el-deuterium { background: rgba(255,220,0,0.1); border-color: rgba(255,220,0,0.3); color: #ffdc00; }
.el-deuterium::before { background: radial-gradient(circle, #ffdc00, transparent); }

/* RIGHT PANEL - TOOLS & INFO */
#right-panel {
  position: absolute;
  top: 52px; right: 0; bottom: 0;
  width: 200px;
  background: var(--bg-panel);
  border-left: 1px solid var(--border-glow);
  display: flex;
  flex-direction: column;
  pointer-events: all;
  backdrop-filter: blur(12px);
  overflow-y: auto;
}

/* TOOL CONTROLS */
.slider-group {
  display: flex;
  flex-direction: column;
  gap: 8px;
  padding: 4px;
}

.slider-row {
  display: flex;
  align-items: center;
  gap: 6px;
}

.slider-label {
  font-size: 9px;
  color: var(--text-dim);
  width: 55px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.slider-val {
  font-size: 10px;
  color: var(--neon-cyan);
  width: 28px;
  text-align: right;
}

input[type=range] {
  -webkit-appearance: none;
  flex: 1;
  height: 3px;
  background: rgba(0,229,255,0.2);
  outline: none;
  border-radius: 2px;
}

input[type=range]::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--neon-cyan);
  box-shadow: 0 0 8px var(--neon-cyan);
  cursor: pointer;
}

/* RADIATION METER */
#rad-meter {
  padding: 10px 8px;
}

.meter-bar {
  height: 8px;
  background: rgba(255,255,255,0.05);
  border-radius: 4px;
  overflow: hidden;
  margin-top: 4px;
  position: relative;
}

.meter-fill {
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s ease;
  position: relative;
  overflow: hidden;
}

.meter-fill::after {
  content: '';
  position: absolute;
  top: 0; left: -100%;
  width: 100%; height: 100%;
  background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
  animation: shimmer 1.5s infinite;
}

@keyframes shimmer { to { left: 200%; } }

.meter-rad { background: linear-gradient(90deg, #00ff88, #ffee00, #ff2244); }
.meter-heat { background: linear-gradient(90deg, #0088ff, #ff8800, #ff2244); }
.meter-power { background: linear-gradient(90deg, #0088ff, #00e5ff); }

/* LOG */
#event-log {
  flex: 1;
  overflow-y: auto;
  padding: 8px;
  min-height: 100px;
  max-height: 200px;
}

.log-entry {
  font-size: 9px;
  padding: 3px 0;
  border-bottom: 1px solid rgba(0,229,255,0.05);
  line-height: 1.4;
  animation: fadeInLog 0.3s ease;
}

@keyframes fadeInLog { from { opacity: 0; transform: translateX(-5px); } to { opacity: 1; transform: translateX(0); } }

.log-normal { color: var(--text-dim); }
.log-warn { color: var(--neon-orange); }
.log-danger { color: var(--neon-red); text-shadow: 0 0 6px var(--neon-red); }
.log-discover { color: var(--neon-green); text-shadow: 0 0 6px var(--neon-green); }
.log-info { color: var(--neon-cyan); }

/* BOTTOM BAR */
#bottom-bar {
  position: absolute;
  bottom: 0; left: 200px; right: 200px;
  height: 44px;
  background: linear-gradient(0deg, rgba(0,10,25,0.98) 0%, rgba(0,10,25,0.7) 100%);
  border-top: 1px solid var(--border-glow);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12px;
  pointer-events: all;
  backdrop-filter: blur(8px);
  padding: 0 12px;
  overflow: hidden;
}

.tool-btn {
  display: flex;
  align-items: center;
  gap: 5px;
  padding: 6px 12px;
  border-radius: 4px;
  cursor: pointer;
  font-family: 'Share Tech Mono', monospace;
  font-size: 10px;
  letter-spacing: 1px;
  transition: all 0.15s;
  border: 1px solid rgba(0,229,255,0.2);
  background: rgba(0,229,255,0.05);
  color: var(--text-dim);
  white-space: nowrap;
}

.tool-btn:hover, .tool-btn.active {
  color: var(--neon-cyan);
  border-color: rgba(0,229,255,0.5);
  background: rgba(0,229,255,0.15);
  box-shadow: 0 0 10px rgba(0,229,255,0.2);
}

.tool-btn .tool-key {
  font-size: 9px;
  opacity: 0.5;
  background: rgba(255,255,255,0.1);
  padding: 1px 4px;
  border-radius: 2px;
}

/* DISCOVERY POPUP */
#discovery-popup {
  position: fixed;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
  z-index: 100;
  background: rgba(0,10,25,0.97);
  border: 2px solid var(--neon-green);
  border-radius: 8px;
  padding: 24px 32px;
  text-align: center;
  max-width: 380px;
  box-shadow: 0 0 40px rgba(0,255,136,0.3), 0 0 80px rgba(0,255,136,0.1);
  transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: all;
}

#discovery-popup.show { transform: translate(-50%, -50%) scale(1); }

#discovery-popup .disc-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 10px;
  letter-spacing: 4px;
  color: var(--neon-green);
  margin-bottom: 10px;
}

#discovery-popup .disc-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 24px;
  font-weight: 900;
  color: white;
  margin-bottom: 8px;
  text-shadow: 0 0 20px var(--neon-green);
}

#discovery-popup .disc-desc {
  font-size: 12px;
  color: var(--text-dim);
  margin-bottom: 16px;
  line-height: 1.5;
}

/* EXPLOSION FLASH */
#explosion-flash {
  position: fixed; inset: 0;
  z-index: 50;
  background: white;
  opacity: 0;
  pointer-events: none;
  transition: opacity 0.05s;
}

/* MENU OVERLAY */
#menu-overlay {
  position: fixed; inset: 0;
  z-index: 90;
  background: rgba(0,5,15,0.97);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  backdrop-filter: blur(10px);
}

#menu-overlay.hidden { display: none; }

.menu-title {
  font-family: 'Orbitron', sans-serif;
  font-size: 42px;
  font-weight: 900;
  color: var(--neon-cyan);
  letter-spacing: 6px;
  text-shadow: 0 0 30px var(--neon-cyan), 0 0 60px rgba(0,229,255,0.3);
  margin-bottom: 8px;
  text-align: center;
}

.menu-subtitle {
  font-family: 'Exo 2', sans-serif;
  font-size: 13px;
  color: var(--text-dim);
  letter-spacing: 4px;
  margin-bottom: 32px;
  text-align: center;
}

.menu-btn {
  width: 280px;
  padding: 14px 24px;
  text-align: center;
  cursor: pointer;
  font-family: 'Orbitron', sans-serif;
  font-size: 13px;
  letter-spacing: 3px;
  border: 1px solid rgba(0,229,255,0.3);
  background: rgba(0,229,255,0.05);
  color: var(--neon-cyan);
  border-radius: 4px;
  transition: all 0.2s;
  text-transform: uppercase;
}

.menu-btn:hover {
  background: rgba(0,229,255,0.2);
  box-shadow: 0 0 20px rgba(0,229,255,0.3);
  border-color: var(--neon-cyan);
  transform: scale(1.02);
}

.menu-btn.primary {
  border-color: var(--neon-green);
  color: var(--neon-green);
  background: rgba(0,255,136,0.05);
  font-size: 15px;
}

.menu-btn.primary:hover {
  background: rgba(0,255,136,0.2);
  box-shadow: 0 0 25px rgba(0,255,136,0.4);
}

/* TOOLTIP */
#tooltip {
  position: fixed;
  z-index: 80;
  background: rgba(0,10,25,0.97);
  border: 1px solid rgba(0,229,255,0.4);
  border-radius: 4px;
  padding: 8px 12px;
  font-size: 11px;
  max-width: 200px;
  pointer-events: none;
  display: none;
  line-height: 1.5;
  box-shadow: 0 4px 20px rgba(0,0,0,0.5);
}

#tooltip .tt-name {
  font-family: 'Orbitron', sans-serif;
  font-size: 12px;
  color: white;
  margin-bottom: 4px;
}

#tooltip .tt-desc { color: var(--text-dim); }
#tooltip .tt-stats { color: var(--neon-cyan); margin-top: 4px; font-size: 10px; }

/* ACHIEVEMENTS */
#achievement-popup {
  position: fixed;
  bottom: 60px; right: 210px;
  z-index: 80;
  background: rgba(0,10,25,0.97);
  border: 1px solid var(--neon-yellow);
  border-radius: 6px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 10px;
  transform: translateX(120%);
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
  box-shadow: 0 0 20px rgba(255,238,0,0.2);
}

#achievement-popup.show { transform: translateX(0); }
.ach-icon { font-size: 22px; }
.ach-text .ach-title { font-family: 'Orbitron', sans-serif; font-size: 9px; color: var(--neon-yellow); letter-spacing: 2px; }
.ach-text .ach-name { font-size: 13px; color: white; margin-top: 2px; }

/* SCROLLBAR */
::-webkit-scrollbar { width: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: rgba(0,229,255,0.2); border-radius: 2px; }

/* RADIATION OVERLAY */
#radiation-vignette {
  position: fixed; inset: 0;
  z-index: 5;
  pointer-events: none;
  opacity: 0;
  background: radial-gradient(ellipse at center, transparent 40%, rgba(0,255,80,0.15) 100%);
  transition: opacity 0.5s;
}

/* SCANLINES */
#scanlines {
  position: fixed; inset: 0;
  z-index: 6;
  pointer-events: none;
  background: repeating-linear-gradient(0deg, transparent, transparent 3px, rgba(0,0,0,0.03) 3px, rgba(0,0,0,0.03) 4px);
}

/* PAUSE OVERLAY */
#pause-overlay {
  position: fixed; inset: 0;
  z-index: 70;
  background: rgba(0,5,15,0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 12px;
  backdrop-filter: blur(4px);
}

#pause-overlay.hidden { display: none; }
.pause-title { font-family: 'Orbitron', sans-serif; font-size: 32px; color: var(--neon-cyan); letter-spacing: 8px; text-shadow: 0 0 30px var(--neon-cyan); }

/* MINI-MAP */
#mini-map {
  position: absolute;
  bottom: 50px; right: 8px;
  width: 100px; height: 100px;
  border: 1px solid rgba(0,229,255,0.2);
  border-radius: 3px;
  background: rgba(0,0,0,0.5);
  pointer-events: none;
  display: none;
}

/* HEAT WAVE EFFECT */
@keyframes heatWave {
  0%, 100% { filter: url(#heat-distort); }
  50% { filter: url(#heat-distort2); }
}

/* Blinking */
@keyframes blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}

.blink { animation: blink 1s infinite; }

/* Glow pulse */
