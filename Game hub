            <div class="info">
                <h2>${escapeHtml(x.title)}</h2>
                <div class="desc">${escapeHtml(x.desc || "")}</div>
                <div class="playtime-display">⏱️ Play Time: ${formatPlayTime(playTime)}</div>
                <div class="personal-best">🏆 Personal Best: ${formatPersonalBest(personalBest)}</div>
                <button class="playBtn blue" onclick="play(${i})">PLAY</button>
