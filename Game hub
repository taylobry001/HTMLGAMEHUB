<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultimate Game Hub</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    background:#050505;
    color:white;
    overflow-x:hidden;
    transition:.5s;
}

/* BACKGROUND FX */

.bgEffects{
    position:fixed;
    inset:0;
    z-index:-3;
    overflow:hidden;
    pointer-events:none;
}

/* PARTICLES */

.particles{
    position:fixed;
    inset:0;
    z-index:-2;
    pointer-events:none;
}

.particles span{
    position:absolute;
    width:3px;
    height:3px;
    background:white;
    opacity:.15;
    border-radius:50%;
    animation:float linear infinite;
}

@keyframes float{

    from{
        transform:translateY(100vh);
    }

    to{
        transform:translateY(-10vh);
    }
}

/* CYBER GRID */

.cyberLines{
    position:absolute;
    width:200%;
    height:200%;
    background:
    repeating-linear-gradient(
        90deg,
        transparent 0px,
        rgba(0,255,255,.05) 2px,
        transparent 4px
    );

    animation:moveGrid 20s linear infinite;
}

@keyframes moveGrid{

    from{
        transform:translateX(0);
    }

    to{
        transform:translateX(-50%);
    }
}

/* ORBS */

.glowOrb{
    position:absolute;
    border-radius:50%;
    filter:blur(80px);
    opacity:.35;
    animation:floatOrb 12s ease-in-out infinite;
}

@keyframes floatOrb{

    0%{
        transform:translate(0,0) scale(1);
    }

    50%{
        transform:translate(100px,-80px) scale(1.2);
    }

    100%{
        transform:translate(0,0) scale(1);
    }
}

/* HEADER */

header{
    text-align:center;
    padding:25px;
    background:rgba(20,20,20,.75);
    backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(255,255,255,.08);
}

header h1{
    font-size:48px;

    text-shadow:
    0 0 10px #00aaff,
    0 0 30px #00aaff,
    0 0 60px #00aaff;
}

/* TOPBAR */

.topbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 20px;
    background:rgba(15,15,15,.7);
    backdrop-filter:blur(12px);
}

.gear{
    background:none;
    border:none;
    color:white;
    font-size:24px;
    cursor:pointer;
    transition:.3s;
}

.gear:hover{
    transform:rotate(90deg);
}

/* GAMES */

.games{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
    padding:20px;
}

.card{
    background:rgba(20,20,20,.65);
    border-radius:18px;
    overflow:hidden;
    border:1px solid rgba(255,255,255,.08);

    backdrop-filter:blur(12px);

    box-shadow:
    0 0 20px rgba(0,0,0,.35);

    transition:.3s;
}

.card:hover{

    transform:
    translateY(-10px)
    scale(1.02);

    box-shadow:
    0 0 35px rgba(0,170,255,.35);
}

.card img{
    width:100%;
    height:180px;
    object-fit:cover;
}

.info{
    padding:15px;
}

.info h2{
    margin-bottom:10px;
}

.desc{
    color:#aaa;
    font-size:14px;
    margin-bottom:10px;
}

.meta{
    color:#777;
    font-size:12px;
    margin-top:6px;
}

/* BUTTONS */

.playBtn{
    width:100%;
    padding:10px;
    margin-top:8px;
    border:none;
    border-radius:10px;
    color:white;
    cursor:pointer;
    transition:.2s;
}

.playBtn:hover{
    transform:scale(1.03);
}

.blue{
    background:#0099ff;
}

.green{
    background:#00aa55;
}

.purple{
    background:#8844ff;
}

/* LOGIN */

.loginOverlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.88);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:10000;
}

.loginBox{
    background:#1d1d1d;
    padding:25px;
    border-radius:16px;
    width:320px;

    animation:pop .3s;
}

@keyframes pop{

    from{
        transform:scale(.7);
        opacity:0;
    }

    to{
        transform:scale(1);
        opacity:1;
    }
}

.loginBox input{
    width:100%;
    padding:10px;
    margin-top:12px;
    border:none;
    border-radius:10px;
    background:#2a2a2a;
    color:white;
}

.loginBox button{
    width:100%;
    padding:10px;
    margin-top:12px;
    border:none;
    border-radius:10px;
    background:#00aa55;
    color:white;
}

/* ADMIN PANEL */

.adminPanel{
    position:fixed;
    top:0;
    right:-460px;
    width:460px;
    height:100%;
    overflow:auto;

    background:
    linear-gradient(
        180deg,
        rgba(20,20,20,.97),
        rgba(5,5,5,.98)
    );

    backdrop-filter:blur(16px);

    box-shadow:
    -10px 0 40px rgba(0,0,0,.5);

    padding:20px;

    transition:.3s;

    z-index:9999;
}

.adminPanel.active{
    right:0;
}

.adminPanel input,
.adminPanel textarea,
.adminPanel select{
    width:100%;
    padding:10px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#2a2a2a;
    color:white;
}

.addBtn{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#00aa55;
    color:white;
    cursor:pointer;
}

iframe{
    width:100%;
    height:700px;
    border:none;
    display:none;
    background:white;
}

</style>
</head>

<body>

<div class="bgEffects" id="bgEffects"></div>

<div class="particles"></div>

<!-- LOGIN -->

<div class="loginOverlay" id="loginOverlay">

    <div class="loginBox">

        <h2>Admin Login</h2>

        <input
        type="password"
        id="pass"
        placeholder="Password">

        <button onclick="login()">
        Unlock
        </button>

    </div>

</div>

<header>

    <h1>🎮 GAME HUB</h1>

</header>

<div class="topbar">

    <div>
        Total Plays:
        <span id="totalViews">0</span>
    </div>

    <button
    class="gear"
    onclick="toggleAdmin()">
    ⚙️
    </button>

</div>

<!-- GAMES -->

<div class="games" id="games"></div>

<!-- GAME VIEW -->

<iframe id="frame"></iframe>

<!-- ADMIN -->

<div class="adminPanel" id="adminPanel">

    <div style="
    display:flex;
    justify-content:space-between;
    align-items:center;
    ">

        <h2>ADMIN PANEL</h2>

        <button onclick="closeAdmin()" style="
        background:red;
        color:white;
        border:none;
        width:35px;
        height:35px;
        border-radius:10px;
        cursor:pointer;
        ">
        ✕
        </button>

    </div>

    <br>

    <input
    id="title"
    placeholder="Game Title">

    <input
    id="image"
    placeholder="Image URL">

    <textarea
    id="desc"
    rows="3"
    placeholder="Game Description"></textarea>

    <textarea
    id="code"
    rows="8"
    placeholder="FULL HTML GAME"></textarea>

    <button
    class="addBtn"
    onclick="addGame()">
    ADD GAME
    </button>

    <br><br>

    <h3>Backgrounds</h3>

    <select id="bgSelect" onchange="changeBG()">

        <option value="default">Default</option>
        <option value="matrix">Matrix</option>
        <option value="stars">Stars</option>
        <option value="sunset">Sunset</option>
        <option value="purple">Purple Void</option>
        <option value="ocean">Ocean</option>
        <option value="fire">Fire</option>
        <option value="grid">Cyber Grid</option>
        <option value="forest">Forest</option>
        <option value="blood">Blood</option>
        <option value="neon">Neon</option>

    </select>

    <br><br>

    <label>
        <input
        type="checkbox"
        id="particlesToggle"
        checked
        onchange="toggleParticles()">
        Particles
    </label>

    <br><br>

    <input
    id="admins"
    placeholder="Admin Passwords comma separated">

    <button
    class="addBtn"
    onclick="saveAdmins()">
    SAVE ADMINS
    </button>

    <br><br>

    <h3>Games</h3>

    <div id="adminList"></div>

</div>

<script>

/* ADMINS */

let adminPasswords =
JSON.parse(localStorage.getItem("admins"))
|| ["1234"];

let unlocked =
sessionStorage.getItem("admin")
=== "true";

/* LOGIN */

function openLogin(){

    document.getElementById(
        "loginOverlay"
    ).style.display = "flex";
}

function login(){

    const val =
    document.getElementById("pass")
    .value;

    if(adminPasswords.includes(val)){

        unlocked = true;

        sessionStorage.setItem(
            "admin",
            "true"
        );

        document.getElementById(
            "loginOverlay"
        ).style.display = "none";

        document.getElementById(
            "adminPanel"
        ).classList.add("active");

        document.body.animate([
            {filter:"brightness(1)"},
            {filter:"brightness(2)"},
            {filter:"brightness(1)"}
        ],{
            duration:600
        });

        alert("Admin unlocked");

    }else{

        alert("Wrong password");
    }
}

/* ADMIN */

function toggleAdmin(){

    if(!unlocked){

        openLogin();
        return;
    }

    document.getElementById(
        "adminPanel"
    ).classList.toggle("active");
}

function closeAdmin(){

    document.getElementById(
        "adminPanel"
    ).classList.remove("active");
}

/* DATA */

let games =
JSON.parse(localStorage.getItem("games"))
|| [];

let totalViews =
localStorage.getItem("totalViews")
|| 0;

document.getElementById(
    "totalViews"
).innerText = totalViews;

/* SAVE */

function save(){

    localStorage.setItem(
        "games",
        JSON.stringify(games)
    );
}

/* RENDER */

function render(){

    let g =
    document.getElementById("games");

    let a =
    document.getElementById("adminList");

    g.innerHTML = "";
    a.innerHTML = "";

    games.forEach((x,i)=>{

        g.innerHTML += `

        <div class="card">

            <img src="${x.image}">

            <div class="info">

                <h2>${x.title}</h2>

                <div class="desc">
                ${x.desc || ""}
                </div>

                <button
                class="playBtn blue"
                onclick="play(${i})">
                PLAY
                </button>

                <button
                class="playBtn green"
                onclick="fullscreenGame(${i})">
                FULLSCREEN
                </button>

                <button
                class="playBtn purple"
                onclick="newTab(${i})">
                OPEN IN TAB
                </button>

                <div class="meta">
                    Published:
                    ${x.date}
                </div>

                <div class="meta">
                    Updated:
                    ${x.updated}
                </div>

            </div>

        </div>
        `;

        a.innerHTML += `

        <div style="
        border-bottom:1px solid #333;
        padding-bottom:12px;
        margin-bottom:12px;
        ">

        <b>${x.title}</b>

        <br>

        Views:
        ${x.views}

        <br><br>

        <button
        onclick="del(${i})"
        style="
        background:red;
        color:white;
        border:none;
        padding:8px;
        border-radius:8px;
        cursor:pointer;
        ">
        Delete
        </button>

        </div>
        `;
    });
}

/* ADD GAME */

function addGame(){

    games.push({

        title:title.value,

        image:image.value,

        desc:desc.value,

        code:code.value,

        views:0,

        date:new Date()
        .toLocaleDateString(),

        updated:new Date()
        .toLocaleString()
    });

    save();

    render();

    title.value="";
    image.value="";
    desc.value="";
    code.value="";
}

/* PLAY */

function play(i){

    games[i].views++;

    totalViews++;

    localStorage.setItem(
        "totalViews",
        totalViews
    );

    save();

    document.getElementById(
        "totalViews"
    ).innerText = totalViews;

    frame.style.display="block";

    frame.srcdoc = games[i].code;

    window.scrollTo({
        top:frame.offsetTop,
        behavior:"smooth"
    });
}

/* FULLSCREEN */

function fullscreenGame(i){

    frame.style.display="block";

    frame.srcdoc = games[i].code;

    frame.requestFullscreen();
}

/* NEW TAB */

function newTab(i){

    const win =
    window.open();

    win.document.write(
        games[i].code
    );
}

/* DELETE */

function del(i){

    games.splice(i,1);

    save();

    render();
}

/* ADMINS */

function saveAdmins(){

    const vals =
    document.getElementById(
        "admins"
    ).value.split(",");

    adminPasswords = vals;

    localStorage.setItem(
        "admins",
        JSON.stringify(vals)
    );

    alert("Admins saved");
}

/* PARTICLES */

function toggleParticles(){

    const enabled =
    document.getElementById(
        "particlesToggle"
    ).checked;

    document.querySelector(
        ".particles"
    ).style.display =
    enabled ? "block" : "none";
}

/* BACKGROUNDS */

function changeBG(){

    const val =
    document.getElementById(
        "bgSelect"
    ).value;

    const body =
    document.body;

    const effects =
    document.getElementById(
        "bgEffects"
    );

    effects.innerHTML = "";

    body.style.background =
    "#050505";

    /* MATRIX */

    if(val==="matrix"){

        body.style.background =
        "linear-gradient(180deg,#000,#001100)";

        effects.innerHTML = `
        <div class="cyberLines"></div>

        <div class="glowOrb"
        style="
        width:300px;
        height:300px;
        background:#00ff66;
        top:20%;
        left:10%;
        ">
        </div>
        `;
    }

    /* STARS */

    if(val==="stars"){

        body.style.background =
        "radial-gradient(circle,#111,#000)";

        for(let i=0;i<120;i++){

            const star =
            document.createElement("div");

            star.style.position="absolute";
            star.style.width="2px";
            star.style.height="2px";
            star.style.background="white";
            star.style.left=Math.random()*100+"vw";
            star.style.top=Math.random()*100+"vh";
            star.style.opacity=Math.random();

            effects.appendChild(star);
        }
    }

    /* SUNSET */

    if(val==="sunset"){

        body.style.background =
        "linear-gradient(135deg,#ff5f6d,#ffc371)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:500px;
        height:500px;
        background:#ff9966;
        top:10%;
        left:60%;
        ">
        </div>
        `;
    }

    /* PURPLE */

    if(val==="purple"){

        body.style.background =
        "linear-gradient(135deg,#0f001f,#3a005f)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:450px;
        height:450px;
        background:#bb66ff;
        top:20%;
        left:30%;
        ">
        </div>
        `;
    }

    /* OCEAN */

    if(val==="ocean"){

        body.style.background =
        "linear-gradient(180deg,#001f3f,#005577)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:500px;
        height:500px;
        background:#00bbff;
        top:40%;
        left:50%;
        ">
        </div>
        `;
    }

    /* FIRE */

    if(val==="fire"){

        body.style.background =
        "linear-gradient(180deg,#220000,#661100)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:500px;
        height:500px;
        background:#ff4400;
        top:30%;
        left:30%;
        ">
        </div>
        `;
    }

    /* GRID */

    if(val==="grid"){

        body.style.background =
        "#050505";

        effects.innerHTML = `
        <div class="cyberLines"></div>

        <div class="glowOrb"
        style="
        width:400px;
        height:400px;
        background:#00ccff;
        top:20%;
        left:50%;
        ">
        </div>
        `;
    }

    /* FOREST */

    if(val==="forest"){

        body.style.background =
        "linear-gradient(180deg,#021,#041)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:500px;
        height:500px;
        background:#00ff99;
        top:50%;
        left:20%;
        ">
        </div>
        `;
    }

    /* BLOOD */

    if(val==="blood"){

        body.style.background =
        "linear-gradient(180deg,#100,#400)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:500px;
        height:500px;
        background:#ff0033;
        top:30%;
        left:60%;
        ">
        </div>
        `;
    }

    /* NEON */

    if(val==="neon"){

        body.style.background =
        "linear-gradient(135deg,#111,#000)";

        effects.innerHTML = `
        <div class="glowOrb"
        style="
        width:400px;
        height:400px;
        background:#ff00ff;
        top:20%;
        left:20%;
        ">
        </div>

        <div class="glowOrb"
        style="
        width:400px;
        height:400px;
        background:#00ffff;
        top:40%;
        left:60%;
        ">
        </div>
        `;
    }

    localStorage.setItem(
        "bg",
        val
    );
}

/* LOAD BG */

const savedBG =
localStorage.getItem("bg");

if(savedBG){

    document.getElementById(
        "bgSelect"
    ).value = savedBG;

    changeBG();
}

/* PARTICLES */

const p =
document.querySelector(".particles");

for(let i=0;i<100;i++){

    let s =
    document.createElement("span");

    s.style.left =
    Math.random()*100+"vw";

    s.style.animationDuration =
    (Math.random()*10+5)+"s";

    p.appendChild(s);
}

/* START */

render();

</script>

</body>
</html>
