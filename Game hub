<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Ultimate Game Hub</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial;
}

body{
    background:#050505;
    color:white;
    overflow-x:hidden;
    transition:.5s;
}

/* BACKGROUND FX */

.bgEffects{
    position:fixed;
    inset:0;
    z-index:-3;
    overflow:hidden;
    pointer-events:none;
}

/* PARTICLES */

.particles{
    position:fixed;
    inset:0;
    z-index:-2;
    pointer-events:none;
}

.particles span{
    position:absolute;
    width:3px;
    height:3px;
    background:white;
    opacity:.15;
    border-radius:50%;
    animation:float linear infinite;
}

@keyframes float{

    from{
        transform:translateY(100vh);
    }

    to{
        transform:translateY(-10vh);
    }
}

/* CYBER GRID */

.cyberLines{
    position:absolute;
    width:200%;
    height:200%;
    background:
    repeating-linear-gradient(
        90deg,
        transparent 0px,
        rgba(0,255,255,.05) 2px,
        transparent 4px
    );

    animation:moveGrid 20s linear infinite;
}

@keyframes moveGrid{

    from{
        transform:translateX(0);
    }

    to{
        transform:translateX(-50%);
    }
}

/* ORBS */

.glowOrb{
    position:absolute;
    border-radius:50%;
    filter:blur(80px);
    opacity:.35;
    animation:floatOrb 12s ease-in-out infinite;
}

@keyframes floatOrb{

    0%{
        transform:translate(0,0) scale(1);
    }

    50%{
        transform:translate(100px,-80px) scale(1.2);
    }

    100%{
        transform:translate(0,0) scale(1);
    }
}

/* HEADER */

header{
    text-align:center;
    padding:25px;
    background:rgba(20,20,20,.75);
    backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(255,255,255,.08);
}

header h1{
    font-size:48px;

    text-shadow:
    0 0 10px #00aaff,
    0 0 30px #00aaff,
    0 0 60px #00aaff;
}

/* TOPBAR */

.topbar{
    display:flex;
    justify-content:space-between;
    align-items:center;
    padding:15px 20px;
    background:rgba(15,15,15,.7);
    backdrop-filter:blur(12px);
    flex-wrap:wrap;
    gap:10px;
}

.search-area{
    display:flex;
    align-items:center;
    gap:10px;
    background:rgba(0,0,0,.4);
    padding:5px 15px;
    border-radius:30px;
}

.search-area input{
    background:transparent;
    border:none;
    color:white;
    padding:8px;
    width:200px;
    outline:none;
}

.gear{
    background:none;
    border:none;
    color:white;
    font-size:24px;
    cursor:pointer;
    transition:.3s;
}

.gear:hover{
    transform:rotate(90deg);
}

/* GAMES */

.games{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:20px;
    padding:20px;
}

.card{
    background:rgba(20,20,20,.65);
    border-radius:18px;
    overflow:hidden;
    border:1px solid rgba(255,255,255,.08);

    backdrop-filter:blur(12px);

    box-shadow:
    0 0 20px rgba(0,0,0,.35);

    transition:.3s;
}

.card:hover{

    transform:
    translateY(-10px)
    scale(1.02);

    box-shadow:
    0 0 35px rgba(0,170,255,.35);
}

.card img{
    width:100%;
    height:180px;
    object-fit:cover;
    background: #1a1a1a;
    /* Lazy loading optimization */
    loading: lazy;
}

.info{
    padding:15px;
}

.info h2{
    margin-bottom:10px;
}

.desc{
    color:#aaa;
    font-size:14px;
    margin-bottom:10px;
}

.meta{
    color:#777;
    font-size:12px;
    margin-top:6px;
}

/* BUTTONS */

.playBtn{
    width:100%;
    padding:10px;
    margin-top:8px;
    border:none;
    border-radius:10px;
    color:white;
    cursor:pointer;
    transition:.2s;
}

.playBtn:hover{
    transform:scale(1.03);
}

.blue{
    background:#0099ff;
}

.green{
    background:#00aa55;
}

.purple{
    background:#8844ff;
}

.orange{
    background:#ff8800;
}

/* LOGIN */

.loginOverlay{
    position:fixed;
    inset:0;
    background:rgba(0,0,0,.88);
    display:none;
    align-items:center;
    justify-content:center;
    z-index:10000;
}

.loginBox{
    background:#1d1d1d;
    padding:25px;
    border-radius:16px;
    width:320px;

    animation:pop .3s;
}

@keyframes pop{

    from{
        transform:scale(.7);
        opacity:0;
    }

    to{
        transform:scale(1);
        opacity:1;
    }
}

.loginBox input{
    width:100%;
    padding:10px;
    margin-top:12px;
    border:none;
    border-radius:10px;
    background:#2a2a2a;
    color:white;
}

.loginBox button{
    width:100%;
    padding:10px;
    margin-top:12px;
    border:none;
    border-radius:10px;
    background:#00aa55;
    color:white;
}

/* ADMIN PANEL */

.adminPanel{
    position:fixed;
    top:0;
    right:-460px;
    width:460px;
    height:100%;
    overflow:auto;

    background:
    linear-gradient(
        180deg,
        rgba(20,20,20,.97),
        rgba(5,5,5,.98)
    );

    backdrop-filter:blur(16px);

    box-shadow:
    -10px 0 40px rgba(0,0,0,.5);

    padding:20px;

    transition:.3s;

    z-index:9999;
}

.adminPanel.active{
    right:0;
}

.adminPanel input,
.adminPanel textarea,
.adminPanel select{
    width:100%;
    padding:10px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    background:#2a2a2a;
    color:white;
}

.addBtn{
    width:100%;
    padding:12px;
    margin-top:10px;
    border:none;
    border-radius:10px;
    color:white;
    cursor:pointer;
}

.editBtn{
    background:#ff8800;
}

.file-label{
    display:inline-block;
    background:#3a3a3a;
    padding:8px 12px;
    border-radius:8px;
    margin-top:8px;
    cursor:pointer;
    text-align:center;
    font-size:12px;
}

iframe{
    width:100%;
    height:700px;
    border:none;
    display:none;
    background:white;
    /* Optimize iframe loading */
    will-change: transform;
    contain: content;
}

/* Play time display */
.playtime-display {
    background: rgba(0,170,255,.1);
    border: 1px solid rgba(0,170,255,.3);
    border-radius: 8px;
    padding: 8px;
    margin-top: 8px;
    font-size: 12px;
    color: #00aaff;
}

.personal-best {
    background: rgba(255,170,0,.1);
    border: 1px solid rgba(255,170,0,.3);
    border-radius: 8px;
    padding: 8px;
    margin-top: 4px;
    font-size: 12px;
    color: #ffaa00;
}

/* Import/Export Modal */
.importExportModal {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.9);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10001;
}

.importExportBox {
    background: #1d1d1d;
    padding: 25px;
    border-radius: 16px;
    width: 90%;
    max-width: 500px;
    max-height: 80vh;
    overflow-y: auto;
    animation: pop .3s;
}

.importExportBox h2 {
    margin-bottom: 15px;
}

.importExportBox textarea {
    width: 100%;
    min-height: 100px;
    padding: 10px;
    border: none;
    border-radius: 10px;
    background: #2a2a2a;
    color: white;
    margin-top: 10px;
    font-family: monospace;
    font-size: 12px;
    resize: vertical;
}

.importExportBox button {
    width: 100%;
    padding: 10px;
    margin-top: 10px;
    border: none;
    border-radius: 10px;
    color: white;
    cursor: pointer;
}

/* Loading indicator */
.loading-overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.5);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 10002;
}

.loading-spinner {
    width: 50px;
    height: 50px;
    border: 3px solid rgba(255,255,255,.3);
    border-top-color: #00aaff;
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Performance optimizations */
.card {
    will-change: transform;
    contain: content;
}

.games {
    contain: layout style paint;
}

/* Batch import progress */
.progress-bar {
    width: 100%;
    height: 4px;
    background: #333;
    border-radius: 2px;
    margin-top: 10px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    background: #00aa55;
    transition: width .3s;
    width: 0%;
}

</style>
</head>

<body>

<div class="bgEffects" id="bgEffects"></div>

<div class="particles"></div>

<!-- Loading Overlay -->
<div class="loading-overlay" id="loadingOverlay">
    <div class="loading-spinner"></div>
</div>

<!-- LOGIN -->

<div class="loginOverlay" id="loginOverlay">

    <div class="loginBox">

        <h2>Admin Login</h2>

        <input
        type="password"
        id="pass"
        placeholder="Password">

        <button onclick="login()">
        Unlock
        </button>

    </div>

</div>

<!-- Import/Export Modal -->
<div class="importExportModal" id="importExportModal">
    <div class="importExportBox">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 15px;">
            <h2 id="modalTitle">📦 Import/Export Games</h2>
            <button onclick="closeImportExport()" style="
                background: red;
                color: white;
                border: none;
                width: 35px;
                height: 35px;
                border-radius: 10px;
                cursor: pointer;
            ">✕</button>
        </div>

        <div id="exportSection">
            <h3>📤 Export All Games</h3>
            <p style="color: #aaa; font-size: 12px; margin-top: 5px;">
                Copy this code to transfer all games
            </p>
            <textarea id="exportCode" readonly style="min-height: 150px;"></textarea>
            <button onclick="copyExportCode()" style="background: #0099ff;">
                📋 Copy Transfer Code
            </button>
        </div>

        <div style="margin: 20px 0; border-top: 1px solid #333;"></div>

        <div id="importSection">
            <h3>📥 Import Games</h3>
            <p style="color: #aaa; font-size: 12px; margin-top: 5px;">
                Paste transfer code to import games
            </p>
            <textarea id="importCode" placeholder="Paste transfer code here..."></textarea>
            
            <label style="display: flex; align-items: center; margin-top: 10px; gap: 8px;">
                <input type="checkbox" id="replaceExisting">
                <span style="font-size: 12px;">Replace existing games</span>
            </label>
            
            <button onclick="importGames()" style="background: #00aa55;">
                📥 Import Games
            </button>
            
            <div class="progress-bar" id="importProgress" style="display: none;">
                <div class="progress-fill" id="progressFill"></div>
            </div>
        </div>
    </div>
</div>

<header>

    <h1>🎮 GAME HUB</h1>

</header>

<div class="topbar">

    <div class="search-area">
        <span>🔍</span>
        <input type="text" id="searchInput" placeholder="Search games..." onkeyup="filterGames()">
    </div>

    <div>
        Total Plays:
        <span id="totalViews">0</span>
        |
        Games: <span id="totalGames">0</span>
    </div>

    <div style="display: flex; gap: 10px;">
        <button
        class="gear"
        onclick="openImportExport()"
        title="Import/Export Games">
        📦
        </button>
        <button
        class="gear"
        onclick="toggleAdmin()"
        title="Admin Panel">
        ⚙️
        </button>
    </div>

</div>

<!-- GAMES -->

<div class="games" id="games"></div>

<!-- GAME VIEW -->

<iframe id="frame" sandbox="allow-scripts allow-same-origin"></iframe>

<!-- ADMIN -->

<div class="adminPanel" id="adminPanel">

    <div style="
    display:flex;
    justify-content:space-between;
    align-items:center;
    ">

        <h2>ADMIN PANEL</h2>

        <button onclick="closeAdmin()" style="
        background:red;
        color:white;
        border:none;
        width:35px;
        height:35px;
        border-radius:10px;
        cursor:pointer;
        ">
        ✕
        </button>

    </div>

    <br>

    <input
    id="title"
    placeholder="Game Title">

    <input
    id="image"
    placeholder="Image URL">

    <div>
        <label class="file-label" onclick="document.getElementById('imageFileInput').click()">📁 Upload Image File</label>
        <input type="file" id="imageFileInput" accept="image/*" style="display:none" onchange="uploadImageFile()">
    </div>

    <textarea
    id="desc"
    rows="3"
    placeholder="Game Description"></textarea>

    <textarea
    id="code"
    rows="8"
    placeholder="FULL HTML GAME"></textarea>

    <div>
        <label class="file-label" onclick="document.getElementById('htmlFileInput').click()">📄 Upload HTML File</label>
        <input type="file" id="htmlFileInput" accept=".html" style="display:none" onchange="uploadHTMLFile()">
    </div>

    <button
    class="addBtn"
    onclick="addGame()"
    style="background: #00aa55;">
    ADD GAME
    </button>

    <br><br>

    <h3>Backgrounds</h3>

    <select id="bgSelect" onchange="changeBG()">

        <option value="default">Default</option>
        <option value="matrix">Matrix</option>
        <option value="stars">Stars</option>
        <option value="sunset">Sunset</option>
        <option value="purple">Purple Void</option>
        <option value="ocean">Ocean</option>
        <option value="fire">Fire</option>
        <option value="grid">Cyber Grid</option>
        <option value="forest">Forest</option>
        <option value="blood">Blood</option>
        <option value="neon">Neon</option>

    </select>

    <br><br>

    <label>
        <input
        type="checkbox"
        id="particlesToggle"
        checked
        onchange="toggleParticles()">
        Particles
    </label>

    <br><br>

    <input
    id="admins"
    placeholder="Admin Passwords comma separated">

    <button
    class="addBtn"
    onclick="saveAdmins()"
    style="background: #8844ff;">
    SAVE ADMINS
    </button>

    <br><br>

    <h3>Games</h3>

    <div id="adminList"></div>

</div>

<script>

/* ADMINS */

let adminPasswords =
JSON.parse(localStorage.getItem("admins"))
|| ["1234"];

let unlocked =
sessionStorage.getItem("admin")
=== "true";

/* LOGIN */

function openLogin(){

    document.getElementById(
        "loginOverlay"
    ).style.display = "flex";
}

function login(){

    const val =
    document.getElementById("pass")
    .value;

    if(adminPasswords.includes(val)){

        unlocked = true;

        sessionStorage.setItem(
            "admin",
            "true"
        );

        document.getElementById(
            "loginOverlay"
        ).style.display = "none";

        document.getElementById(
            "adminPanel"
        ).classList.add("active");

        document.body.animate([
            {filter:"brightness(1)"},
            {filter:"brightness(2)"},
            {filter:"brightness(1)"}
        ],{
            duration:600
        });

        alert("Admin unlocked");

    }else{

        alert("Wrong password");
    }
}

/* ADMIN */

function toggleAdmin(){

    if(!unlocked){

        openLogin();
        return;
    }

    document.getElementById(
        "adminPanel"
    ).classList.toggle("active");
}

function closeAdmin(){

    document.getElementById(
        "adminPanel"
    ).classList.remove("active");
}

/* DATA */

let games =
JSON.parse(localStorage.getItem("games"))
|| [];

let totalViews =
localStorage.getItem("totalViews")
|| 0;

// Play time tracking data
let playTimeData = JSON.parse(localStorage.getItem("playTimeData")) || {};

// Personal best tracking
let personalBests = JSON.parse(localStorage.getItem("personalBests")) || {};

document.getElementById(
    "totalViews"
).innerText = totalViews;

document.getElementById(
    "totalGames"
).innerText = games.length;

/* CROSS-TAB SYNC */
window.addEventListener('storage', function(e) {
    if(e.key === 'games') {
        games = JSON.parse(e.newValue) || [];
        render();
        filterGames();
        document.getElementById("totalGames").innerText = games.length;
    }
    if(e.key === 'totalViews') {
        totalViews = e.newValue || 0;
        document.getElementById("totalViews").innerText = totalViews;
    }
    if(e.key === 'admins') {
        adminPasswords = JSON.parse(e.newValue) || ["1234"];
    }
    if(e.key === 'playTimeData') {
        playTimeData = JSON.parse(e.newValue) || {};
        render();
    }
    if(e.key === 'personalBests') {
        personalBests = JSON.parse(e.newValue) || {};
        render();
    }
});

/* SAVE */

function save(){
    localStorage.setItem(
        "games",
        JSON.stringify(games)
    );
    document.getElementById("totalGames").innerText = games.length;
}

/* IMPORT/EXPORT FUNCTIONS */

function openImportExport() {
    document.getElementById("importExportModal").style.display = "flex";
    generateExportCode();
}

function closeImportExport() {
    document.getElementById("importExportModal").style.display = "none";
}

function generateExportCode() {
    const exportData = {
        version: "2.0",
        exportDate: new Date().toISOString(),
        games: games.map(game => ({
            title: game.title,
            image: game.image,
            desc: game.desc,
            code: game.code,
            views: game.views,
            date: game.date,
            updated: game.updated
        })),
        playTimeData: playTimeData,
        personalBests: personalBests
    };
    
    // Compress the data
    const jsonStr = JSON.stringify(exportData);
    const compressed = btoa(encodeURIComponent(jsonStr));
    
    document.getElementById("exportCode").value = compressed;
}

function copyExportCode() {
    const exportCode = document.getElementById("exportCode");
    exportCode.select();
    document.execCommand("copy");
    
    // Visual feedback
    const btn = event.target;
    const originalText = btn.textContent;
    btn.textContent = "✅ Copied!";
    btn.style.background = "#00aa55";
    
    setTimeout(() => {
        btn.textContent = originalText;
        btn.style.background = "#0099ff";
    }, 2000);
}

async function importGames() {
    const importCode = document.getElementById("importCode").value.trim();
    const replaceExisting = document.getElementById("replaceExisting").checked;
    
    if (!importCode) {
        alert("Please paste a transfer code first!");
        return;
    }
    
    try {
        // Show loading
        document.getElementById("loadingOverlay").style.display = "flex";
        const progressBar = document.getElementById("importProgress");
        const progressFill = document.getElementById("progressFill");
        progressBar.style.display = "block";
        progressFill.style.width = "0%";
        
        // Decode the transfer code
        const jsonStr = decodeURIComponent(atob(importCode));
        const importData = JSON.parse(jsonStr);
        
        if (!importData.games || !Array.isArray(importData.games)) {
            throw new Error("Invalid transfer code format");
        }
        
        // Update progress
        progressFill.style.width = "20%";
        await sleep(100);
        
        // Process games in batches to prevent UI freezing
        const batchSize = 5;
        const totalGames = importData.games.length;
        let processedGames = 0;
        
        if (replaceExisting) {
            // Replace all games
            games = [];
            playTimeData = {};
            personalBests = {};
        }
        
        for (let i = 0; i < totalGames; i += batchSize) {
            const batch = importData.games.slice(i, i + batchSize);
            
            // Process batch
            batch.forEach(importedGame => {
                games.push({
                    title: importedGame.title,
                    image: importedGame.image || '',
                    desc: importedGame.desc || '',
                    code: importedGame.code,
                    views: importedGame.views || 0,
                    date: importedGame.date || new Date().toLocaleDateString(),
                    updated: importedGame.updated || new Date().toLocaleString()
                });
            });
            
            processedGames += batch.length;
            
            // Update progress
            const progress = 20 + (processedGames / totalGames) * 70;
            progressFill.style.width = progress + "%";
            
            // Allow UI to update
            await sleep(50);
        }
        
        // Import play time data if available
        if (importData.playTimeData) {
            if (replaceExisting) {
                playTimeData = importData.playTimeData;
            } else {
                // Merge play time data
                Object.keys(importData.playTimeData).forEach(key => {
                    if (!playTimeData[key]) {
                        playTimeData[key] = importData.playTimeData[key];
                    }
                });
            }
        }
        
        // Import personal bests if available
        if (importData.personalBests) {
            if (replaceExisting) {
                personalBests = importData.personalBests;
            } else {
                // Merge personal bests
                Object.keys(importData.personalBests).forEach(key => {
                    if (!personalBests[key] || importData.personalBests[key] > personalBests[key]) {
                        personalBests[key] = importData.personalBests[key];
                    }
                });
            }
        }
        
        // Save everything
        progressFill.style.width = "95%";
        await sleep(100);
        
        save();
        localStorage.setItem("playTimeData", JSON.stringify(playTimeData));
        localStorage.setItem("personalBests", JSON.stringify(personalBests));
        
        progressFill.style.width = "100%";
        await sleep(200);
        
        // Hide loading
        document.getElementById("loadingOverlay").style.display = "none";
        progressBar.style.display = "none";
        
        // Clear import field
        document.getElementById("importCode").value = "";
        
        // Update UI
        render();
        filterGames();
        
        alert(`✅ Successfully imported ${totalGames} games!`);
        
    } catch (error) {
        console.error("Import error:", error);
        document.getElementById("loadingOverlay").style.display = "none";
        document.getElementById("importProgress").style.display = "none";
        alert("❌ Failed to import games. Please check the transfer code and try again.\n\nError: " + error.message);
    }
}

function sleep(ms) {
    return new Promise(resolve => setTimeout(resolve, ms));
}

/* FILE UPLOADS */

function uploadImageFile() {
    const file = document.getElementById('imageFileInput').files[0];
    if(file) {
        // Compress image before storing
        const reader = new FileReader();
        reader.onload = function(e) {
            compressImage(e.target.result, 800, 0.7, function(compressed) {
                document.getElementById('image').value = compressed;
            });
        };
        reader.readAsDataURL(file);
    }
}

function compressImage(dataUrl, maxWidth, quality, callback) {
    const img = new Image();
    img.onload = function() {
        const canvas = document.createElement('canvas');
        let width = img.width;
        let height = img.height;
        
        if (width > maxWidth) {
            height = (height * maxWidth) / width;
            width = maxWidth;
        }
        
        canvas.width = width;
        canvas.height = height;
        
        const ctx = canvas.getContext('2d');
        ctx.drawImage(img, 0, 0, width, height);
        
        callback(canvas.toDataURL('image/jpeg', quality));
    };
    img.src = dataUrl;
}

function uploadHTMLFile() {
