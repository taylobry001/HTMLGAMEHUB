/* Play time tracking functions */
function formatPlayTime(seconds) {
    if (!seconds || seconds === 0) return '0min';
    
    const hours = Math.floor(seconds / 3600);
    const minutes = Math.floor((seconds % 3600) / 60);
    
    if (hours > 0) {
        return `${hours}h ${minutes}min`;
    } else {
        return `${minutes}min`;
    }
}

function getPlayTime(gameIndex) {
    const key = `game_${gameIndex}`;
    return playTimeData[key] || 0;
}

function getPersonalBest(gameIndex) {
    const key = `game_${gameIndex}`;
    return personalBests[key] || 0;
}

function formatPersonalBest(seconds) {
    if (!seconds || seconds === 0) return 'No record yet';
    return formatPlayTime(seconds);
}

