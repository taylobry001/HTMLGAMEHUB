/* PLAY TIME TRACKER */
let playStartTime = null;
let currentGameIndex = null;
let playTimeInterval = null;

function startPlayTimer(gameIndex) {
    stopPlayTimer();
    
    currentGameIndex = gameIndex;
    playStartTime = Date.now();
    
    playTimeInterval = setInterval(() => {
        updatePlayTime(gameIndex);
    }, 1000);
}

function stopPlayTimer() {
    if (playTimeInterval) {
        clearInterval(playTimeInterval);
        playTimeInterval = null;
    }
    
    if (currentGameIndex !== null && playStartTime !== null) {
        updatePlayTime(currentGameIndex);
        
        const sessionTime = Math.floor((Date.now() - playStartTime) / 1000);
        const key = `game_${currentGameIndex}`;
        const currentBest = personalBests[key] || 0;
        
        if (sessionTime > currentBest) {
            personalBests[key] = sessionTime;
            localStorage.setItem("personalBests", JSON.stringify(personalBests));
        }
    }
    
    currentGameIndex = null;
    playStartTime = null;
}

function updatePlayTime(gameIndex) {
    if (playStartTime === null || gameIndex !== currentGameIndex) return;
    
    const key = `game_${gameIndex}`;
    const previousTime = playTimeData[key] || 0;
    
    playTimeData[key] = previousTime + 1;
    localStorage.setItem("playTimeData", JSON.stringify(playTimeData));
    
    // Update personal best
    const currentBest = personalBests[key] || 0;
    if (playTimeData[key] > currentBest) {
        personalBests[key] = playTimeData[key];
        localStorage.setItem("personalBests", JSON.stringify(personalBests));
    }
}

/* RESET PLAY TIME */
function resetPlayTime(gameIndex) {
    if (confirm(`Reset play time and personal best for "${games[gameIndex].title}"?`)) {
        const key = `game_${gameIndex}`;
        delete playTimeData[key];
        delete personalBests[key];
        
        localStorage.setItem("playTimeData", JSON.stringify(playTimeData));
        localStorage.setItem("personalBests", JSON.stringify(personalBests));
        
        render();
    }
}

/* PLAY - Optimized */

function play(i){
    games[i].views++;
    totalViews++;
    
    localStorage.setItem("totalViews", totalViews);
    save();
    
    document.getElementById("totalViews").innerText = totalViews;
    
    const frame = document.getElementById('frame');
    frame.style.display = "block";
    
    // Use srcdoc for better performance
    frame.srcdoc = games[i].code;
    
    // Smooth scroll to frame
    frame.scrollIntoView({ behavior: "smooth", block: "start" });
    
    startPlayTimer(i);
}

/* FULLSCREEN */

function fullscreenGame(i){
    const frame = document.getElementById('frame');
    frame.style.display = "block";
    frame.srcdoc = games[i].code;
    
    if (frame.requestFullscreen) {
        frame.requestFullscreen();
    } else if (frame.webkitRequestFullscreen) {
        frame.webkitRequestFullscreen();
    }
    
    startPlayTimer(i);
}

/* NEW TAB - Optimized */

function newTab(i){
    const game = games[i];
    const win = window.open('', '_blank');
    
    // Write optimized content
    win.document.write(`
        <!DOCTYPE html>
        <html>
        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>${escapeHtml(game.title)}</title>
            <style>
                * { margin: 0; padding: 0; box-sizing: border-box; }
                body { overflow: hidden; }
            </style>
        </head>
        <body>
            <script>
                // Track views and play time
                try {
                    const totalViews = localStorage.getItem('totalViews');
                    if(totalViews) {
                        localStorage.setItem('totalViews', parseInt(totalViews) + 1);
                    }
                    
                    const gamesData = localStorage.getItem('games');
                    if(gamesData) {
                        const gamesArr = JSON.parse(gamesData);
                        if(gamesArr[${i}]) {
                            gamesArr[${i}].views = (gamesArr[${i}].views || 0) + 1;
                            localStorage.setItem('games', JSON.stringify(gamesArr));
                        }
                    }
                    
                    // Play time tracking
                    let playInterval = setInterval(() => {
                        const playTimeData = JSON.parse(localStorage.getItem('playTimeData') || '{}');
                        const key = 'game_${i}';
                        playTimeData[key] = (playTimeData[key] || 0) + 1;
                        
                        const personalBests = JSON.parse(localStorage.getItem('personalBests') || '{}');
                        if (playTimeData[key] > (personalBests[key] || 0)) {
                            personalBests[key] = playTimeData[key];
                            localStorage.setItem('personalBests', JSON.stringify(personalBests));
                        }
                        
                        localStorage.setItem('playTimeData', JSON.stringify(playTimeData));
                    }, 1000);
                    
                    window.addEventListener('beforeunload', () => {
                        clearInterval(playInterval);
                    });
                } catch(e) {
                    console.error('Tracking error:', e);
                }
            <\/script>
            ${game.code}
        </body>
        </html>
    `);
    
    // Increment local immediately
    games[i].views++;
    totalViews++;
    localStorage.setItem("totalViews", totalViews);
    save();
    document.getElementById("totalViews").innerText = totalViews;
    
    startPlayTimer(i);
}

// Stop play timer when frame is hidden
document.addEventListener('fullscreenchange', () => {
    if (!document.fullscreenElement) {
        const frame = document.getElementById('frame');
        if (frame.style.display === 'none') {
            stopPlayTimer();
        }
    }
});

const frameObserver = new MutationObserver((mutations) => {
    mutations.forEach((mutation) => {
        if (mutation.type === 'attributes' && mutation.attributeName === 'style') {
            const frame = document.getElementById('frame');
            if (frame.style.display === 'none') {
                stopPlayTimer();
            }
        }
    });
});

const frame = document.getElementById('frame');
frameObserver.observe(frame, { attributes: true });

/* DELETE */

function del(i){
